# lifeos-lifeosd — Rust daemon (Axi orchestrator) containerized
#
# Phase 3 of the architecture pivot — most complex of the CPU-only services
# because it owns the SQLite + sqlite-vec encrypted memory store and several
# bind mounts to /var/lib/lifeos.
# PRD: docs/strategy/prd-architecture-pivot-lean-bootc-quadlet.md
#
# === IMPORTANT — scope of this container ===
#
# This container ships the daemon's HTTP/agentic surfaces:
#   - REST API on 127.0.0.1:8081
#   - WebSocket on /ws
#   - SimpleX bridge → 127.0.0.1:5226
#   - Telegram bridge (in-process)
#   - LLM router → talks to llama-server on :8082, llama-embeddings on :8083,
#     lifeos-tts on :8084 (all on host loopback via Network=host)
#   - SQLite + sqlite-vec memory store via bind mount to /var/lib/lifeos
#
# What it does NOT ship in Phase 3:
#   - GTK4 desktop overlay ("Eye of Axi" tray icon)
#   - Direct Wayland socket access
#   - PipeWire / D-Bus session bus integration
#   - Screen capture / camera direct access
#
# Those desktop-integration paths stay on the HOST (lifeosd-desktop, a small
# companion binary that talks to this container's HTTP API). Splitting that
# out is Phase 3b (follow-up). The benefit: the bulk of lifeosd (~95% of
# functionality) gets the Quadlet treatment — atomic deploys, rollbacks,
# resource limits — while desktop integration that REQUIRES session state
# stays where it has to be.
#
# Build:
#   podman build -t 10.66.66.1:5001/lifeos-lifeosd:dev \
#     -f containers/lifeos-lifeosd/Containerfile .
#   (note: build context is repo root because Cargo.toml + workspace lives there)

# ---------------------------------------------------------------------------
# Stage 1 — builder
# ---------------------------------------------------------------------------
# Heavy: Rust toolchain, native deps for SQLite/openssl/dbus, full cargo cache.
# Kept entirely separate from runtime so we don't ship gcc, headers, or .cargo/.
FROM fedora:44 AS builder

RUN dnf -y install \
        rust cargo \
        gcc gcc-c++ make pkgconf-pkg-config \
        openssl-devel \
        sqlite-devel \
        dbus-devel \
        glib2-devel \
        wayland-devel \
        libxkbcommon-devel \
        ca-certificates \
        git \
        && \
    dnf clean all

WORKDIR /src

# Copy ONLY Cargo manifests first → Docker layer cache for deps. Source code
# changes don't invalidate the dependency build, only the final cargo build.
COPY Cargo.toml Cargo.lock ./
COPY daemon/Cargo.toml daemon/
COPY cli/Cargo.toml cli/
COPY tests/Cargo.toml tests/
RUN mkdir -p daemon/src cli/src tests/src && \
    echo 'fn main(){}' > daemon/src/main.rs && \
    echo 'fn main(){}' > cli/src/main.rs && \
    echo 'fn main(){}' > tests/src/main.rs && \
    cargo fetch --manifest-path daemon/Cargo.toml

# Now copy real sources and build for real. The Cargo cache from `cargo fetch`
# is reused, so this rebuild only compiles our crates, not the world.
COPY daemon ./daemon
COPY cli ./cli
COPY tests ./tests
COPY contracts ./contracts

# Build features: drop BOTH `ui-overlay` and `wake-word`.
#   - `ui-overlay` (GTK4) makes no sense in a headless container.
#   - `wake-word` (rustpotter) needs continuous PipeWire input from the user
#     session. The container has no PipeWire socket — the feature would
#     either crash or log-spam attempting to open the input stream.
# Both desktop-bound paths move to the host companion lifeosd-desktop
# (Phase 3b) which can talk to this container's HTTP API for the
# Axi-side responses while owning the session-side capture itself.
RUN cargo build \
        --manifest-path daemon/Cargo.toml \
        --release \
        --features "dbus,http-api,messaging"

# Sanity: the binary exists and runs --version.
RUN /src/target/release/lifeosd --version || \
    /src/target/release/lifeosd --help | head -1

# ---------------------------------------------------------------------------
# Stage 1b — whisper.cpp STT tools (Phase 7 of architecture pivot)
# ---------------------------------------------------------------------------
# Phase 7 of prd-architecture-pivot-lean-bootc-quadlet.md moves whisper-cli
# out of bootc (saves ~10 MB host) and INTO this container, because:
#   - lifeosd invokes whisper-cli as a tokio subprocess for file-based
#     transcription (sensory_pipeline::transcribe_audio_file, simplex voice
#     notes, meeting assistant clip mode).
#   - lifeosd lives in this container post-Phase-3, so the binary must be
#     reachable from inside this container.
#   - Shipping whisper-cli HERE (vs a separate side container with HTTP
#     wrapper) is the simpler of the two PRD-permitted paths and avoids a
#     daemon-wide subprocess→HTTP refactor that would need hands-on audio
#     validation. The HTTP-wrapper variant is a possible Phase 7b follow-up.
#
# whisper-stream (live PipeWire capture for wake-word / meeting realtime)
# is NOT shipped here — it needs the user's PipeWire socket bound in, and
# that path is deferred to the lifeosd-desktop companion (Phase 3b).

# ---------------------------------------------------------------------------
# Stage 1c — WeSpeaker ONNX model fetch (speaker identification)
# ---------------------------------------------------------------------------
# WeSpeaker ResNet34 ONNX (~24 MB) used by daemon/src/speaker_id.rs via the
# lifeos-speaker-embedding.py Python helper. Pre-Phase-3-trim it lived on
# the bootc host at /usr/share/lifeos/models/wespeaker; moved INTO this
# container so the bootc image carries no LifeOS-specific model bytes.
# Daemon code path stays the same (/usr/share/lifeos/models/wespeaker/...
# is INSIDE the container now, not on the host).
FROM fedora:44 AS wespeaker-fetch

RUN dnf -y install curl && dnf clean all
RUN set -eux && \
    mkdir -p /out/models/wespeaker && \
    curl -fSL --retry 3 --connect-timeout 120 \
      -o /out/models/wespeaker/voxceleb_resnet34_LM.onnx \
      "https://huggingface.co/Wespeaker/wespeaker-voxceleb-resnet34-LM/resolve/main/voxceleb_resnet34_LM.onnx?download=true" && \
    test -s /out/models/wespeaker/voxceleb_resnet34_LM.onnx

FROM fedora:44 AS whisper-builder

RUN dnf install -y cmake make gcc-c++ git openssl-devel curl && \
    dnf clean all

# Pin whisper.cpp to a release tag for reproducibility — same tag the bootc
# image used to ship before Phase 7 cutover.
ARG WHISPER_CPP_TAG=v1.8.4
RUN set -eux && \
    git clone --branch "${WHISPER_CPP_TAG}" --depth=1 \
        https://github.com/ggml-org/whisper.cpp /tmp/whisper.cpp && \
    cmake -S /tmp/whisper.cpp -B /tmp/whisper.cpp/build \
        -DCMAKE_BUILD_TYPE=Release \
        -DBUILD_SHARED_LIBS=OFF \
        -DWHISPER_BUILD_TESTS=OFF \
        -DWHISPER_SDL2=OFF \
        -DWHISPER_BUILD_EXAMPLES=ON && \
    cmake --build /tmp/whisper.cpp/build -j"$(nproc)" --target whisper-cli && \
    CLI_BIN="$(find /tmp/whisper.cpp/build -name 'whisper-cli' -type f | head -1)" && \
    test -n "${CLI_BIN}" && \
    install -D -m 0755 "${CLI_BIN}" /out/whisper-cli && \
    rm -rf /tmp/whisper.cpp

# ---------------------------------------------------------------------------
# Stage 2 — runtime
# ---------------------------------------------------------------------------
# fedora-minimal:44 because we need libsqlite3 + libdbus + libssl runtime libs
# and it's smaller than full fedora:44 (~80 MB vs ~250 MB). distroless is
# tempting but lacks D-Bus libs we need for the SimpleX bridge IPC.
FROM fedora-minimal:44 AS runtime

RUN microdnf install -y \
        ca-certificates \
        sqlite-libs \
        openssl-libs \
        dbus-libs \
        libcurl \
        glib2 \
        tini \
        python3 \
        python3-pip \
        python3-numpy \
        --setopt=tsflags=nodocs && \
    microdnf clean all

# Speaker-identification runtime: onnxruntime via pip (no Fedora rpm yet).
# Used by daemon/src/speaker_id.rs through lifeos-speaker-embedding.py.
# Adds ~80 MB to the runtime image but trims that same weight off bootc.
RUN pip3 install --no-cache-dir onnxruntime && \
    python3 -c "import onnxruntime; print('onnxruntime', onnxruntime.__version__)"

# Copy just the binary and the bundled sqlite-vec extension if any (it's
# statically linked into the daemon today via the rusqlite-vec crate, so no
# separate .so needed — verified in cargo tree).
COPY --from=builder /src/target/release/lifeosd /usr/bin/lifeosd

# Phase 7: whisper-cli for file-based transcription. The daemon's STT paths
# resolve `whisper-cli` via PATH lookup (sensory_pipeline.rs:resolve_binary),
# so /usr/bin/whisper-cli is enough. Models are read from
# /var/lib/lifeos/models/whisper which is bind-mounted from the host (the
# host-side `lifeos-stt-setup.sh` continues to download model files there).
COPY --from=whisper-builder /out/whisper-cli /usr/bin/whisper-cli

# Speaker identification: WeSpeaker ONNX model + Python helper. The daemon
# spawns python3 lifeos-speaker-embedding.py at runtime to extract a 256-D
# embedding from a WAV; both paths are hard-coded in
# daemon/src/speaker_id.rs (SPEAKER_EMBEDDING_SCRIPT,
# WESPEAKER_MODEL_PATH). Both moved INTO this image as part of the bootc
# trim so the host carries no model bytes.
COPY --from=wespeaker-fetch /out/models/wespeaker/voxceleb_resnet34_LM.onnx /usr/share/lifeos/models/wespeaker/voxceleb_resnet34_LM.onnx
COPY image/files/usr/local/bin/lifeos-speaker-embedding.py /usr/local/bin/lifeos-speaker-embedding.py
RUN chmod +x /usr/local/bin/lifeos-speaker-embedding.py

# Dashboard static assets — the Quadlet sets LIFEOS_DASHBOARD_DIR=
# /usr/share/lifeos/dashboard. Pre-Phase-3 this lived on the host bootc
# image; Axum's ServeDir does not error on missing directory, it just
# returns 404 for every request — silent dashboard breakage. We bake the
# assets into the runtime image so the in-process web server has something
# to serve. Build context is the repo root (per side-images.yml workflow).
COPY daemon/static/dashboard /usr/share/lifeos/dashboard

# UID/GID strategy — Phase 3a pragmatic choice.
#
# The bind mount /var/lib/lifeos comes from the host owned by uid=1000
# (lifeos) with mode 600/700 on critical files (memory.db has 600 because
# it's encrypted state). SELinux ':z'/':Z' relabel security context but
# do NOT change file UIDs. A container running as a non-root UID would
# get permission denied opening memory.db.
#
# Correct long-term fix: podman `UserNS=keep-id:uid=1000,gid=1000` on the
# Quadlet (maps container 1000 ↔ host 1000), which requires subuid setup
# on the host for the lifeos user. Tracked for Phase 3b.
#
# Phase 3a pragmatic decision: container runs as ROOT inside (no USER
# directive). The Quadlet is rootful → systemd PID 1 owns the container,
# external defenses (Capa 1 storage isolation, Capa 2 sudoers, Capa 5
# code blocklist) provide the real security boundary. The internal
# non-root convention is dropped to unblock the bind mount.
#
# Intentionally NO mkdir/chown of /var/lib/lifeos or /etc/lifeos here:
# bind mounts at runtime mask whatever in-image directories exist, so
# any chown applied at build time is a no-op that misleads readers
# into thinking the in-image owner matters.

# Daemon's HTTP API.
EXPOSE 8081

# tini for clean signal forwarding so SIGTERM from systemd reaches the daemon
# and triggers its graceful-shutdown path (flushes session_store, closes DB).
ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["/usr/bin/lifeosd"]

LABEL org.opencontainers.image.title="lifeos-lifeosd"
LABEL org.opencontainers.image.description="LifeOS Rust daemon (Axi orchestrator) — HTTP API + SQLite memory + agentic chat"
LABEL org.opencontainers.image.source="https://github.com/hectormr206/lifeos"
LABEL org.opencontainers.image.licenses="Apache-2.0"
