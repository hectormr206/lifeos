# lifeos-tts — Kokoro TTS server (CPU-only, fully self-contained)
#
# Phase 6 of the architecture pivot — Kokoro Python venv + voice models +
# manifest + server script all live INSIDE this image now. The bootc base
# no longer ships /opt/lifeos/kokoro-env (~850 MB removed from bootc).
# PRD: docs/strategy/prd-architecture-pivot-lean-bootc-quadlet.md
#
# Runtime contract:
#   - HTTP API on 127.0.0.1:8084 via Network=host in the Quadlet.
#   - HF_HUB_OFFLINE=1 — model weights are pre-warmed at build time. No
#     runtime network access required.
#   - voices-manifest.json shipped INSIDE the image at the same path the
#     script expects (/opt/lifeos/kokoro-env/voices-manifest.json).
#   - Server script baked at /usr/local/bin/lifeos-tts-server.py.
#
# Build:
#   podman build -t 10.66.66.1:5001/lifeos-tts:dev \
#     -f containers/lifeos-tts/Containerfile \
#     containers/lifeos-tts/

# ---------------------------------------------------------------------------
# Stage 1 — builder
# ---------------------------------------------------------------------------
# Heavy: torch + kokoro + pre-warm + manifest gen. Kept separate so the
# runtime image doesn't ship gcc, headers, or pip cache.
FROM python:3.12-slim AS builder

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        ca-certificates \
        build-essential \
        git \
        libsndfile1 \
        && \
    rm -rf /var/lib/apt/lists/*

RUN python3 -m venv /opt/lifeos/kokoro-env

# Vendored wheels for torch — same approach the old bootc kokoro-builder
# used. If build-assets/wheels/ is empty (local builds without git LFS
# pulls), pip falls through to https://download.pytorch.org/whl/cpu.
# CI runs from a checkout that should have the wheels populated.
COPY build-assets/wheels/ /build-assets/wheels/

# All Python deps pinned to match what the bootc image used to ship —
# preserves identical synthesis behaviour pre/post Phase 6 flip.
# torch 2.4.1 + numpy 1.26.x ABI compat (numpy 2.x breaks torch 2.4).
RUN /opt/lifeos/kokoro-env/bin/pip install --upgrade pip && \
    /opt/lifeos/kokoro-env/bin/pip install --no-cache-dir \
        --find-links /build-assets/wheels/ \
        "torch==2.4.1+cpu" \
        --index-url https://download.pytorch.org/whl/cpu && \
    /opt/lifeos/kokoro-env/bin/pip install --no-cache-dir \
        --find-links /build-assets/wheels/ \
        "kokoro==0.9.4" \
        "aiohttp==3.13.5" \
        "soundfile==0.13.1" \
        "numpy==1.26.4" \
        "misaki[en]" \
        "misaki[es]"

# Pre-warm: download voice .pt weights into HF_HOME (bakes ~200-500 MB of
# model files into the image so the runtime container has zero network
# dependency). Same script the bootc image used.
COPY containers/lifeos-tts/prewarm-kokoro.py /build/prewarm-kokoro.py
ENV HF_HOME=/opt/lifeos/kokoro-env/hf-cache
RUN HF_HUB_OFFLINE=0 \
    /opt/lifeos/kokoro-env/bin/python3 /build/prewarm-kokoro.py

# Verify default voice artifact exists post-prewarm.
RUN find /opt/lifeos/kokoro-env -name 'if_sara*' | grep -q '.' || \
    (echo 'ERROR: if_sara voice artifact not found after pre-warm' && exit 1)

# Generate voices-manifest.json — the runtime script reads this from
# /opt/lifeos/kokoro-env/voices-manifest.json to populate the /voices
# endpoint and validate /tts voice= parameters.
COPY containers/lifeos-tts/build-kokoro-manifest.py /build/build-kokoro-manifest.py
RUN LIFEOS_TTS_DEFAULT_VOICE=if_sara \
    /opt/lifeos/kokoro-env/bin/python3 /build/build-kokoro-manifest.py \
        --venv-dir /opt/lifeos/kokoro-env \
        --output /opt/lifeos/kokoro-env/voices-manifest.json && \
    test -s /opt/lifeos/kokoro-env/voices-manifest.json

# Strip build artefacts.
RUN find /opt/lifeos/kokoro-env -type d -name '__pycache__' -exec rm -rf {} + 2>/dev/null || true && \
    find /opt/lifeos/kokoro-env -name '*.pyc' -delete 2>/dev/null || true && \
    find /opt/lifeos/kokoro-env -path '*/tests/*.py' -not -name '__init__.py' -delete 2>/dev/null || true

RUN /opt/lifeos/kokoro-env/bin/python3 -c \
    "from kokoro import KPipeline; print('kokoro import OK')"

# ---------------------------------------------------------------------------
# Stage 2 — runtime
# ---------------------------------------------------------------------------
FROM python:3.12-slim AS runtime

#   - libsndfile1: soundfile package for OGG/WAV writing
#   - libespeak-ng1 + espeak-ng-data: REQUIRED by Kokoro phonemizer
#   - ffmpeg: OGG encoding fallback used by lifeos-tts-server.py
#   - tini: PID 1 for SIGTERM forwarding
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        ca-certificates \
        libsndfile1 \
        libespeak-ng1 \
        espeak-ng-data \
        ffmpeg \
        tini \
        && \
    rm -rf /var/lib/apt/lists/* && \
    mkdir -p /usr/lib64 && \
    ln -sf /usr/lib/x86_64-linux-gnu/libespeak-ng.so.1 /usr/lib64/libespeak-ng.so.1

# Venv + pre-warmed HF cache + manifest, all baked.
COPY --from=builder /opt/lifeos/kokoro-env /opt/lifeos/kokoro-env

# Server script baked into the image (Phase 6: no longer bind-mounted from
# the host). Iterating on the script now requires a container rebuild —
# acceptable trade for removing /usr/local/bin/lifeos-tts-server.py from
# the bootc image.
COPY containers/lifeos-tts/lifeos-tts-server.py /usr/local/bin/lifeos-tts-server.py
RUN chmod +x /usr/local/bin/lifeos-tts-server.py

RUN useradd --system --uid 65532 --no-create-home --shell /usr/sbin/nologin lifeos-tts
USER 65532

EXPOSE 8084

ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["/opt/lifeos/kokoro-env/bin/python3", "/usr/local/bin/lifeos-tts-server.py"]

LABEL org.opencontainers.image.title="lifeos-tts"
LABEL org.opencontainers.image.description="Kokoro TTS server for LifeOS — CPU-only, fully self-contained"
LABEL org.opencontainers.image.source="https://github.com/hectormr206/lifeos"
LABEL org.opencontainers.image.licenses="Apache-2.0"
