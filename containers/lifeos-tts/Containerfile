# lifeos-tts — Kokoro TTS server (CPU-only)
#
# Phase 1 of the architecture pivot — first service to be containerized.
# PRD: docs/strategy/prd-architecture-pivot-lean-bootc-quadlet.md
#
# Why TTS is the test bed for Phase 1:
#   - Pure CPU (no GPU passthrough, no CDI, no Vulkan dance)
#   - Stateless (Kokoro voice models baked in the Python venv, no bind mount
#     to /var/lib/lifeos needed)
#   - Loosely coupled (clients reach :8084 over HTTP, no IPC, no shared FDs)
#   - If anything breaks, only TTS is affected — Axi keeps working
#
# Build:
#   podman build -t 10.66.66.1:5001/lifeos-tts:dev \
#     -f containers/lifeos-tts/Containerfile \
#     containers/lifeos-tts/
#
# Test inner-loop:
#   See docs/contributor/quadlet-dev-workflow.md for the full edit → push :dev →
#   laptop test → promote :stable workflow.
#
# Promote to production:
#   podman tag 10.66.66.1:5001/lifeos-tts:dev ghcr.io/hectormr206/lifeos-tts:stable
#   podman push ghcr.io/hectormr206/lifeos-tts:stable

# ---------------------------------------------------------------------------
# Stage 1 — builder
# ---------------------------------------------------------------------------
# Heavy Python build deps (torch ~750 MB) + Kokoro install. Kept separate so
# the runtime image doesn't ship gcc, headers, or pip cache.
FROM python:3.12-slim AS builder

# Build deps for native wheels (torch, sentencepiece, etc.) and ca-certs for
# pip download. Cleaned in the same RUN so the layer doesn't carry them.
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        ca-certificates \
        build-essential \
        git \
        && \
    rm -rf /var/lib/apt/lists/*

# Build the venv at the same path the existing systemd unit uses
# (/opt/lifeos/kokoro-env). Keeping the path identical means the lifeos-tts-server.py
# script needs zero changes when migrating from systemd-host to containerized.
RUN python3 -m venv /opt/lifeos/kokoro-env

# Pin to the same Kokoro version the host service uses to avoid behavior drift
# during the migration. Bump explicitly when validating a new version.
RUN /opt/lifeos/kokoro-env/bin/pip install --upgrade pip && \
    /opt/lifeos/kokoro-env/bin/pip install --no-cache-dir \
        torch==2.6.0 \
        torchaudio==2.6.0 \
        --index-url https://download.pytorch.org/whl/cpu && \
    /opt/lifeos/kokoro-env/bin/pip install --no-cache-dir \
        soundfile \
        numpy \
        "kokoro==0.9.4" \
        "misaki[en]" \
        "misaki[es]"

# Sanity check: import kokoro inside the venv. If this fails the build fails
# fast — better than discovering the breakage at container start time.
RUN /opt/lifeos/kokoro-env/bin/python3 -c \
    "from kokoro import KPipeline; print('kokoro import OK')"

# ---------------------------------------------------------------------------
# Stage 2 — runtime
# ---------------------------------------------------------------------------
# Slim base + only the libs needed at runtime. No build tools, no headers.
FROM python:3.12-slim AS runtime

# Minimal runtime deps: libsndfile for soundfile, ca-certs for HTTPS, tini as
# PID 1 for clean signal forwarding (so SIGTERM from systemd actually reaches
# the Python process and triggers its in-process watchdog graceful exit).
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        ca-certificates \
        libsndfile1 \
        tini \
        && \
    rm -rf /var/lib/apt/lists/*

# Bring the prebuilt venv from the builder. This is the bulk of the image
# (~850 MB — torch dominates). Nothing else is copied — the script itself
# is bind-mounted from the host (see Quadlet) so iteration on the script
# doesn't require a container rebuild.
COPY --from=builder /opt/lifeos/kokoro-env /opt/lifeos/kokoro-env

# The Quadlet bind-mounts the live host script at /usr/local/bin/lifeos-tts-server.py
# (read-only). This means: edit the .py on the host → restart the container →
# reload, no rebuild needed. The image stays stable even when the script changes.

# Run as a non-root user inside the container. systemd's DynamicUser= on the
# host service achieved the same; we replicate the isolation here.
RUN useradd --system --uid 65532 --no-create-home --shell /usr/sbin/nologin lifeos-tts
USER 65532

EXPOSE 8084

# tini reaps zombies and forwards signals correctly — important because
# kokoro spawns subprocesses for audio synthesis. Without tini, SIGTERM from
# systemd doesn't reach those children cleanly.
ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["/opt/lifeos/kokoro-env/bin/python3", "/usr/local/bin/lifeos-tts-server.py"]

# Image labels for traceability + cosign verification matching.
LABEL org.opencontainers.image.title="lifeos-tts"
LABEL org.opencontainers.image.description="Kokoro TTS server for LifeOS — CPU-only, stateless"
LABEL org.opencontainers.image.source="https://github.com/hectormr206/lifeos"
LABEL org.opencontainers.image.licenses="Apache-2.0"
