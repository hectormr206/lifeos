# lifeos-llama-server.container — Qwen3.5-9B Vulkan inference Quadlet
#
# Phase 4 of the architecture pivot. NOT auto-installed; BLOCKED on
# nvidia-container-toolkit availability in the bootc image (see
# project_pending_nvidia_container_toolkit memory).

[Unit]
Description=LifeOS LLM Server (Qwen3.5 chat, Vulkan GPU, containerized)
Documentation=https://github.com/ggml-org/llama.cpp
After=network-online.target lifeos-image-guardian.service nvidia-cdi-refresh.service
# nvidia-cdi-refresh.service ships with nvidia-container-toolkit and regenerates
# the CDI spec at boot. Wants= because if it's absent (driver hot-swap, custom
# host config) we still try and let CDI errors fail loudly.
Wants=network-online.target nvidia-cdi-refresh.service

[Container]
Image=ghcr.io/hectormr206/lifeos-llama-server:stable
ContainerName=lifeos-llama-server
HostName=lifeos-llama-server

# Network=host — chat clients (lifeosd, dashboard) reach :8082 on loopback,
# zero URL changes from current systemd-host setup.
Network=host

# === GPU passthrough via CDI ===
#
# AddDevice=nvidia.com/gpu=all uses Container Device Interface. The host
# nvidia-container-toolkit generates /etc/cdi/nvidia.yaml that describes how
# to inject /dev/nvidia*, libraries, and Vulkan ICDs into the container.
# This replaces the legacy `--gpus all` Docker flag with a runtime-agnostic
# spec.
#
# Requirements on host:
#   - nvidia-container-toolkit installed (BLOCKED in current image — see
#     memory project_pending_nvidia_container_toolkit)
#   - nvidia-cdi-refresh.service ran successfully (ships with the toolkit)
#   - GPU is Turing+ if using nvidia-open driver (we use closed via
#     lifeos-nvidia-drivers — works for Pascal+)
AddDevice=nvidia.com/gpu=all

# === Models bind mount — the largest single state item in LifeOS ===
#
# /var/lib/lifeos/models holds:
#   Qwen3.5-9B-Q4_K_M.gguf      5.3 GB  ← the model
#   Qwen3.5-9B-mmproj-F16.gguf  876 MB  ← multimodal projection
#   + smaller fallbacks (4B, 2B, 0.8B + their mmproj)
#   + nomic-embed-text-v1.5.f16.gguf
#
# Always bind-mount RO. Models NEVER live inside the container image — that
# would inflate to ~14 GB and force a rebuild on model bumps.
Volume=/var/lib/lifeos/models:/var/lib/lifeos/models:ro,Z

# Runtime profile env (LIFEOS_AI_MODEL, LIFEOS_AI_CTX_SIZE, LIFEOS_AI_THREADS,
# LIFEOS_AI_GPU_LAYERS, LIFEOS_AI_PARALLEL, etc.) lives on host so the
# benchmarker can update it without rebuilding the container.
#
# NO Volume= bind for these env files. The [Service] EnvironmentFile=
# directives below load them on the HOST side (systemd reads, exports
# vars to the podman process, podman injects as ENV into the container).
# A separate bind mount would be redundant — llama-server reads vars
# from its environment, not from a file path.

# Defense-in-depth Capa 4.
ExecStartPre=/usr/local/bin/lifeos-ensure-images

# === The exec line — same args the host service uses ===
#
# Reads model + tuning from the runtime-profile env file. The benchmarker
# (defer benchmark, PR #65) writes that file with hardware-tuned values.
# Game-guard env file overrides for low-power profiles when gaming detected.
Exec=/usr/sbin/llama-server \
    --model /var/lib/lifeos/models/${LIFEOS_AI_MODEL} \
    --mmproj /var/lib/lifeos/models/${LIFEOS_AI_MMPROJ} \
    --alias lifeos \
    --host 127.0.0.1 \
    --port 8082 \
    --ctx-size ${LIFEOS_AI_CTX_SIZE} \
    --threads ${LIFEOS_AI_THREADS} \
    --n-gpu-layers ${LIFEOS_AI_GPU_LAYERS} \
    --mlock \
    --parallel ${LIFEOS_AI_PARALLEL} \
    --batch-size ${LIFEOS_AI_BATCH_SIZE} \
    --ubatch-size ${LIFEOS_AI_UBATCH_SIZE} \
    --n-predict 2048 \
    --flash-attn auto \
    --cache-type-k q8_0 \
    --cache-type-v q8_0 \
    -kvu -cram -1 -sm none -mg 0 \
    --temp 0.6 --top-p 0.95 --top-k 20 --min-p 0.0 \
    --presence-penalty 0.0 --repeat-penalty 1.0 \
    --reasoning off \
    --jinja

[Service]
# CRITICAL: these paths are HOST paths (systemd evaluates EnvironmentFile=
# on the host before the container is created). The benchmarker writes
# to /var/lib/lifeos/llama-server-runtime-profile.env on the host —
# previous version pointed at /etc/llama-server-runtime-profile.env which
# does NOT exist on the host, so all ${LIFEOS_AI_*} vars came up empty
# and the Exec= line above ran with --model "/var/lib/lifeos/models/"
# (no filename) → llama-server fails to start.
EnvironmentFile=-/var/lib/lifeos/llama-server-runtime-profile.env
EnvironmentFile=-/var/lib/lifeos/llama-server-game-guard.env

# Capa 3 — auto-restart with a longer backoff than embeddings/TTS because
# Qwen3.5-9B warmup (model load + GPU upload + Vulkan shader cache prime)
# takes ~30-60s. Avoid restart-thrash on transient OOM.
Restart=always
RestartSec=15s
TimeoutStartSec=180s

# Resource limits. The model itself fills GPU VRAM (5.3 GB Q4); host RAM is
# for the kv-cache, server overhead, and Vulkan staging. 8G cap is generous
# but realistic for the 131K context profile.
MemoryMax=8G
CPUQuota=400%

NoNewPrivileges=true

[Install]
WantedBy=multi-user.target default.target
