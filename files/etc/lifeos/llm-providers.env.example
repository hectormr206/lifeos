# LifeOS LLM Provider API Keys
# Copy this file to llm-providers.env and fill in your keys.
# cp llm-providers.env.example llm-providers.env
#
# PRIVACY PRIORITY:
# 1. Local model (max privacy — never leaves your machine)
# 2. Cerebras (zero data retention by default, never trains on your data)
# 3. Groq (zero data retention by default, never trains on your data)
# 4. Z.AI/GLM (requires balance, Chinese jurisdiction — use for non-sensitive only)
# 5. OpenRouter (mixed privacy — depends on underlying provider)

# === Cerebras (FREE, zero data retention, 2000+ tok/s) ===
# Sign up: https://cloud.cerebras.ai/
# Privacy: https://cloud.cerebras.ai/privacy — never stores/logs/reuses your data
CEREBRAS_API_KEY=

# === Groq (FREE, zero data retention, 500-1000 tok/s) ===
# Sign up: https://console.groq.com/
# Privacy: https://console.groq.com/docs/your-data — ZDR enabled by default
GROQ_API_KEY=

# === Z.AI / GLM (paid, requires balance) ===
# Sign up: https://open.bigmodel.cn/
# Note: Chinese jurisdiction. Use for non-sensitive tasks only.
ZAI_API_KEY=

# === OpenRouter (FREE models, mixed privacy) ===
# Sign up: https://openrouter.ai/
# Note: Privacy depends on underlying provider. Last resort fallback.
OPENROUTER_API_KEY=

# === Telegram Bot (optional — for remote control) ===
# Create bot: @BotFather on Telegram -> /newbot
# Get chat ID: @userinfobot on Telegram
LIFEOS_TELEGRAM_BOT_TOKEN=
LIFEOS_TELEGRAM_CHAT_ID=
