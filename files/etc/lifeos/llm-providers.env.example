# LifeOS LLM Provider API Keys
# Copy this file to llm-providers.env and fill in your keys.
# cp llm-providers.env.example llm-providers.env
#
# Configure only the providers you want to use. The router handles fallbacks.
# You don't need all of them — even 1-2 is enough.
#
# ============================================================================
# PRIVACY RANKING (recommended order)
# ============================================================================
#
# [RECOMMENDED] HIGH PRIVACY — zero data retention, never train on your data:
#   1. Local model    — never leaves your machine (always active)
#   2. Cerebras       — zero retention by default, fastest inference in the world
#   3. Groq           — zero retention by default, very fast inference
#
# [OPTIONAL] MEDIUM PRIVACY — API data not used for training (paid tiers):
#   4. Anthropic API  — no training on API data, 30-day retention with opt-out
#   5. OpenAI API     — no training on API data (paid), opt-out available
#
# [OPTIONAL] VARIABLE PRIVACY — depends on tier or provider:
#   6. Google Gemini   — FREE tier trains on your data. Paid tier does not
#   7. OpenRouter      — privacy depends on underlying provider
#
# [OPTIONAL] LOW PRIVACY — Chinese jurisdiction, data laws differ:
#   8. Z.AI / GLM      — "no training without consent" but Chinese law applies
#   9. Kimi / Moonshot — same jurisdiction concerns
#  10. Qwen (direct)   — Alibaba Cloud, same concerns
#  11. MiniMax         — same concerns
#
# ============================================================================

# ---------- HIGH PRIVACY (recommended) ----------

# === Cerebras (FREE, zero data retention, 2000+ tok/s) ===
# Sign up: https://cloud.cerebras.ai/
# Privacy: https://cloud.cerebras.ai/privacy
# Models: qwen-3-235b, llama3.1-8b
CEREBRAS_API_KEY=

# === Groq (FREE, zero data retention, 500-1000 tok/s) ===
# Sign up: https://console.groq.com/
# Privacy: https://console.groq.com/docs/your-data
# Models: llama-3.3-70b, qwen-qwq-32b, llama-3.1-8b, deepseek-r1-70b
GROQ_API_KEY=

# ---------- MEDIUM PRIVACY (optional, paid) ----------

# === Anthropic / Claude API (paid, no training on API data) ===
# Sign up: https://console.anthropic.com/
# Privacy: API data not used for training. 30-day retention (opt-out available)
# Models: claude-sonnet-4-6, claude-haiku-4-5
# Pricing: Haiku $0.25/$1.25, Sonnet $3/$15 per M tokens
ANTHROPIC_API_KEY=

# === OpenAI API (paid, no training on API data) ===
# Sign up: https://platform.openai.com/
# Privacy: API data not used for training by default (since Mar 2023)
# Models: gpt-4o, gpt-4o-mini
# Pricing: 4o-mini $0.15/$0.60, 4o $2.50/$10 per M tokens
OPENAI_API_KEY=

# === Google Gemini API (FREE tier trains on data! Paid tier does NOT) ===
# Sign up: https://aistudio.google.com/
# Privacy: Free tier data used to improve products. Paid tier: opt-out available
# Models: gemini-2.5-flash, gemini-2.5-pro
# Free tier: 250 req/day (flash), 100 req/day (pro) — but trains on your data
GEMINI_API_KEY=

# ---------- VARIABLE PRIVACY (optional, fallback) ----------

# === OpenRouter (FREE models, mixed privacy) ===
# Sign up: https://openrouter.ai/
# Privacy: OpenRouter itself doesn't retain. But underlying providers vary.
# Tip: Enable "don't route to providers that train" in account settings
# Models: 400+ models available, many free
OPENROUTER_API_KEY=

# ---------- LOW PRIVACY (optional, Chinese jurisdiction) ----------
# Note: These providers offer competitive pricing and quality but operate
# under Chinese data laws. Use only for non-sensitive tasks (code, research).

# === Z.AI / GLM (paid, requires balance) ===
# Sign up: https://open.bigmodel.cn/ or https://z.ai/
# Models: glm-4.7, glm-5
# Pricing: $0.55/$2.20 per M tokens
ZAI_API_KEY=

# === Kimi / Moonshot (paid, multimodal + vision) ===
# Sign up: https://platform.moonshot.cn/
# Models: kimi-k2.5 (256K context, vision)
# Pricing: $0.60/$2.50 per M tokens
KIMI_API_KEY=

# === MiniMax (paid, strong coding) ===
# Sign up: https://platform.minimax.io/
# Models: minimax-m2.5 (80% SWE-Bench)
# Pricing: $0.30/$1.20 per M tokens
MINIMAX_API_KEY=

# === Qwen / Alibaba Cloud (various tiers) ===
# Sign up: https://dashscope.aliyun.com/
# Models: qwen-max, qwen-plus, qwen-turbo
# Note: Available via OpenRouter too
QWEN_API_KEY=

# ============================================================================
# WEB SEARCH (optional — for internet research)
# ============================================================================
# Note: Groq has built-in browser_search (no key needed, uses GROQ_API_KEY)
# These are additional/fallback options:

# === Serper (2,500 searches/month FREE, then $1/1K) ===
# Sign up: https://serper.dev/
# Best for: fast Google-powered search results
SERPER_API_KEY=

# === Brave Search (independent index, $3/1K requests) ===
# Sign up: https://brave.com/search/api/
# Best for: privacy-focused, not dependent on Google
BRAVE_SEARCH_API_KEY=

# ============================================================================
# TELEGRAM BOT (optional — for remote control)
# ============================================================================
# Create bot: @BotFather on Telegram -> /newbot
# Get chat ID: @userinfobot on Telegram
LIFEOS_TELEGRAM_BOT_TOKEN=
LIFEOS_TELEGRAM_CHAT_ID=
