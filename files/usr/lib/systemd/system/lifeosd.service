[Unit]
Description=LifeOS System Daemon
Documentation=man:lifeosd(8)
After=network.target
Wants=network.target

[Service]
Type=notify
ExecStart=/usr/bin/lifeosd
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=lifeosd

# Load LLM provider API keys and Telegram config (user-editable)
EnvironmentFile=-/etc/lifeos/llm-providers.env
EnvironmentFile=-/var/home/lifeos/.config/lifeos/llm-providers.env

# Security hardening
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=/var/lib/lifeos /var/log/lifeos
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true

[Install]
WantedBy=multi-user.target
