{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LifeOS Intent v1",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "intents.lifeos.dev/v1"
    },
    "kind": {
      "type": "string",
      "const": "Intent"
    },
    "metadata": {
      "type": "object",
      "required": ["name", "app_id"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Unique name or ID for this intent execution"
        },
        "app_id": {
          "type": "string",
          "description": "The registered ID of the app or agent triggering the intent"
        }
      }
    },
    "spec": {
      "type": "object",
      "required": ["action"],
      "properties": {
        "action": {
          "type": "string",
          "description": "The standardized action verb (e.g., 'system.suspend', 'browser.open', 'ai.generate')"
        },
        "payload": {
          "type": "object",
          "description": "Action specific key-value parameters"
        }
      }
    }
  }
}
