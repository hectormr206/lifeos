{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LifeOS Capability Token v1",
  "type": "object",
  "required": ["iss", "sub", "act", "cap", "scope", "risk", "iat", "exp", "jti"],
  "properties": {
    "iss": {
      "type": "string",
      "description": "Token issuer"
    },
    "sub": {
      "type": "string",
      "pattern": "^(user|agent|service)://.+",
      "description": "Token subject principal"
    },
    "act": {
      "type": "string",
      "description": "Acting principal"
    },
    "cap": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "description": "Granted capabilities"
    },
    "scope": {
      "type": "object",
      "description": "Token scope limits"
    },
    "risk": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "iat": {
      "type": "integer",
      "description": "Issued at (unix epoch seconds)"
    },
    "exp": {
      "type": "integer",
      "description": "Expiration (unix epoch seconds)"
    },
    "jti": {
      "type": "string",
      "description": "Unique token identifier"
    },
    "device_id": {
      "type": "string",
      "description": "Optional device binding id"
    },
    "tpm_quote_hash": {
      "type": "string",
      "description": "Optional TPM quote binding"
    }
  }
}
