{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LifeOS Delegation v1",
  "type": "object",
  "required": [
    "delegation_id",
    "delegator",
    "delegatee",
    "capabilities",
    "scope",
    "risk_ceiling",
    "expires_at",
    "reason",
    "signature"
  ],
  "properties": {
    "delegation_id": {
      "type": "string",
      "description": "Delegation identifier (ULID or UUID)"
    },
    "delegator": {
      "type": "string",
      "pattern": "^(user|agent|service)://.+",
      "description": "Principal that delegates capabilities"
    },
    "delegatee": {
      "type": "string",
      "pattern": "^(agent|service)://.+",
      "description": "Principal that receives delegated capabilities"
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "scope": {
      "type": "object",
      "description": "Resource boundaries for delegated execution"
    },
    "risk_ceiling": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "reason": {
      "type": "string",
      "minLength": 3
    },
    "signature": {
      "type": "string",
      "minLength": 16
    }
  }
}
