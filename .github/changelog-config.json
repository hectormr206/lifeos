{
  "categories": [
    {
      "title": "## 🚀 Features",
      "labels": ["feature", "enhancement"]
    },
    {
      "title": "## 🐛 Bug Fixes",
      "labels": ["fix", "bug"]
    },
    {
      "title": "## 🧪 Tests",
      "labels": ["test", "testing"]
    },
    {
      "title": "## 📦 Dependencies",
      "labels": ["dependencies", "deps"]
    },
    {
      "title": "## 📝 Documentation",
      "labels": ["docs", "documentation"]
    },
    {
      "title": "## 🔧 Maintenance",
      "labels": ["chore", "maintenance", "refactor"]
    },
    {
      "title": "## 🔒 Security",
      "labels": ["security"]
    },
    {
      "title": "## ⚡ Performance",
      "labels": ["performance"]
    }
  ],
  "ignore_labels": [
    "ignore-for-changelog",
    "ci"
  ],
  "sort": "ASC",
  "template": "${{CHANGELOG}}",
  "pr_template": "- ${{TITLE}} (#${{NUMBER}})",
  "empty_template": "- No changes",
  "label_extractor": [
    {
      "pattern": "(.)\\s*\\[(.+?)\\]\\s*(.+)",
      "target": "$1",
      "flags": "gu"
    },
    {
      "pattern": "\\[CI\\]",
      "on_property": "title"
    }
  ],
  "duplicate_filter": {
    "pattern": "\\[CI\\]",
    "on_property": "title",
    "method": "match"
  },
  "reference": {
    "pattern": "#(\\d+)",
    "on_property": "body"
  }
}
