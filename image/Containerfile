# --- sysusers + tmpfiles ---
RUN mkdir -p /usr/lib/sysusers.d /usr/lib/tmpfiles.d && \
    printf '%s\n' \
    'g wsdd -' \
    'u wsdd - "WSDD Service User" /var/lib/wsdd -' \
    'g akmods -' \
    'u akmods - "User is used by akmods to build akmod packages" /var/cache/akmods/ -' \
    > /usr/lib/sysusers.d/wsdd.conf && \
    # Dedicated unprivileged user for the GitHub Actions runner. No shell,
    # no wheel, no sudo. Owns /var/lib/lifeos/actions-runner/. Workflow RCE
    # can no longer escalate to the interactive `lifeos` user (uid 1000).
    printf '%s\n' \
    'g lifeos-runner -' \
    'u lifeos-runner - "LifeOS GitHub Actions Runner" /var/lib/lifeos/actions-runner /usr/sbin/nologin' \
    > /usr/lib/sysusers.d/lifeos-runner.conf && \
    printf '%s\n' \
    'L /var/lib/greetd/.config/systemd/user/xdg-desktop-portal.service - - - - /dev/null' \
    'd /var/lib/lifeos/models 0755 root root - -' \
    'L /var/lib/unbound/root.key - - - - ../../../etc/unbound/dnssec-root.key' \
    'd /var/cache/dnf 0755 root root - -' \
    'd /var/cache/PackageKit 0755 root root - -' \
    'd /var/cache/app-info 0755 root root - -' \
    'd /var/cache/app-info/icons 0755 root root - -' \
    'd /var/cache/app-info/xmls 0755 root root - -' \
    'd /var/cache/libX11 0755 root root - -' \
    'd /var/cache/libX11/compose 0755 root root - -' \
    'd /var/cache/libdnf5 0755 root root - -' \
    'd /var/cache/swcatalog 0755 root root - -' \
    'd /var/cache/swcatalog/cache 0755 root root - -' \
    'd /var/cache/swcatalog/gv 0755 root root - -' \
    'd /var/cache/swcatalog/icons 0755 root root - -' \
    'd /var/cache/swcatalog/xml 0755 root root - -' \
    'd /var/lib/AccountsService 0775 root root - -' \
    'd /var/lib/AccountsService/icons 0775 root root - -' \
    'd /var/lib/AccountsService/users 0700 root root - -' \
    'd /var/lib/PackageKit 0755 root root - -' \
    'd /var/lib/dnf 0755 root root - -' \
    'd /var/lib/dnf/repos 0755 root root - -' \
    'd /var/lib/dnf/repos/fedora-f8e7c8bda68a349e 0755 root root - -' \
    'd /var/lib/dnf/repos/updates-79babcf8637033ce 0755 root root - -' \
    'd /var/lib/flatpak 0755 root root - -' \
    'd /var/lib/fprint 0700 root root - -' \
    'd /var/lib/geoclue 0755 geoclue geoclue - -' \
    'd /var/lib/greetd/.config 0755 greetd greetd - -' \
    'd /var/lib/greetd/.config/systemd 0755 greetd greetd - -' \
    'd /var/lib/greetd/.config/systemd/user 0755 greetd greetd - -' \
    'd /var/lib/lifeos 0755 1000 1000 - -' \
    'd /var/lib/rpm-state 0755 root root - -' \
    'd /var/lib/rpm-state/kernel 0755 root root - -' \
    'd /var/lib/unbound 0755 unbound unbound - -' \
    'd /var/lib/smartmontools 0755 root root - -' \
    'd /var/lib/tuned 0755 root root - -' \
    'd /var/log/lifeos 0755 1000 1000 - -' \
    'd /var/log/tuned 0755 root root - -' \
    > /usr/lib/tmpfiles.d/lifeos-var.conf && \
    rm -f /var/lib/dnf/repos/*/countme && \
    rm -f /var/log/dnf5.log* && \
    rm -f /var/cache/ldconfig/aux-cache && \
    rm -f /var/cache/swcatalog/cache/C-local-metainfo.xb /var/cache/swcatalog/cache/C-os-catalog.xb

# --- Stale-library cleanup ---
# Phase 4 of the architecture pivot removed the on-host llama-server binary
# (and its sibling libllama.so / libggml*.so) because chat inference now runs
# inside the lifeos-llama-server Quadlet container with its own private
# library set. The previous "final llama-server verification" RUN block
# (re-linking the binary, asserting --version) was load-bearing on the
# binary existing in the host filesystem; removing the build site without
# removing the verification produced a "FATAL: llama-server disappeared"
# CI failure on this branch. We still scrub any stale .so files in case a
# rollback or a previous layer left them behind, then ldconfig — that's
# all the host needs now.
RUN set -eux && \
    rm -f /usr/lib64/libllama.so* /usr/lib64/libggml*.so* /usr/lib64/libmtmd.so* && \
    ldconfig

# --- Verificación final ---
# Wrapper reports WHICH check failed instead of a silent exit code.
RUN set -e; fail() { echo "VERIFY FAILED: $1"; exit 1; }; \
    # mpv/evince/keepassxc/loupe migrated from RPM to Flatpak (v0.5.0)
    # Their Flatpak presence is verified at first-boot by install_desktop_apps()
    test -x /usr/bin/life                 || fail "/usr/bin/life"; \
    # Phase 3: lifeosd binary moved to ghcr.io/hectormr206/lifeos-lifeosd:stable
    # — runs as a system Quadlet, no host binary. Validation switches to the
    # Quadlet definition + state migration unit below.
    test -x /usr/local/bin/cargo-audit    || fail "/usr/local/bin/cargo-audit"; \
    # Phase 4: llama-server binary removed from bootc (lives in
    # ghcr.io/hectormr206/lifeos-llama-server:stable Quadlet now).
    # Phase 7: whisper-cli / whisper-stream removed from bootc — now live
    # inside ghcr.io/hectormr206/lifeos-lifeosd:stable.
    test -x /usr/bin/grim                 || fail "/usr/bin/grim"; \
    test -x /usr/bin/wl-copy              || fail "/usr/bin/wl-copy"; \
    test -x /usr/bin/tesseract            || fail "/usr/bin/tesseract"; \
    test -x /usr/bin/espeak-ng            || fail "/usr/bin/espeak-ng"; \
    test -f /etc/lifeos/tts-server.env    || fail "/etc/lifeos/tts-server.env"; \
    test -x /usr/local/bin/lifeos-ensure-images || fail "/usr/local/bin/lifeos-ensure-images"; \
    test -f /usr/lib/systemd/system/lifeos-image-guardian.service || fail "lifeos-image-guardian.service"; \
    test -L /usr/lib/systemd/system/multi-user.target.wants/lifeos-image-guardian.service || fail "guardian wants symlink"; \
    test -f /usr/share/containers/systemd/lifeos-tts.container || fail "lifeos-tts.container"; \
    test -f /usr/share/containers/systemd/lifeos-llama-server.container || fail "lifeos-llama-server.container"; \
    test -x /usr/bin/nvidia-ctk || fail "/usr/bin/nvidia-ctk (Phase 4 GPU passthrough)"; \
    test -f /usr/share/containers/systemd/lifeos-llama-embeddings.container || fail "lifeos-llama-embeddings.container"; \
    test -f /usr/share/containers/systemd/lifeos-simplex-bridge.container || fail "lifeos-simplex-bridge.container"; \
