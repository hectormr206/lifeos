    ln -f /usr/bin/whisper-cli /usr/local/bin/whisper-cli 2>/dev/null || true && \
    ln -f /usr/bin/whisper-stream /usr/local/bin/whisper-stream 2>/dev/null || true && \
    echo ">>> Verifying AI runtime binaries..." && \
    /usr/sbin/llama-server --version && \
    /usr/bin/whisper-cli -h >/dev/null && \
    /usr/bin/whisper-stream -h >/dev/null && \
