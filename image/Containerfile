COPY image/files/etc/lifeos/tuf/targets.json    /etc/lifeos/tuf/targets.json
COPY image/files/etc/lifeos/cosmic-theme.toml  /etc/lifeos/cosmic-theme.toml
COPY image/files/etc/lifeos/design-tokens.toml /etc/lifeos/design-tokens.toml
COPY image/files/etc/lifeos/design-tokens.json /etc/lifeos/design-tokens.json

# LifeOS Wallpapers
COPY image/files/usr/share/backgrounds/lifeos /usr/share/backgrounds/lifeos

# LifeOS Icon Theme
COPY image/files/usr/share/icons/LifeOS /usr/share/icons/LifeOS

RUN echo "LIFEOS_CHANNEL=${LIFEOS_CHANNEL}" > /etc/lifeos/channel && \
    echo "LIFEOS_VERSION=${LIFEOS_VERSION}" >> /etc/lifeos/channel && \
    echo "BUILD_DATE=${BUILD_DATE}" >> /etc/lifeos/channel && \
    echo "VCS_REF=${VCS_REF}" >> /etc/lifeos/channel

# LifeOS COSMIC Themes (index.theme + GTK4 CSS)
COPY image/files/usr/share/themes/LifeOS-Dark/index.theme        /usr/share/themes/LifeOS-Dark/index.theme
COPY image/files/usr/share/themes/LifeOS-Dark/gtk-4.0/gtk.css    /usr/share/themes/LifeOS-Dark/gtk-4.0/gtk.css
