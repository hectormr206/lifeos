# --- AI Model (pre-bundled) ---
# Qwen3.5-4B: multimodal vision-language model with hybrid DeltaNet architecture.
# Q4_K_M quantization (~2.74GB) + F16 vision projector (~672MB) = ~3.4GB total.
# See docs/AI_MODEL_SELECTION.md for technical justification.
RUN set -eux && \
    if [ "${LIFEOS_PRELOAD_MODEL:-false}" = "true" ]; then \
        MODEL_URL="https://huggingface.co/unsloth/Qwen3.5-4B-GGUF/resolve/main/Qwen3.5-4B-Q4_K_M.gguf" && \
        MODEL_FILE="/usr/share/lifeos/models/Qwen3.5-4B-Q4_K_M.gguf" && \
        MMPROJ_URL="https://huggingface.co/unsloth/Qwen3.5-4B-GGUF/resolve/main/mmproj-F16.gguf" && \
        MMPROJ_FILE="/usr/share/lifeos/models/Qwen3.5-4B-mmproj-F16.gguf" && \
        echo ">>> LIFEOS_PRELOAD_MODEL=true: downloading Qwen3.5-4B assets..." && \
        curl -fSL --retry 3 --connect-timeout 60 -o "${MODEL_FILE}" "${MODEL_URL}" && \
        echo ">>> Model size: $(du -h "${MODEL_FILE}" | cut -f1)" && \
        test -s "${MODEL_FILE}" || { echo "ERROR: Model file is empty"; exit 1; } && \
        curl -fSL --retry 3 --connect-timeout 60 -o "${MMPROJ_FILE}" "${MMPROJ_URL}" && \
        echo ">>> mmproj size: $(du -h "${MMPROJ_FILE}" | cut -f1)" && \
        test -s "${MMPROJ_FILE}" || { echo "ERROR: mmproj file is empty"; exit 1; }; \
    else \
        echo ">>> LIFEOS_PRELOAD_MODEL=false: skipping model pre-bundle to keep image pull/build lightweight"; \
    fi

