    test -x /usr/bin/spice-vdagent        || fail "/usr/bin/spice-vdagent"; \
    test -x /usr/bin/virsh                || fail "/usr/bin/virsh"; \
    test -x /usr/bin/pkg-config           || fail "/usr/bin/pkg-config"; \
    test -x /usr/local/bin/lifeos-nvidia-secureboot.sh || fail "/usr/local/bin/lifeos-nvidia-secureboot.sh"; \
    test -x /usr/local/bin/lifeos-maintenance-cleanup.sh || fail "/usr/local/bin/lifeos-maintenance-cleanup.sh"; \
    test -x /usr/local/bin/lifeos-open-axi-dashboard.sh || fail "/usr/local/bin/lifeos-open-axi-dashboard.sh"; \
    # Dashboard moved INTO ghcr.io/hectormr206/lifeos-lifeosd:stable —
    # validated by the side-images CI on container build, not on host bootc.
    # Dashboard .desktop removed — access only via tray icon
    # Phase 3: user-scope lifeosd.service no longer ships (replaced by Quadlet).
    # Phase 4: legacy llama-server.service no longer ships (replaced by Quadlet).
    test -f /usr/lib/systemd/system/whisper-stt.service || fail "whisper-stt.service"; \
