# Phase 3 (lifeosd Quadlet) — drops the .container into /usr/share/containers/systemd/.
# At this stage of the rollout the host /usr/bin/lifeosd binary STILL ships
# (user-scope systemd unit auto-starts it). The Quadlet is here so an operator
# can flip manually:
#   sudo systemctl --user stop lifeosd
#   sudo systemctl daemon-reload
#   sudo systemctl start lifeos-lifeosd.service
# Once validation passes, a follow-up commit removes /usr/bin/lifeosd from
# bootc and masks the legacy user unit. Rollback is bootc rollback.
COPY containers/lifeos-lifeosd/lifeos-lifeosd.container /usr/share/containers/systemd/lifeos-lifeosd.container

# State migration helper (Phase 3) — first time lifeos-lifeosd.service starts
# after a deploy that flipped lifeosd to a Quadlet, /var/lib/lifeos is empty
# but ~/.local/share/lifeos has the user's encrypted memory store. The
# migration unit (oneshot, ordered Before=lifeos-lifeosd.service) copies the
# tree once. Idempotent — exits clean if /var/lib/lifeos/memory.db already
# exists. The script also asserts /etc/machine-id matches what the existing
# memory.db was encrypted with (since the key derives from machine-id), so a
# laptop swap doesn't silently produce an unreadable DB.
COPY image/files/usr/local/bin/lifeos-state-migrate.sh /usr/local/bin/lifeos-state-migrate.sh
COPY image/files/etc/systemd/system/lifeos-state-migrate.service /usr/lib/systemd/system/lifeos-state-migrate.service
RUN chmod +x /usr/local/bin/lifeos-state-migrate.sh
COPY image/files/usr/local/bin/lifeos-simplex-setup.sh /usr/local/bin/lifeos-simplex-setup.sh
RUN chmod +x /usr/local/bin/lifeos-simplex-setup.sh
COPY image/files/etc/systemd/system/nvidia-persistenced.service.d/10-lifeos-conditions.conf /etc/systemd/system/nvidia-persistenced.service.d/10-lifeos-conditions.conf
# Dev-mode NVIDIA signed modules loader (no-op on release builds — gated by ConditionPathExists)
COPY image/files/etc/systemd/system/lifeos-nvidia-signed-modules.service /usr/lib/systemd/system/lifeos-nvidia-signed-modules.service
COPY image/files/etc/systemd/system/systemd-remount-fs.service.d/10-skip-on-overlay.conf /etc/systemd/system/systemd-remount-fs.service.d/10-skip-on-overlay.conf
# Dashboard access: only via Axi tray icon → "Abrir Dashboard"
# COPY image/files/etc/xdg/autostart/lifeos-axi-experience.desktop /etc/xdg/autostart/lifeos-axi-experience.desktop
# COPY image/files/usr/share/applications/lifeos-axi-dashboard.desktop /usr/share/applications/lifeos-axi-dashboard.desktop
# Phase 3: the legacy user-scope lifeosd.service (which ran /usr/bin/lifeosd)
# is REMOVED. The daemon now runs as a system Quadlet generated from
# /usr/share/containers/systemd/lifeos-lifeosd.container. systemd's Quadlet
# generator synthesizes lifeos-lifeosd.service at boot. The Quadlet binds
# /var/lib/lifeos for state (lifeos-state-migrate.service copies the user's
# old ~/.local/share/lifeos data on first boot). UI features (tray, wake-
# word) return as small companion binaries in a follow-up PR.

# Habilitar servicios via symlinks
RUN mkdir -p /usr/lib/systemd/system/multi-user.target.wants \
             /usr/lib/systemd/system/graphical.target.wants \
             /usr/lib/systemd/system/timers.target.wants \
             /usr/lib/systemd/system/sockets.target.wants \
             /usr/lib/systemd/user/default.target.wants && \
    ln -sf /usr/lib/systemd/system/lifeos-thermal.service /usr/lib/systemd/system/multi-user.target.wants/lifeos-thermal.service && \
    ln -sf /usr/lib/systemd/system/lifeos-power-profile.service /usr/lib/systemd/system/multi-user.target.wants/lifeos-power-profile.service && \
    ln -sf /usr/lib/systemd/system/lifeos-powertune.service /usr/lib/systemd/system/multi-user.target.wants/lifeos-powertune.service && \
    ln -sf /usr/lib/systemd/system/lifeos-ecore-pin.service /usr/lib/systemd/system/multi-user.target.wants/lifeos-ecore-pin.service && \
    ln -sf /usr/lib/systemd/system/lifeos-battery.service /usr/lib/systemd/system/multi-user.target.wants/lifeos-battery.service && \
    ln -sf /usr/lib/systemd/system/lifeos-smart-charge.timer /usr/lib/systemd/system/timers.target.wants/lifeos-smart-charge.timer && \
    ln -sf /usr/lib/systemd/system/lifeos-nvidia-signed-modules.service /usr/lib/systemd/system/multi-user.target.wants/lifeos-nvidia-signed-modules.service && \
    ln -sf /usr/lib/systemd/system/lifeos-security-baseline.service /usr/lib/systemd/system/multi-user.target.wants/lifeos-security-baseline.service && \
    ln -sf /usr/lib/systemd/system/lifeos-sentinel.service /usr/lib/systemd/system/multi-user.target.wants/lifeos-sentinel.service && \
    ln -sf /usr/lib/systemd/system/lifeos-refresh-bls-titles.service /usr/lib/systemd/system/multi-user.target.wants/lifeos-refresh-bls-titles.service && \
    # Phase 3: user-scope lifeosd.service symlink removed. The Quadlet
    # auto-enables via systemd-generator + [Install] WantedBy in the
    # .container file.
    # Enable nvidia-persistenced so the NVIDIA driver keeps the GPU
    # context alive across idle periods. Without this the driver unloads
    # the context when no client is active and the LLM weights get
    # evicted from VRAM. The lifeos-conditions dropin gates it on
    # /dev/nvidiactl so it's a no-op on AMD/Intel machines.
    if [ -f /usr/lib/systemd/system/nvidia-persistenced.service ]; then \
        ln -sf /usr/lib/systemd/system/nvidia-persistenced.service /usr/lib/systemd/system/multi-user.target.wants/nvidia-persistenced.service; \
    fi && \
    ln -sf /usr/lib/systemd/system/whisper-stt.service    /usr/lib/systemd/system/multi-user.target.wants/whisper-stt.service && \
    ln -sf /usr/lib/systemd/system/fstrim.timer /usr/lib/systemd/system/timers.target.wants/fstrim.timer && \
    ln -sf /usr/lib/systemd/system/lifeos-btrfs-snapshot.timer /usr/lib/systemd/system/timers.target.wants/lifeos-btrfs-snapshot.timer && \
    ln -sf /usr/lib/systemd/system/lifeos-maintenance-cleanup.timer /usr/lib/systemd/system/timers.target.wants/lifeos-maintenance-cleanup.timer && \
    ln -sf /usr/lib/systemd/system/lifeos-flatpak-update.timer /usr/lib/systemd/system/timers.target.wants/lifeos-flatpak-update.timer && \
    ln -sf /usr/lib/systemd/system/lifeos-flatpak-nvidia-sync.service /usr/lib/systemd/system/multi-user.target.wants/lifeos-flatpak-nvidia-sync.service && \
    ln -sf /usr/lib/systemd/system/lifeos-aide-check.timer /usr/lib/systemd/system/timers.target.wants/lifeos-aide-check.timer && \
    ln -sf /usr/lib/systemd/system/lifeos-state-migrate.service /usr/lib/systemd/system/multi-user.target.wants/lifeos-state-migrate.service && \
    ln -sf /usr/lib/systemd/system/lifeos-image-guardian.service /usr/lib/systemd/system/multi-user.target.wants/lifeos-image-guardian.service && \
    ln -sf /usr/lib/systemd/system/lifeos-update-check.timer /usr/lib/systemd/system/timers.target.wants/lifeos-update-check.timer && \
    ln -sf /usr/lib/systemd/system/lifeos-update-stage.timer /usr/lib/systemd/system/timers.target.wants/lifeos-update-stage.timer && \
    ln -sf /usr/lib/systemd/system/lifeos-first-boot.service /usr/lib/systemd/system/graphical.target.wants/lifeos-first-boot.service && \
    ln -sf /usr/lib/systemd/system/lifeos-cosmic-greeter-branding.service /usr/lib/systemd/system/graphical.target.wants/lifeos-cosmic-greeter-branding.service && \
    ln -sf /usr/lib/systemd/system/bluetooth.service      /usr/lib/systemd/system/multi-user.target.wants/bluetooth.service && \
    ln -sf /usr/lib/systemd/system/NetworkManager.service /usr/lib/systemd/system/multi-user.target.wants/NetworkManager.service && \
    if [ -f /usr/lib/systemd/system/supergfxd.service ]; then \
        ln -sf /usr/lib/systemd/system/supergfxd.service /usr/lib/systemd/system/multi-user.target.wants/supergfxd.service; \
    fi && \
    if [ -f /usr/lib/systemd/system/libvirtd.service ]; then \
        ln -sf /usr/lib/systemd/system/libvirtd.service /usr/lib/systemd/system/multi-user.target.wants/libvirtd.service; \
    fi && \
    if [ -f /usr/lib/systemd/system/spice-vdagentd.service ]; then \
        ln -sf /usr/lib/systemd/system/spice-vdagentd.service /usr/lib/systemd/system/graphical.target.wants/spice-vdagentd.service; \
    fi && \
    for unit in virtqemud.socket virtnetworkd.socket virtstoraged.socket virtlogd.socket virtproxyd.socket; do \
        if [ -f "/usr/lib/systemd/system/${unit}" ]; then \
            ln -sf "/usr/lib/systemd/system/${unit}" "/usr/lib/systemd/system/sockets.target.wants/${unit}"; \
        fi; \
    done && \
    true  # removed stale lifeisd typo symlink

# --- Update policy: no surprise reboot ---
# Mask bootc auto-apply units so updates are operator-driven.
RUN mkdir -p /etc/systemd/system && \
    ln -sf /dev/null /etc/systemd/system/bootc-fetch-apply-updates.timer && \
    ln -sf /dev/null /etc/systemd/system/bootc-fetch-apply-updates.service

# --- CLI Life y Daemon (binarios compilados) ---
# Keep app binaries and dashboard late in the Dockerfile because they change
# more often than the large OS/model layers above.
COPY --from=builder /out/life /usr/bin/life
# Phase 3: lifeosd binary removed from bootc — runs as a Quadlet from
# ghcr.io/hectormr206/lifeos-lifeosd:stable. The container ships with
# --features "dbus,http-api,messaging" (HTTP API, memory, agentic chat,
# SimpleX bridge). UI features (tray icon, wake-word, GTK4 overlay)
# are not in the container — those return as small companion binaries
# in a follow-up PR. For now the dashboard at http://127.0.0.1:8081
# is the canonical user surface. Saves ~150 MB from bootc.
COPY --from=builder /opt/lifeos-devtools/bin/cargo-audit /usr/local/bin/cargo-audit

# Dashboard web (Axi control panel) — REMOVED from bootc.
# Phase 3 of the architecture pivot moved lifeosd into a Quadlet container
# (ghcr.io/hectormr206/lifeos-lifeosd:stable) which now bakes the dashboard
# assets directly via `COPY daemon/static/dashboard /usr/share/lifeos/dashboard`
# in containers/lifeos-lifeosd/Containerfile. The Quadlet sets
# Environment=LIFEOS_DASHBOARD_DIR=/usr/share/lifeos/dashboard, so the
# daemon's Axum ServeDir reads from inside the container, not from the host.
# Keeping a duplicate copy on the host was dead weight (~344 KB).

RUN chmod +x /usr/bin/life /usr/local/bin/cargo-audit && \
    ln -sf /usr/bin/life /usr/local/bin/life

# --- Runtime metadata that changes on almost every build ---
# Keep labels/channel markers at the end so BUILD_DATE/VCS_REF churn does not
# invalidate cache and layer reuse for the full OS filesystem payload.
RUN echo "LIFEOS_CHANNEL=${LIFEOS_CHANNEL}" > /etc/lifeos/channel && \
    echo "LIFEOS_VERSION=${LIFEOS_VERSION}" >> /etc/lifeos/channel && \
    echo "BUILD_DATE=${BUILD_DATE}" >> /etc/lifeos/channel && \
    echo "VCS_REF=${VCS_REF}" >> /etc/lifeos/channel

LABEL org.lifeos.channel="${LIFEOS_CHANNEL}" \
      org.lifeos.version="${LIFEOS_VERSION}" \
      org.lifeos.build-date="${BUILD_DATE}" \
      org.lifeos.vcs-ref="${VCS_REF}" \
      org.opencontainers.image.source="https://github.com/hectormrm/lifeos" \
      org.opencontainers.image.title="LifeOS" \
      org.opencontainers.image.description="AI-focused operating system with COSMIC Desktop" \
      org.opencontainers.image.version="${LIFEOS_VERSION}" \
      org.opencontainers.image.created="${BUILD_DATE}" \
      org.opencontainers.image.revision="${VCS_REF}"

