    test -x /usr/bin/firefox              || fail "/usr/bin/firefox"; \
    test -f /etc/firefox/policies/policies.json || fail "/etc/firefox/policies/policies.json"; \
    (test -f /usr/lib64/firefox/distribution/extensions/uBlock0@raymondhill.net.xpi || test -f /usr/lib/firefox/distribution/extensions/uBlock0@raymondhill.net.xpi) || fail "uBlock0 xpi"; \
    test -f /etc/skel/.mozilla/firefox/profiles.ini || fail "firefox/profiles.ini"; \
    test -f /etc/skel/.mozilla/firefox/lifeos.default/user.js || fail "firefox/lifeos.default/user.js"; \
    test -f /etc/skel/.mozilla/firefox/lifeos.default/chrome/userChrome.css || fail "firefox/userChrome.css"; \
    test -f /etc/profile.d/firefox-wayland.sh || fail "firefox-wayland.sh"; \
    test -f /etc/profile.d/lifeos-terminal.sh || fail "lifeos-terminal.sh"; \
    test -f /etc/fish/conf.d/lifeos-terminal.fish || fail "lifeos-terminal.fish"; \
    test -f /usr/share/applications/firefox-lifeos.desktop || fail "firefox-lifeos.desktop"; \
    test "$(find /usr/share/applications -maxdepth 1 -type f -name '*firefox*.desktop' | wc -l)" -eq 1 || fail "expected exactly 1 firefox .desktop file"; \
    test -f /usr/lib/bootc/kargs.d/70-lifeos-zswap.toml || fail "70-lifeos-zswap.toml"; \
    test -f /etc/systemd/zram-generator.conf || fail "zram-generator.conf"; \
    test -f /usr/lib/udev/rules.d/60-lifeos-io-scheduler.rules || fail "60-lifeos-io-scheduler.rules"; \
    test -f /usr/lib/udev/rules.d/85-lifeos-power-epp.rules || fail "85-lifeos-power-epp.rules"; \
    test -f /etc/xdg-desktop-portal/portals.conf || fail "portals.conf"; \
    test -f /var/lib/flatpak/overrides/global || fail "flatpak overrides/global"; \
    test -L /usr/lib/systemd/system/timers.target.wants/fstrim.timer || fail "fstrim.timer symlink"; \
    test -x /usr/local/bin/lifeos-flatpak-update.sh || fail "lifeos-flatpak-update.sh"; \
    test -L /usr/lib/systemd/system/timers.target.wants/lifeos-flatpak-update.timer || fail "lifeos-flatpak-update.timer symlink"; \
    test -x /usr/local/bin/lifeos-flatpak-nvidia-sync.sh || fail "lifeos-flatpak-nvidia-sync.sh"; \
    test -f /usr/lib/systemd/system/lifeos-power-profile.service || fail "lifeos-power-profile.service"; \
    test -f /usr/lib/systemd/system/lifeos-powertune.service || fail "lifeos-powertune.service"; \
    test -f /usr/lib64/firefox/distribution/policies.json || fail "firefox distribution/policies.json"; \
    test -f /usr/lib/systemd/system/lifeos-background.slice || fail "lifeos-background.slice"; \
    test -f /usr/lib/systemd/system/lifeos-ecore-pin.service || fail "lifeos-ecore-pin.service"; \
    test -x /usr/local/bin/lifeos-detect-ecores.sh || fail "lifeos-detect-ecores.sh"; \
    test -f /usr/lib/systemd/system/whisper-stt.service.d/20-lifeos-background.conf || fail "whisper-stt 20-lifeos-background.conf"; \
    # Legacy llama-embeddings/llama-server dropins removed — units no
    # longer exist on host (Phase 2/4 Quadlet flips).
    test -x /usr/local/bin/lifeos-dev-deploy.sh || fail "lifeos-dev-deploy.sh"; \
    test -x /usr/local/bin/lifeos-apply-default-layout.sh || fail "lifeos-apply-default-layout.sh"

# nonempty-boot is intentionally skipped: /boot/efi content is required for bootc-image-builder ISO generation.
RUN dnf clean all && rm -f /var/log/dnf5.log* /var/cache/ldconfig/aux-cache && bootc container lint --skip nonempty-boot
