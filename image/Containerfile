# image/Containerfile
# LifeOS: construido directamente sobre Fedora bootc
# Incorpora COSMIC Desktop, Nvidia Optimus + Gaming (Steam/Proton) y llama-server (AI local)
#
# Build context must be the repo root:
#   podman build -t lifeos:latest -f image/Containerfile .
#
# Channel builds:
#   podman build --build-arg LIFEOS_CHANNEL=stable -t lifeos:stable -f image/Containerfile .
#   podman build --build-arg LIFEOS_CHANNEL=candidate -t lifeos:candidate -f image/Containerfile .
#   podman build --build-arg LIFEOS_CHANNEL=edge -t lifeos:edge -f image/Containerfile .

# Build against the latest supported Fedora major release.
ARG FEDORA_MAJOR=43

# ============================================================================
# Stage 1: Build CLI + Daemon (Rust)
# ============================================================================
FROM fedora:${FEDORA_MAJOR} AS builder

ARG LIFEOS_CHANNEL=edge
ARG LIFEOS_VERSION=dev
ARG BUILD_DATE
ARG VCS_REF
ARG LIFEOS_NVIDIA_KMOD_SIGN_KEY_B64=""
ARG LIFEOS_NVIDIA_KMOD_CERT_DER_B64=""
ARG LIFEOS_PRELOAD_MODEL=false

RUN dnf -y install \
    rust cargo \
    openssl-devel \
    pkgconf-pkg-config \
    gcc \
    git \
    dbus-devel \
    glib2-devel \
    gtk4-devel \
    libadwaita-devel \
    pango-devel \
    gdk-pixbuf2-devel \
    graphene-devel \
    cairo-devel \
    && dnf clean all

# Prebuild QA tooling once so the shipped ISO can run `make ci`
# without a manual cargo bootstrap on the host.
RUN cargo install --locked cargo-audit --root /opt/lifeos-devtools

WORKDIR /build

# Copy workspace manifests first for better build cache behavior.
COPY Cargo.toml Cargo.lock ./
COPY cli/Cargo.toml cli/
COPY daemon/Cargo.toml daemon/
COPY tests/Cargo.toml tests/
COPY tests/integration tests/integration/

# Copy source trees.
COPY cli/src cli/src/
COPY cli/assets cli/assets/
COPY daemon/src daemon/src/

# Copy contracts for model catalog (needed by CLI include_str!)
COPY contracts/ contracts/

# Build binaries with deterministic dependency resolution, then keep only artifacts.
RUN set -eux && \
    cargo build --release --locked -p life && \
    cargo build --release --all-features --locked -p lifeosd && \
    install -D -m 0755 /build/target/release/life /out/life && \
    install -D -m 0755 /build/target/release/lifeosd /out/lifeosd && \
    rm -rf /build/target /root/.cargo/registry /root/.cargo/git

# ============================================================================
# Stage 2: Build llama-server (GPU-capable via Vulkan)
# ============================================================================
FROM fedora:${FEDORA_MAJOR} AS llama-builder

RUN dnf install -y cmake make gcc-c++ git openssl-devel vulkan-loader-devel glslc && \
    dnf clean all

RUN set -eux && \
    echo ">>> Building llama-server from source (Vulkan-enabled)..." && \
    git clone --depth=1 https://github.com/ggml-org/llama.cpp /tmp/llama.cpp && \
    cmake -S /tmp/llama.cpp -B /tmp/llama.cpp/build \
        -DCMAKE_BUILD_TYPE=Release \
        -DBUILD_SHARED_LIBS=OFF \
        -DGGML_STATIC=ON \
        -DGGML_VULKAN=ON \
        -DLLAMA_BUILD_TESTS=OFF \
        -DLLAMA_BUILD_EXAMPLES=OFF \
        -DLLAMA_BUILD_SERVER=ON && \
    cmake --build /tmp/llama.cpp/build -j"$(nproc)" --target llama-server && \
    BUILD_BIN="$(find /tmp/llama.cpp/build -name 'llama-server' -type f | head -1)" && \
    echo ">>> Binary found at: ${BUILD_BIN}" && \
    mkdir -p /out && \
    install -m 0755 "${BUILD_BIN}" /out/llama-server && \
    /out/llama-server --version && \
    rm -rf /tmp/llama.cpp

# ============================================================================
# Stage 3: Build whisper-cli + ship a default STT model
# ============================================================================
FROM fedora:${FEDORA_MAJOR} AS whisper-builder

RUN dnf install -y cmake make gcc-c++ git openssl-devel curl && \
    dnf clean all

RUN set -eux && \
    echo ">>> Building whisper-cli from source..." && \
    git clone --depth=1 https://github.com/ggml-org/whisper.cpp /tmp/whisper.cpp && \
    cmake -S /tmp/whisper.cpp -B /tmp/whisper.cpp/build \
        -DCMAKE_BUILD_TYPE=Release \
        -DBUILD_SHARED_LIBS=OFF \
        -DWHISPER_BUILD_TESTS=OFF \
        -DWHISPER_BUILD_EXAMPLES=ON && \
    cmake --build /tmp/whisper.cpp/build -j"$(nproc)" --target whisper-cli && \
    BUILD_BIN="$(find /tmp/whisper.cpp/build -name 'whisper-cli' -type f | head -1)" && \
    echo ">>> Binary found at: ${BUILD_BIN}" && \
    mkdir -p /out/models/whisper && \
    install -m 0755 "${BUILD_BIN}" /out/whisper-cli && \
    curl -fSL --retry 3 --connect-timeout 60 \
      -o /out/models/whisper/ggml-base.bin \
      https://huggingface.co/ggerganov/whisper.cpp/resolve/main/ggml-base.bin && \
    test -s /out/models/whisper/ggml-base.bin && \
    rm -rf /tmp/whisper.cpp

# ============================================================================
# Stage 4: Bundle Piper TTS assets (brand voice)
# ============================================================================
FROM fedora:${FEDORA_MAJOR} AS piper-voice-builder

RUN dnf install -y curl && \
    dnf clean all

RUN set -eux && \
    mkdir -p /out/models/piper && \
    curl -fSL --retry 3 --connect-timeout 60 \
      -o /out/models/piper/es_MX-claude-high.onnx \
      https://huggingface.co/rhasspy/piper-voices/resolve/main/es/es_MX/claude/high/es_MX-claude-high.onnx?download=true && \
    curl -fSL --retry 3 --connect-timeout 60 \
      -o /out/models/piper/es_MX-claude-high.onnx.json \
      https://huggingface.co/rhasspy/piper-voices/resolve/main/es/es_MX/claude/high/es_MX-claude-high.onnx.json?download=true && \
    test -s /out/models/piper/es_MX-claude-high.onnx && \
    test -s /out/models/piper/es_MX-claude-high.onnx.json

# ============================================================================
# Stage 5: Bundle Piper TTS runtime binary (Rhasspy Piper CLI)
# ============================================================================
FROM fedora:${FEDORA_MAJOR} AS piper-runtime-builder

ARG PIPER_RUNTIME_VERSION=2023.11.14-2

RUN dnf install -y curl tar gzip && \
    dnf clean all

RUN set -eux && \
    mkdir -p /out/opt/lifeos/piper-tts && \
    curl -fSL --retry 3 --connect-timeout 60 \
      -o /tmp/piper_linux_x86_64.tar.gz \
      "https://github.com/rhasspy/piper/releases/download/${PIPER_RUNTIME_VERSION}/piper_linux_x86_64.tar.gz" && \
    tar -xzf /tmp/piper_linux_x86_64.tar.gz -C /tmp && \
    cp -a /tmp/piper/. /out/opt/lifeos/piper-tts/ && \
    test -x /out/opt/lifeos/piper-tts/piper && \
    /out/opt/lifeos/piper-tts/piper --help 2>&1 | grep -q -- '--model'

# ============================================================================
# Stage 6: Sistema Final
# ============================================================================
FROM quay.io/fedora/fedora-bootc:${FEDORA_MAJOR}

ARG LIFEOS_PRELOAD_MODEL=false
ARG FEDORA_MAJOR=43

ARG LIFEOS_CHANNEL=edge
ARG LIFEOS_VERSION=dev
ARG BUILD_DATE
ARG VCS_REF
ARG LIFEOS_NVIDIA_KMOD_SIGN_KEY_B64=""
ARG LIFEOS_NVIDIA_KMOD_CERT_DER_B64=""

LABEL org.lifeos.channel="${LIFEOS_CHANNEL}" \
      org.lifeos.version="${LIFEOS_VERSION}" \
      org.lifeos.build-date="${BUILD_DATE}" \
      org.lifeos.vcs-ref="${VCS_REF}" \
      org.opencontainers.image.source="https://github.com/hectormrm/lifeos" \
      org.opencontainers.image.title="LifeOS" \
      org.opencontainers.image.description="AI-focused operating system with COSMIC Desktop" \
      org.opencontainers.image.version="${LIFEOS_VERSION}" \
      org.opencontainers.image.created="${BUILD_DATE}" \
      org.opencontainers.image.revision="${VCS_REF}"

# --- Repositorios adicionales (COSMIC y RPMFusion) ---
RUN dnf -y install dnf5-plugins && \
    dnf -y copr enable ryanabx/cosmic-epoch && \
    dnf -y install distribution-gpg-keys && \
    rpm --import \
      /usr/share/distribution-gpg-keys/rpmfusion/RPM-GPG-KEY-rpmfusion-free-fedora-2020 \
      /usr/share/distribution-gpg-keys/rpmfusion/RPM-GPG-KEY-rpmfusion-nonfree-fedora-2020 && \
    dnf -y --setopt=localpkg_gpgcheck=1 install \
      "https://mirrors.rpmfusion.org/free/fedora/rpmfusion-free-release-$(rpm -E %fedora).noarch.rpm" \
      "https://mirrors.rpmfusion.org/nonfree/fedora/rpmfusion-nonfree-release-$(rpm -E %fedora).noarch.rpm" && \
    dnf clean all

# --- Escritorio COSMIC y Base ---
RUN dnf -y install --skip-unavailable \
    cosmic-desktop cosmic-files cosmic-term cosmic-edit cosmic-store \
    xdg-desktop-portal-cosmic xdg-desktop-portal-gtk xdg-desktop-portal-wlr \
    xdg-user-dirs \
    NetworkManager NetworkManager-wifi wpa_supplicant wireless-regdb iwd \
    bluez bluez-tools \
    pipewire wireplumber pipewire-alsa pipewire-pulseaudio pipewire-utils \
    alsa-utils alsa-sof-firmware alsa-ucm \
    v4l-utils libcamera \
    gnome-screenshot grim scrot maim \
    tesseract tesseract-langpack-eng tesseract-langpack-spa \
    espeak-ng \
    vulkan-loader \
    fwupd \
    && dnf clean all

# --- Soporte Nvidia Optimus y Gaming ---
RUN set -eux && \
    dnf -y install --skip-unavailable \
        kernel-devel akmod-nvidia xorg-x11-drv-nvidia-cuda \
        xorg-x11-drv-nvidia-power nvidia-settings nvidia-modprobe && \
    if dnf -q repoquery --available --qf '%{name}' supergfxctl 2>/dev/null | grep -Fxq supergfxctl; then \
        dnf -y install supergfxctl; \
    else \
        echo "INFO: supergfxctl not available in current repos; continuing without hybrid-switch helper"; \
    fi && \
    if dnf -q repoquery --available --qf '%{name}' akmod-wl 2>/dev/null | grep -Fxq akmod-wl; then \
        dnf -y install broadcom-wl akmod-wl; \
    else \
        echo "INFO: broadcom-wl/akmod-wl not available in current repos; continuing without Broadcom proprietary module"; \
    fi && \
    if command -v akmods >/dev/null 2>&1; then \
        for modules_dir in /usr/lib/modules/*; do \
            [ -d "${modules_dir}" ] || continue; \
            kernel_ver="$(basename "${modules_dir}")"; \
            if [ ! -d "/usr/src/kernels/${kernel_ver}" ]; then \
                echo "WARNING: kernel-devel missing for ${kernel_ver}; skipping akmods build for that kernel"; \
                continue; \
            fi; \
            akmods --force --kernels "${kernel_ver}" || echo "WARNING: akmods failed for ${kernel_ver} in build environment; will retry on target host"; \
        done; \
    fi && \
    install -d /usr/share/lifeos/secureboot && \
    if [ -n "${LIFEOS_NVIDIA_KMOD_SIGN_KEY_B64:-}" ] && [ -n "${LIFEOS_NVIDIA_KMOD_CERT_DER_B64:-}" ]; then \
        KMOD_SIGN_KEY=/tmp/lifeos-nvidia-kmod-sign.key; \
        KMOD_SIGN_CERT=/tmp/lifeos-nvidia-kmod-sign.der; \
        echo "${LIFEOS_NVIDIA_KMOD_SIGN_KEY_B64}" | base64 -d > "${KMOD_SIGN_KEY}"; \
        echo "${LIFEOS_NVIDIA_KMOD_CERT_DER_B64}" | base64 -d > "${KMOD_SIGN_CERT}"; \
        chmod 0600 "${KMOD_SIGN_KEY}" "${KMOD_SIGN_CERT}"; \
        cp -f "${KMOD_SIGN_CERT}" /usr/share/lifeos/secureboot/lifeos-nvidia-kmod.der; \
        SIGNED_COUNT=0; \
        KERNELS_WITH_MISSING_SIGN_TOOL=0; \
        for modules_dir in /usr/lib/modules/*; do \
            [ -d "${modules_dir}/extra/nvidia" ] || continue; \
            kernel_ver="$(basename "${modules_dir}")"; \
            SIGN_TOOL="/usr/src/kernels/${kernel_ver}/scripts/sign-file"; \
            if [ ! -x "${SIGN_TOOL}" ]; then \
                echo "ERROR: sign-file tool not found for kernel ${kernel_ver} at ${SIGN_TOOL}; cannot sign NVIDIA modules"; \
                KERNELS_WITH_MISSING_SIGN_TOOL=$((KERNELS_WITH_MISSING_SIGN_TOOL + 1)); \
                continue; \
            fi; \
            for mod in "${modules_dir}"/extra/nvidia/*.ko; do \
                [ -e "${mod}" ] || continue; \
                "${SIGN_TOOL}" sha256 "${KMOD_SIGN_KEY}" "${KMOD_SIGN_CERT}" "${mod}"; \
                SIGNED_COUNT=$((SIGNED_COUNT + 1)); \
            done; \
            depmod "${kernel_ver}" || true; \
        done; \
        if [ "${KERNELS_WITH_MISSING_SIGN_TOOL}" -gt 0 ]; then \
            echo "ERROR: ${KERNELS_WITH_MISSING_SIGN_TOOL} kernel module trees could not be signed due to missing sign-file"; \
            exit 1; \
        fi; \
        if [ "${SIGNED_COUNT}" -eq 0 ]; then \
            echo "ERROR: No NVIDIA kernel modules found to sign"; \
            exit 1; \
        fi; \
        UNSIGNED_COUNT=0; \
        for mod in /usr/lib/modules/*/extra/nvidia/*.ko; do \
            [ -e "${mod}" ] || continue; \
            if [ -z "$(modinfo -F signer "${mod}" 2>/dev/null || true)" ]; then \
                echo "ERROR: NVIDIA module still unsigned after signing: ${mod}"; \
                UNSIGNED_COUNT=$((UNSIGNED_COUNT + 1)); \
            fi; \
        done; \
        if [ "${UNSIGNED_COUNT}" -gt 0 ]; then \
            echo "ERROR: ${UNSIGNED_COUNT} NVIDIA modules are unsigned; refusing build"; \
            exit 1; \
        fi; \
        echo "INFO: Signed ${SIGNED_COUNT} NVIDIA kernel modules for Secure Boot"; \
        rm -f "${KMOD_SIGN_KEY}" "${KMOD_SIGN_CERT}"; \
    else \
        echo "INFO: NVIDIA module signing secrets not provided; Secure Boot may reject NVIDIA modules"; \
        rm -f /usr/share/lifeos/secureboot/lifeos-nvidia-kmod.der; \
    fi && \
    dnf clean all

# --- Steam/Proton (default via RPM Fusion) + ProtonUp-Qt ---
RUN set -eux && \
    dnf -y install steam steam-devices && \
    if dnf -q repoquery --available --qf '%{name}' protonup-qt 2>/dev/null | grep -Fxq protonup-qt; then \
        dnf -y install protonup-qt; \
    else \
        echo "INFO: protonup-qt RPM not available; installing official Flatpak app (net.davidotek.pupgui2)"; \
        dnf -y install flatpak && \
        flatpak remote-add --if-not-exists --system flathub https://flathub.org/repo/flathub.flatpakrepo && \
        flatpak install --system -y --noninteractive flathub net.davidotek.pupgui2; \
    fi && \
    dnf clean all

# --- Firefox Hardened (Privacy-first browser) ---
RUN dnf -y install \
    firefox \
    && dnf clean all

# Download uBlock Origin extension for global installation
# This is installed as a "distributed extension" that cannot be uninstalled by users
RUN set -eux && \
    UBLOCK_URL="https://addons.mozilla.org/firefox/downloads/latest/ublock-origin/addon-607454-latest.xpi" && \
    TMP_XPI="/tmp/uBlock0@raymondhill.net.xpi" && \
    curl -fSL --retry 3 -o "${TMP_XPI}" "${UBLOCK_URL}" && \
    test -s "${TMP_XPI}" && \
    mkdir -p /usr/lib/firefox/distribution/extensions && \
    install -m 0644 "${TMP_XPI}" /usr/lib/firefox/distribution/extensions/uBlock0@raymondhill.net.xpi && \
    mkdir -p /usr/lib64/firefox/distribution/extensions && \
    install -m 0644 "${TMP_XPI}" /usr/lib64/firefox/distribution/extensions/uBlock0@raymondhill.net.xpi && \
    rm -f "${TMP_XPI}" && \
    echo ">>> uBlock Origin extension downloaded to /usr/lib and /usr/lib64 Firefox distribution paths"

# --- Herramientas del Sistema ---
# Incluye toolchain de desarrollo para que LifeOS pueda auto-hospedar
# build/test de `life` y `lifeosd --all-features` sin toolbox adicional.
RUN dnf -y install \
    toolbox btrfs-progs smartmontools podman podman-docker podman-compose buildah skopeo flatpak \
    qemu-kvm libvirt-client libvirt-daemon libvirt-daemon-config-network libvirt-daemon-kvm \
    libvirt-daemon-driver-qemu libvirt-daemon-driver-network \
    virt-install virt-viewer virt-manager edk2-ovmf swtpm spice-vdagent \
    fuse-overlayfs slirp4netns \
    fish bat ripgrep fd-find htop fastfetch age jq sqlite git gh wget \
    pkgconf-pkg-config \
    gcc gcc-c++ make cmake \
    openssl-devel \
    dbus-devel glib2-devel gtk4-devel libadwaita-devel \
    rust cargo rustfmt clippy rust-analyzer \
    wlsunset gammastep \
    linux-firmware \
    pciutils usbutils biosdevname prefixdevname curl ca-certificates openssl-libs cryptsetup \
    python3-mako \
    anaconda-core anaconda-dracut \
    lorax-templates-generic \
    shim-x64 grub2-efi-x64 grub2-efi-x64-modules grub2-efi-x64-cdboot \
    glibc-langpack-es glibc-langpack-en \
    langpacks-es langpacks-en \
    && dnf clean all

# --- Aplicaciones Nativas Esenciales ---
RUN dnf -y install \
    mpv evince keepassxc \
    && dnf clean all

# bootc-image-builder expects EFI binaries under /boot/efi/EFI/fedora when producing installer ISOs.
# Fedora 42 exposed these via /usr/lib/bootupd/updates/EFI/fedora, while newer bootc images
# store versioned shim/grub artifacts under /usr/lib/efi/*/.../EFI/fedora.
RUN set -eux && \
    mkdir -p /boot/efi/EFI/fedora && \
    if [ -d /usr/lib/bootupd/updates/EFI/fedora ]; then \
        cp -a /usr/lib/bootupd/updates/EFI/fedora/. /boot/efi/EFI/fedora/; \
    else \
        test -d /usr/lib/efi/shim && \
        test -d /usr/lib/efi/grub2 && \
        find /usr/lib/efi/shim -type f -path '*/EFI/fedora/*' -exec cp -a {} /boot/efi/EFI/fedora/ \; && \
        find /usr/lib/efi/grub2 -type f -path '*/EFI/fedora/*' -exec cp -a {} /boot/efi/EFI/fedora/ \; && \
        test -f /boot/efi/EFI/fedora/shimx64.efi && \
        test -f /boot/efi/EFI/fedora/grubx64.efi; \
    fi

# --- CLI Life y Daemon (binarios compilados) ---
COPY --from=builder /out/life /usr/bin/life
COPY --from=builder /out/lifeosd /usr/bin/lifeosd
COPY --from=builder /opt/lifeos-devtools/bin/cargo-audit /usr/local/bin/cargo-audit
RUN chmod +x /usr/bin/life /usr/bin/lifeosd && \
    ln -sf /usr/bin/life /usr/local/bin/life && \
    ln -sf /usr/bin/lifeosd /usr/local/bin/lifeosd && \
    life --version

# --- AI Runtime (llama.cpp / llama-server) ---
# Built in isolated stage to avoid pulling/removing toolchains in the final image.
COPY --from=llama-builder /out/llama-server /usr/sbin/llama-server
COPY --from=whisper-builder /out/whisper-cli /usr/bin/whisper-cli
RUN set -eux && \
    ln -f /usr/sbin/llama-server /usr/bin/llama-server 2>/dev/null || true && \
    ln -f /usr/bin/whisper-cli /usr/local/bin/whisper-cli 2>/dev/null || true && \
    echo ">>> Verifying AI runtime binaries..." && \
    /usr/sbin/llama-server --version && \
    /usr/bin/whisper-cli -h >/dev/null && \
    echo ">>> llama-server installed at /usr/sbin and /usr/bin" && \
    ls -la /usr/sbin/llama-server /usr/bin/llama-server /usr/bin/whisper-cli

# --- Directorios LifeOS ---
# bootc installer + lorax expect /var/mnt to exist because /mnt -> /var/mnt.
RUN mkdir -p /usr/share/lifeos/models /var/lib/lifeos /var/lib/lifeos/models /var/log/lifeos /etc/lifeos /var/mnt /var/roothome && \
    chmod 0700 /var/roothome

COPY --from=whisper-builder /out/models/whisper /usr/share/lifeos/models/whisper
COPY --from=piper-voice-builder /out/models/piper /usr/share/lifeos/models/piper
COPY --from=piper-runtime-builder /out/opt/lifeos/piper-tts /opt/lifeos/piper-tts

RUN ln -sf /opt/lifeos/piper-tts/piper /usr/local/bin/lifeos-piper

# --- AI Model (pre-bundled) ---
# Qwen3.5-4B: multimodal vision-language model with hybrid DeltaNet architecture.
# Q4_K_M quantization (~2.74GB) + F16 vision projector (~672MB) = ~3.4GB total.
# See docs/AI_MODEL_SELECTION.md for technical justification.
RUN set -eux && \
    if [ "${LIFEOS_PRELOAD_MODEL:-false}" = "true" ]; then \
        MODEL_URL="https://huggingface.co/unsloth/Qwen3.5-4B-GGUF/resolve/main/Qwen3.5-4B-Q4_K_M.gguf" && \
        MODEL_FILE="/usr/share/lifeos/models/Qwen3.5-4B-Q4_K_M.gguf" && \
        MMPROJ_URL="https://huggingface.co/unsloth/Qwen3.5-4B-GGUF/resolve/main/mmproj-F16.gguf" && \
        MMPROJ_FILE="/usr/share/lifeos/models/Qwen3.5-4B-mmproj-F16.gguf" && \
        echo ">>> LIFEOS_PRELOAD_MODEL=true: downloading Qwen3.5-4B assets..." && \
        curl -fSL --retry 3 --connect-timeout 60 -o "${MODEL_FILE}" "${MODEL_URL}" && \
        echo ">>> Model size: $(du -h "${MODEL_FILE}" | cut -f1)" && \
        test -s "${MODEL_FILE}" || { echo "ERROR: Model file is empty"; exit 1; } && \
        curl -fSL --retry 3 --connect-timeout 60 -o "${MMPROJ_FILE}" "${MMPROJ_URL}" && \
        echo ">>> mmproj size: $(du -h "${MMPROJ_FILE}" | cut -f1)" && \
        test -s "${MMPROJ_FILE}" || { echo "ERROR: mmproj file is empty"; exit 1; }; \
    else \
        echo ">>> LIFEOS_PRELOAD_MODEL=false: skipping model pre-bundle to keep image pull/build lightweight"; \
    fi

# --- Copiar archivos de configuración y scripts desde el repo ---
