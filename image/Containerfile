# lifeosd.service (inline - es simple)
RUN printf '%s\n' \
    '[Unit]' \
    'Description=LifeOS System Daemon' \
    'After=network-online.target lifeos-security-baseline.service' \
    'Wants=network-online.target lifeos-security-baseline.service' \
    '' \
    '[Service]' \
    'Type=simple' \
    'Environment=LIFEOS_TTS_BIN=/usr/local/bin/lifeos-piper' \
    'Environment=LIFEOS_TTS_MODEL=/usr/share/lifeos/models/piper/es_MX-claude-high.onnx' \
    'Environment=LIFEOS_TTS_FALLBACK_BIN=/usr/bin/espeak-ng' \
    'ExecStart=/usr/bin/lifeosd' \
    'Restart=on-failure' \
    'RestartSec=5' \
    '' \
    '[Install]' \
    'WantedBy=multi-user.target' \
    > /usr/lib/systemd/system/lifeosd.service

# Habilitar servicios via symlinks
RUN mkdir -p /usr/lib/systemd/system/multi-user.target.wants \
             /usr/lib/systemd/system/graphical.target.wants \
             /usr/lib/systemd/system/timers.target.wants \
             /usr/lib/systemd/system/sockets.target.wants \
             /usr/lib/systemd/user/default.target.wants \
             /usr/lib/systemd/user/pipewire.service.wants \
             /usr/lib/systemd/user/pipewire-pulse.service.wants \
             /usr/lib/systemd/user/wireplumber.service.wants && \
    ln -sf /usr/lib/systemd/system/lifeos-security-baseline.service /usr/lib/systemd/system/multi-user.target.wants/lifeos-security-baseline.service && \
    ln -sf /usr/lib/systemd/system/lifeosd.service       /usr/lib/systemd/system/multi-user.target.wants/lifeosd.service && \
    ln -sf /usr/lib/systemd/system/llama-server.service   /usr/lib/systemd/system/multi-user.target.wants/llama-server.service && \
    ln -sf /usr/lib/systemd/system/whisper-stt.service    /usr/lib/systemd/system/multi-user.target.wants/whisper-stt.service && \
    ln -sf /usr/lib/systemd/system/lifeos-btrfs-snapshot.timer /usr/lib/systemd/system/timers.target.wants/lifeos-btrfs-snapshot.timer && \
    ln -sf /usr/lib/systemd/system/lifeos-maintenance-cleanup.timer /usr/lib/systemd/system/timers.target.wants/lifeos-maintenance-cleanup.timer && \
    ln -sf /usr/lib/systemd/system/lifeos-first-boot.service /usr/lib/systemd/system/graphical.target.wants/lifeos-first-boot.service && \
    ln -sf /usr/lib/systemd/system/bluetooth.service      /usr/lib/systemd/system/multi-user.target.wants/bluetooth.service && \
    ln -sf /usr/lib/systemd/system/NetworkManager.service /usr/lib/systemd/system/multi-user.target.wants/NetworkManager.service && \
    if [ -f /usr/lib/systemd/system/supergfxd.service ]; then \
        ln -sf /usr/lib/systemd/system/supergfxd.service /usr/lib/systemd/system/multi-user.target.wants/supergfxd.service; \
    fi && \
    if [ -f /usr/lib/systemd/system/libvirtd.service ]; then \
        ln -sf /usr/lib/systemd/system/libvirtd.service /usr/lib/systemd/system/multi-user.target.wants/libvirtd.service; \
    fi && \
    if [ -f /usr/lib/systemd/system/spice-vdagentd.service ]; then \
        ln -sf /usr/lib/systemd/system/spice-vdagentd.service /usr/lib/systemd/system/graphical.target.wants/spice-vdagentd.service; \
    fi && \
    for unit in virtqemud.socket virtnetworkd.socket virtstoraged.socket virtlogd.socket virtproxyd.socket; do \
        if [ -f "/usr/lib/systemd/system/${unit}" ]; then \
            ln -sf "/usr/lib/systemd/system/${unit}" "/usr/lib/systemd/system/sockets.target.wants/${unit}"; \
        fi; \
    done && \
    ln -sf /usr/lib/systemd/system/lifeosd.service        /usr/lib/systemd/system/lifeisd.service && \
    ln -sf /usr/lib/systemd/user/lifeos-audio-route-heal.service /usr/lib/systemd/user/default.target.wants/lifeos-audio-route-heal.service && \
    ln -sf /usr/lib/systemd/user/lifeos-audio-route-heal.service /usr/lib/systemd/user/pipewire.service.wants/lifeos-audio-route-heal.service && \
    ln -sf /usr/lib/systemd/user/lifeos-audio-route-heal.service /usr/lib/systemd/user/pipewire-pulse.service.wants/lifeos-audio-route-heal.service && \
    ln -sf /usr/lib/systemd/user/lifeos-audio-route-heal.service /usr/lib/systemd/user/wireplumber.service.wants/lifeos-audio-route-heal.service

