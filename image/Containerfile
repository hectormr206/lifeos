# --- Herramientas del Sistema ---
# Incluye toolchain de desarrollo para que LifeOS pueda auto-hospedar
# build/test de `life` y `lifeosd --all-features` sin toolbox adicional.
# Fedora 44's bootc base image now ships `ffmpeg-free` pre-installed,
# which conflicts with the `ffmpeg` package from rpmfusion-free that
# we install for SimpleX voice/video transcoding. `--allowerasing`
# lets dnf swap the free variant for the rpmfusion variant in a single
# transaction. Without it the build fails at line 576 with
# `installed package ffmpeg-free conflicts with ffmpeg from rpmfusion-free`.
RUN dnf -y install --allowerasing \
    toolbox btrfs-progs smartmontools podman podman-docker podman-compose buildah skopeo flatpak \
    qemu-kvm libvirt-client libvirt-daemon libvirt-daemon-config-network libvirt-daemon-kvm \
    libvirt-daemon-driver-qemu libvirt-daemon-driver-network \
    virt-install virt-viewer virt-manager edk2-ovmf swtpm spice-vdagent \
    fuse-overlayfs slirp4netns \
    fish bat ripgrep fd-find htop fastfetch age jq sqlite git gh wget \
    zoxide fzf eza atuin direnv tmux btop neovim \
    rsms-inter-fonts jetbrains-mono-fonts cascadia-code-nf-fonts \
    google-noto-color-emoji-fonts pop-icon-theme \
    pkgconf-pkg-config \
    gcc gcc-c++ make cmake \
    openssl-devel \
    dbus-devel glib2-devel gtk4-devel libadwaita-devel \
    wayland-devel libxkbcommon-devel \
    rust cargo rustfmt clippy rust-analyzer \
    wlsunset \
    linux-firmware \
    aide firewalld audit \
    powertop zram-generator \
    pciutils usbutils biosdevname prefixdevname curl ca-certificates openssl-libs cryptsetup \
    ffmpeg \
    python3-mako \
    anaconda-core anaconda-dracut \
    lorax-templates-generic \
    shim-x64 grub2-efi-x64 grub2-efi-x64-modules grub2-efi-x64-cdboot \
    glibc-langpack-es glibc-langpack-en \
    langpacks-es langpacks-en \
    && dnf clean all

# --- Pre-generate fontconfig cache (avoids cold-cache delay on first boot) ---
RUN fc-cache -f 2>&1 | tail -5 || true

# --- Speaker identification runtime — REMOVED ---
# The WeSpeaker ONNX runtime (python3-pip + python3-numpy + onnxruntime
# pip package, ~150 MB) moved INTO ghcr.io/hectormr206/lifeos-lifeosd:stable.
# The daemon spawns python3 lifeos-speaker-embedding.py inside the
# container; nothing on the host needs onnxruntime any more.

# --- Aplicaciones de Escritorio (Flatpak — auto-update via lifeos-flatpak-update.timer) ---
# mpv, evince, keepassxc, loupe moved from RPM to Flatpak for independent updates.
# Installed at first boot; if flathub is not reachable during build, user gets them on first login.
RUN flatpak remote-add --if-not-exists --system flathub \
        https://flathub.org/repo/flathub.flatpakrepo 2>/dev/null || true && \
    flatpak install --system -y --noninteractive flathub \
        io.mpv.Mpv \
        org.gnome.Evince \
        org.keepassxc.KeePassXC \
        org.gnome.Loupe \
        2>/dev/null || \
    echo "INFO: Desktop apps will be installed on first boot via flatpak"

# bootc-image-builder expects EFI binaries under /boot/efi/EFI/fedora when producing installer ISOs.
# Fedora 42 exposed these via /usr/lib/bootupd/updates/EFI/fedora, while newer bootc images
# store versioned shim/grub artifacts under /usr/lib/efi/*/.../EFI/fedora.
RUN set -eux && \
    mkdir -p /boot/efi/EFI/fedora && \
    if [ -d /usr/lib/bootupd/updates/EFI/fedora ]; then \
        cp -a /usr/lib/bootupd/updates/EFI/fedora/. /boot/efi/EFI/fedora/; \
    else \
        test -d /usr/lib/efi/shim && \
        test -d /usr/lib/efi/grub2 && \
        find /usr/lib/efi/shim -type f -path '*/EFI/fedora/*' -exec cp -a {} /boot/efi/EFI/fedora/ \; && \
        find /usr/lib/efi/grub2 -type f -path '*/EFI/fedora/*' -exec cp -a {} /boot/efi/EFI/fedora/ \; && \
        test -f /boot/efi/EFI/fedora/shimx64.efi && \
        test -f /boot/efi/EFI/fedora/grubx64.efi; \
    fi

# --- CLI LifeOS build artifacts needed before app/config layers ---
# Phase-3-trim: lifeos-train-wakeword removed from bootc (~80 MB). Wake-word
# personalization is a niche one-off training step that runs in a distrobox
# / Toolbx, not a daily host binary; users who need it can pull a dedicated
# training container. The Cargo build no longer produces it either (see the
# Stage 1 builder rules).
# Phase-3-trim: legacy /usr/local/bin/simplex-chat host binary removed
# (~30 MB). Phase 5 of the architecture pivot replaced it with the
# ghcr.io/hectormr206/lifeos-simplex-bridge:stable Quadlet container; the
# host copy was kept only as a manual rollback target. With Phase 3/7/8
# in production we don't need it any more.

# --- AI Runtime ---
# Phase 4: llama-server moved to ghcr.io/hectormr206/lifeos-llama-server
#   (Quadlet + nvidia-container-toolkit CDI for GPU passthrough).
# Phase 7: whisper-cli moved INTO ghcr.io/hectormr206/lifeos-lifeosd because
#   the daemon (now itself a Quadlet) is the only consumer of whisper-cli for
#   file-based STT (simplex voice notes, meeting clips). Saves ~10 MB host
#   image. whisper-stream (live PipeWire capture) is deferred to the
#   lifeosd-desktop companion (Phase 3b) — it needs the user's PipeWire
#   socket which a headless Quadlet container does not have.
# The host-side lifeos-stt-setup.sh + whisper-stt.service still download
# model files into /var/lib/lifeos/models/whisper; that path is bind-mounted
# into the lifeos-lifeosd container so the daemon's whisper-cli reads it.

# --- Phase 4: nvidia-container-toolkit for GPU passthrough into Quadlets ---
# Required so the lifeos-llama-server.container can request `nvidia.com/gpu=all`
# and get the host driver injected via CDI. The Fedora 43 RPM digest issue
# documented in earlier sessions is gone in fc44 — packages install cleanly.
# `sslverify=0` on the repo file is a workaround for a current /etc/pki ca-bundle
# corruption inside the bootc rootfs builder; the package is GPG-verified by
# its own gpgkey directive so SSL is just transport hardening.
RUN curl -fsSL -o /etc/yum.repos.d/nvidia-container-toolkit.repo \
        https://nvidia.github.io/libnvidia-container/stable/rpm/nvidia-container-toolkit.repo && \
    sed -i 's/^sslverify=1/sslverify=0/' /etc/yum.repos.d/nvidia-container-toolkit.repo && \
    dnf -y install nvidia-container-toolkit && \
    dnf clean all

# Generate the CDI spec at image build time so the laptop boots with a
# valid /etc/cdi/nvidia.yaml without first-boot regen latency. The
# nvidia-cdi-refresh.path watcher (installed by the toolkit) keeps the
# spec in sync with driver updates afterwards.
# We can't run nvidia-ctk against the actual host GPU during the bootc
# build (the builder has no /dev/nvidia*), so we ship the toolkit and
# let the post-install scriptlet's nvidia-cdi-refresh handle first-boot
# regeneration via systemd path activation.

# --- Directorios LifeOS ---
# bootc installer + lorax expect /var/mnt to exist because /mnt -> /var/mnt.
RUN mkdir -p /usr/share/lifeos/models /var/lib/lifeos /var/lib/lifeos/models /var/log/lifeos /etc/lifeos /var/mnt /var/roothome && \
    chmod 0700 /var/roothome && \
    chmod 0775 /var/lib/lifeos /var/lib/lifeos/models /var/log/lifeos && \
    chgrp wheel /var/lib/lifeos /var/lib/lifeos/models /var/log/lifeos

# Phase 6b: whisper STT models live at /var/lib/lifeos/models/whisper —
# downloaded at first boot by lifeos-stt-setup.sh, bind-mounted into the
# lifeos-lifeosd container.
# Phase-3-trim: WeSpeaker ONNX moved INTO the lifeos-lifeosd container
# (containers/lifeos-lifeosd/Containerfile, stage `wespeaker-fetch`).
# The /usr/share/lifeos/models/ directory above stays empty on bootc.

# --- Kokoro TTS runtime: env file only ---
#
# Phase 6 of the architecture pivot — the Python venv, voice models,
# manifest, and server script all moved INTO ghcr.io/hectormr206/lifeos-tts:stable.
# bootc only ships the env file the Quadlet bind-mounts at runtime.
# The legacy lifeos-tts-server.service is removed; rollback path is
# `bootc rollback` to the previous deployment.
COPY image/files/etc/lifeos/tts-server.env /etc/lifeos/tts-server.env

# --- Capa 4 — image guardian (PRD §5e) ---
# Best-effort script + systemd unit that re-pulls system Quadlet images if
# they were deleted from rootful containers-storage. Also wired as
# ExecStartPre of every Quadlet, so the same code path runs before each
# container start (defense-in-depth — works even if guardian.service is
# masked).
COPY image/files/usr/local/bin/lifeos-ensure-images /usr/local/bin/lifeos-ensure-images
COPY image/files/etc/systemd/system/lifeos-image-guardian.service /usr/lib/systemd/system/lifeos-image-guardian.service
RUN chmod +x /usr/local/bin/lifeos-ensure-images

# --- Phase 1: TTS Quadlet (architecture pivot) ---
# Drop the systemd Quadlet definition. systemd-generator picks it up at boot
# and synthesizes lifeos-tts.service automatically — no symlink needed.
# The Quadlet image (ghcr.io/hectormr206/lifeos-tts:stable) is built by the
# side-images.yml workflow and pulled at first boot via lifeos-ensure-images.
# The legacy lifeos-tts-server.service was REMOVED in Phase 6. The bootc
# rollback path is now `bootc rollback` to a previous deployment, not a
# manual systemctl unmask of an in-image legacy unit. PRD §5a + §6.
COPY containers/lifeos-tts/lifeos-tts.container /usr/share/containers/systemd/lifeos-tts.container

# Phase 8: dedicated podman bridge `lifeos-net`. Side containers (TTS,
# llama-server, llama-embeddings, simplex-bridge) attach to it instead of
# the host network namespace. Each one keeps PublishPort=127.0.0.1:PORT:PORT
# so the daemon (still Network=host until Phase 8b daemon URL refactor)
# reaches them via loopback unchanged.
COPY containers/lifeos-net/lifeos-net.network /usr/share/containers/systemd/lifeos-net.network

# Phase 6: the venv smoke test moved into containers/lifeos-tts/Containerfile
# (`from kokoro import KPipeline` runs there at build time). The bootc image
# no longer ships the venv to test.

# --- AI Model (pre-bundled) ---
# Qwen3.5-4B: multimodal vision-language model with hybrid DeltaNet architecture.
# Q4_K_M quantization (~2.74GB) + F16 vision projector (~672MB) = ~3.4GB total.
# See docs/AI_MODEL_SELECTION.md for technical justification.
RUN set -eux && \
    if [ "${LIFEOS_PRELOAD_MODEL:-false}" = "true" ]; then \
        MODEL_URL="https://huggingface.co/unsloth/Qwen3.5-4B-GGUF/resolve/main/Qwen3.5-4B-Q4_K_M.gguf" && \
        MODEL_FILE="/usr/share/lifeos/models/Qwen3.5-4B-Q4_K_M.gguf" && \
        MMPROJ_URL="https://huggingface.co/unsloth/Qwen3.5-4B-GGUF/resolve/main/mmproj-F16.gguf" && \
        MMPROJ_FILE="/usr/share/lifeos/models/Qwen3.5-4B-mmproj-F16.gguf" && \
        echo ">>> LIFEOS_PRELOAD_MODEL=true: downloading Qwen3.5-4B assets..." && \
        curl -fSL --retry 3 --connect-timeout 60 -o "${MODEL_FILE}" "${MODEL_URL}" && \
        echo ">>> Model size: $(du -h "${MODEL_FILE}" | cut -f1)" && \
        test -s "${MODEL_FILE}" || { echo "ERROR: Model file is empty"; exit 1; } && \
        curl -fSL --retry 3 --connect-timeout 60 -o "${MMPROJ_FILE}" "${MMPROJ_URL}" && \
        echo ">>> mmproj size: $(du -h "${MMPROJ_FILE}" | cut -f1)" && \
        test -s "${MMPROJ_FILE}" || { echo "ERROR: mmproj file is empty"; exit 1; }; \
    else \
        echo ">>> LIFEOS_PRELOAD_MODEL=false: skipping model pre-bundle to keep image pull/build lightweight"; \
    fi

