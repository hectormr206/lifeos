# --- Final llama-server verification ---
# Belt-and-suspenders: verify the AI binaries survived all dnf operations.
# Also clean up any stale .so files from previous pre-compiled builds.
RUN set -eux && \
    rm -f /usr/lib64/libllama.so* /usr/lib64/libggml*.so* /usr/lib64/libmtmd.so* && \
    ldconfig && \
    LLAMA_BIN="$(command -v llama-server 2>/dev/null || find /usr -name llama-server -type f 2>/dev/null | head -1)" && \
    echo ">>> Final check: llama-server at ${LLAMA_BIN:-NOT FOUND}" && \
    test -n "${LLAMA_BIN}" || { echo "FATAL: llama-server disappeared"; exit 1; } && \
    for dest in /usr/bin/llama-server /usr/sbin/llama-server; do \
        if [ ! -x "$dest" ]; then \
            ln -f "${LLAMA_BIN}" "$dest" 2>/dev/null || cp -f "${LLAMA_BIN}" "$dest" && \
            chmod 0755 "$dest" && \
            echo ">>> Linked to $dest"; \
        fi; \
    done && \
    ls -la /usr/bin/llama-server /usr/sbin/llama-server /usr/bin/whisper-cli /usr/bin/whisper-stream && \
    /usr/sbin/llama-server --version && \
    /usr/bin/whisper-cli -h >/dev/null && \
    /usr/bin/whisper-stream -h >/dev/null

# --- Verificación final ---
# Wrapper reports WHICH check failed instead of a silent exit code.
RUN set -e; fail() { echo "VERIFY FAILED: $1"; exit 1; }; \
