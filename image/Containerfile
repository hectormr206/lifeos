# image/Containerfile
# LifeOS: construido directamente sobre Fedora bootc
# Incorpora COSMIC Desktop, Nvidia Optimus y llama-server (AI local)
# Gaming (Steam/Proton) disponible via Flatpak desde COSMIC Store
#
# Build context must be the repo root:
#   podman build -t lifeos:latest -f image/Containerfile .
#
# Channel builds:
#   podman build --build-arg LIFEOS_CHANNEL=stable -t lifeos:stable -f image/Containerfile .
#   podman build --build-arg LIFEOS_CHANNEL=candidate -t lifeos:candidate -f image/Containerfile .
#   podman build --build-arg LIFEOS_CHANNEL=edge -t lifeos:edge -f image/Containerfile .

# Build against the latest supported Fedora major release.
ARG FEDORA_MAJOR=43

# ============================================================================
# Stage 1: Build CLI + Daemon (Rust)
# ============================================================================
FROM fedora:${FEDORA_MAJOR} AS builder

ARG LIFEOS_CHANNEL=edge
# Runtime booted version for bootc/channel manifests.
# Keep distinct from the formal workspace package semver in Cargo.toml.
ARG LIFEOS_VERSION=dev
ARG BUILD_DATE
ARG VCS_REF
ARG LIFEOS_NVIDIA_KMOD_SIGN_KEY_B64=""
ARG LIFEOS_NVIDIA_KMOD_CERT_DER_B64=""
ARG LIFEOS_PRELOAD_MODEL=false

# Image variant selector for the AMD/NVIDIA split (item #12 in
# docs/operations/pending-items-roadmap.md). Values:
#   "nvidia" (default) — full image with proprietary NVIDIA drivers,
#                        akmods, CUDA, Secure Boot signing, and
#                        nvidia-persistenced enabled. Backwards
#                        compatible with the pre-split build.
#   "amd"             — lean image for AMD / Intel / ARM hosts.
#                       Skips the nvidia-kmod-builder stage inputs,
#                       skips nvidia-persistenced enablement, and
#                       does not install the NVIDIA userspace packages.
#                       (Full skip wiring is tracked as follow-up; this
#                       arg is the anchor point for the refactor.)
ARG LIFEOS_IMAGE_VARIANT=nvidia


# Tune dnf for fast package downloads. Default dnf5 ships with
# max_parallel_downloads=3 which bottlenecks heavily on the Fedora
# mirror network — builder stage pulls ~500 transitive packages and
# on Hector's connection individual mirrors were delivering 9 KiB/s,
# stretching STEP 11 past 90 minutes. Raising the parallel ceiling
# to 20 and enabling fastestmirror cut download time by ~3-5x.
# minrate=1k gives dnf permission to drop a stalled mirror after a
# sane threshold instead of hanging indefinitely on a dead CDN.
RUN printf '%s\n' \
        'max_parallel_downloads=20' \
        'minrate=5k' \
        'timeout=20' \
        'deltarpm=False' \
        >> /etc/dnf/dnf.conf

RUN dnf -y install \
    rust cargo \
    openssl-devel \
    pkgconf-pkg-config \
    gcc \
    git \
    dbus-devel \
    glib2-devel \
    gtk4-devel \
    libadwaita-devel \
    pango-devel \
    gdk-pixbuf2-devel \
    graphene-devel \
    cairo-devel \
    wayland-devel \
    libxkbcommon-devel \
    && dnf clean all

# Prebuild QA tooling once so the shipped ISO can run `make ci`
# without a manual cargo bootstrap on the host.
RUN cargo install --locked cargo-audit --root /opt/lifeos-devtools

WORKDIR /build

# Copy workspace manifests first for better build cache behavior.
COPY Cargo.toml Cargo.lock ./
COPY cli/Cargo.toml cli/
COPY daemon/Cargo.toml daemon/
COPY tests/Cargo.toml tests/
COPY tests/integration tests/integration/

# Copy source trees.
COPY cli/src cli/src/
COPY cli/assets cli/assets/
COPY daemon/src daemon/src/
COPY daemon/defaults daemon/defaults/
COPY daemon/static daemon/static/

# Copy contracts for model catalog (needed by CLI include_str!)
COPY contracts/ contracts/

# Build binaries with deterministic dependency resolution, then keep only artifacts.
RUN set -eux && \
    cargo build --release --locked -p life && \
    cargo build --release --locked -p lifeosd \
        --features "dbus,http-api,ui-overlay,wake-word,speaker-id,messaging,tray" && \
    install -D -m 0755 /build/target/release/life /out/life && \
    install -D -m 0755 /build/target/release/lifeosd /out/lifeosd && \
    install -D -m 0755 /build/target/release/lifeos-train-wakeword /out/lifeos-train-wakeword && \
    rm -rf /build/target /root/.cargo/registry /root/.cargo/git

# ============================================================================
# Stage 2: Build llama-server (GPU-capable via Vulkan)
# ============================================================================
FROM fedora:${FEDORA_MAJOR} AS llama-builder

RUN dnf install -y cmake make gcc-c++ git openssl-devel vulkan-loader-devel vulkan-headers glslc glslang && \
    dnf clean all

# Pin llama.cpp to a stable tag. Upstream master sometimes ships broken Vulkan
# shaders that fail to build. Update periodically after verifying tag builds.
ARG LLAMA_CPP_TAG=b8701
RUN set -eux && \
    echo ">>> Building llama-server from source (Vulkan-enabled, pinned ${LLAMA_CPP_TAG})..." && \
    git clone https://github.com/ggml-org/llama.cpp /tmp/llama.cpp && \
    cd /tmp/llama.cpp && \
    git checkout "${LLAMA_CPP_TAG}" && \
    cd - && \
    cmake -S /tmp/llama.cpp -B /tmp/llama.cpp/build \
        -DCMAKE_BUILD_TYPE=Release \
        -DBUILD_SHARED_LIBS=OFF \
        -DGGML_STATIC=ON \
        -DGGML_NATIVE=OFF \
        -DGGML_VULKAN=ON \
        -DLLAMA_BUILD_TESTS=OFF \
        -DLLAMA_BUILD_EXAMPLES=OFF \
        -DLLAMA_BUILD_SERVER=ON && \
    cmake --build /tmp/llama.cpp/build -j2 --target llama-server && \
    BUILD_BIN="$(find /tmp/llama.cpp/build -name 'llama-server' -type f | head -1)" && \
    echo ">>> Binary found at: ${BUILD_BIN}" && \
    mkdir -p /out && \
    install -m 0755 "${BUILD_BIN}" /out/llama-server && \
    /out/llama-server --version && \
    rm -rf /tmp/llama.cpp

# ============================================================================
# Stage 3: Build whisper.cpp STT tools + ship default STT models
# ============================================================================
FROM fedora:${FEDORA_MAJOR} AS whisper-builder

RUN dnf install -y cmake make gcc-c++ git openssl-devel curl SDL2-devel && \
    dnf clean all

RUN set -eux && \
    echo ">>> Building whisper.cpp STT tools from source..." && \
    git clone --depth=1 https://github.com/ggml-org/whisper.cpp /tmp/whisper.cpp && \
    cmake -S /tmp/whisper.cpp -B /tmp/whisper.cpp/build \
        -DCMAKE_BUILD_TYPE=Release \
        -DBUILD_SHARED_LIBS=OFF \
        -DWHISPER_BUILD_TESTS=OFF \
        -DWHISPER_SDL2=ON \
        -DWHISPER_BUILD_EXAMPLES=ON && \
    cmake --build /tmp/whisper.cpp/build -j"$(nproc)" --target whisper-cli whisper-stream && \
    CLI_BIN="$(find /tmp/whisper.cpp/build -name 'whisper-cli' -type f | head -1)" && \
    STREAM_BIN="$(find /tmp/whisper.cpp/build -name 'whisper-stream' -type f | head -1)" && \
    echo ">>> whisper-cli found at: ${CLI_BIN}" && \
    echo ">>> whisper-stream found at: ${STREAM_BIN}" && \
    mkdir -p /out/models/whisper && \
    install -m 0755 "${CLI_BIN}" /out/whisper-cli && \
    install -m 0755 "${STREAM_BIN}" /out/whisper-stream && \
    curl -fSL --retry 3 --connect-timeout 60 \
      -o /out/models/whisper/ggml-base.bin \
      https://huggingface.co/ggerganov/whisper.cpp/resolve/main/ggml-base.bin && \
    curl -fSL --retry 3 --connect-timeout 60 \
      -o /out/models/whisper/ggml-tiny.bin \
      https://huggingface.co/ggerganov/whisper.cpp/resolve/main/ggml-tiny.bin && \
    test -s /out/models/whisper/ggml-base.bin && \
    test -s /out/models/whisper/ggml-tiny.bin && \
    rm -rf /tmp/whisper.cpp

# ============================================================================
# Stage 4b: Download WeSpeaker ONNX model for speaker identification
# ============================================================================
FROM fedora:${FEDORA_MAJOR} AS wespeaker-builder

RUN dnf install -y curl && dnf clean all

RUN set -eux && \
    mkdir -p /out/models/wespeaker && \
    curl -fSL --retry 3 --connect-timeout 120 \
      -o /out/models/wespeaker/voxceleb_resnet34_LM.onnx \
      "https://huggingface.co/Wespeaker/wespeaker-voxceleb-resnet34-LM/resolve/main/voxceleb_resnet34_LM.onnx?download=true" && \
    test -s /out/models/wespeaker/voxceleb_resnet34_LM.onnx && \
    echo ">>> WeSpeaker ONNX model downloaded ($(du -sh /out/models/wespeaker/voxceleb_resnet34_LM.onnx | cut -f1))"

# ============================================================================
# Stage 5: Build Kokoro TTS Python environment (CPU-only)
# ============================================================================
# Uses python:3.12-slim as base (Debian) for a smaller pip-install surface.
# The resulting /opt/lifeos/kokoro-env venv is copied into the final image.
# Torch wheel is sourced from vendored build-assets/wheels/ so this stage
# never requires network access to download.pytorch.org at build time.
# Approximate size: ~850 MB (torch ~750 MB + kokoro + deps ~100 MB).
FROM python:3.12-slim AS kokoro-builder

# Install system deps needed for pip build steps + ffmpeg (for OGG encoding)
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    libsndfile1 \
    && rm -rf /var/lib/apt/lists/*

# Create venv
RUN python3 -m venv /opt/lifeos/kokoro-env

# Copy vendored wheel directory (torch ~180 MB, pre-downloaded for offline builds)
# If the wheel is absent, pip falls back to https://download.pytorch.org/whl/cpu
# during the build — CI should always have the vendored wheel.
COPY build-assets/wheels/ /build-assets/wheels/

# Install Python dependencies with pip cache mount for layer efficiency
# torch: CPU-only variant from vendored wheel or PyTorch whl index
# kokoro: kokoro-82m (TTS model + inference engine)
# aiohttp: async HTTP server
# soundfile: optional fast OGG encoding (libsndfile Vorbis if available)
# numpy: audio array processing
RUN --mount=type=cache,target=/root/.cache/pip \
    /opt/lifeos/kokoro-env/bin/pip install --upgrade pip && \
    /opt/lifeos/kokoro-env/bin/pip install \
        --find-links /build-assets/wheels/ \
        "torch==2.4.1+cpu" \
        --index-url https://download.pytorch.org/whl/cpu && \
    /opt/lifeos/kokoro-env/bin/pip install \
        --find-links /build-assets/wheels/ \
        kokoro \
        aiohttp \
        soundfile \
        numpy

# Pre-warm the default voice (if_sara) to materialise .pt weights files
# and verify kokoro can synthesise without network access.
# NOTE: Python code lives in a separate file to avoid Dockerfile parser
# confusion — a `from X import Y` line inside an inline RUN heredoc gets
# misparsed as a `FROM` stage directive by buildkit.
COPY image/scripts/prewarm-kokoro.py /build/prewarm-kokoro.py
ENV HF_HOME=/opt/lifeos/kokoro-env/hf-cache
RUN HF_HUB_OFFLINE=0 \
    /opt/lifeos/kokoro-env/bin/python3 /build/prewarm-kokoro.py

# Verify if_sara voice artifact exists after pre-warm (weights land in HF_HOME)
RUN find /opt/lifeos/kokoro-env -name 'if_sara*' | grep -q '.' || \
    (echo 'ERROR: if_sara voice artifact not found after pre-warm' && exit 1)

# Copy the manifest builder script and generate voices-manifest.json
COPY image/scripts/build-kokoro-manifest.py /build/build-kokoro-manifest.py
RUN LIFEOS_TTS_DEFAULT_VOICE=if_sara \
    /opt/lifeos/kokoro-env/bin/python3 /build/build-kokoro-manifest.py \
        --venv-dir /opt/lifeos/kokoro-env \
        --output /opt/lifeos/kokoro-env/voices-manifest.json && \
    test -s /opt/lifeos/kokoro-env/voices-manifest.json && \
    echo "voices-manifest.json generated ($(wc -l < /opt/lifeos/kokoro-env/voices-manifest.json) lines)"

# Strip build artifacts to reduce image size
RUN find /opt/lifeos/kokoro-env -type d -name '__pycache__' -exec rm -rf {} + 2>/dev/null || true && \
    find /opt/lifeos/kokoro-env -name '*.pyc' -delete 2>/dev/null || true && \
    find /opt/lifeos/kokoro-env -path '*/tests/*.py' -not -name '__init__.py' -delete 2>/dev/null || true

# ============================================================================
# Stage 6a-simplex: Extract SimpleX CLI binary from Ubuntu .deb
# ============================================================================
# We use bsdtar (libarchive) which natively handles .deb (ar) and .tar.zst
# without needing dpkg or extra packages.
FROM fedora:${FEDORA_MAJOR} AS simplex-extract
ARG SIMPLEX_CLI_VERSION=v6.4.11
RUN set -eux && \
    dnf -y install bsdtar curl && \
    curl -fSL -o /tmp/simplex-chat.deb \
        "https://github.com/simplex-chat/simplex-chat/releases/download/${SIMPLEX_CLI_VERSION}/simplex-chat-ubuntu-22_04-x86_64.deb" && \
    mkdir -p /tmp/deb-extract && \
    cd /tmp/deb-extract && \
    bsdtar xf /tmp/simplex-chat.deb && \
    bsdtar xf data.tar.* && \
    mkdir -p /out && \
    install -m 0755 usr/bin/simplex-chat /out/simplex-chat && \
    ls -la /out/simplex-chat && \
    cd / && rm -rf /tmp/simplex-chat.deb /tmp/deb-extract && \
    dnf clean all

# ============================================================================
# Stage 6a: Pre-build NVIDIA kernel modules (isolated — pattern from UBlue)
# ============================================================================
# This stage compiles NVIDIA akmods against the exact kernel in fedora-bootc.
# Pre-built RPMs are COPYed into the final stage, keeping the main build fast
# and cacheable when only non-kernel layers change.
FROM quay.io/fedora/fedora-bootc:${FEDORA_MAJOR} AS nvidia-kmod-builder

RUN dnf -y install dnf5-plugins && \
    dnf -y install distribution-gpg-keys && \
    rpm --import \
      /usr/share/distribution-gpg-keys/rpmfusion/RPM-GPG-KEY-rpmfusion-free-fedora-2020 \
      /usr/share/distribution-gpg-keys/rpmfusion/RPM-GPG-KEY-rpmfusion-nonfree-fedora-2020 && \
    dnf -y --setopt=localpkg_gpgcheck=1 install \
      "https://mirrors.rpmfusion.org/free/fedora/rpmfusion-free-release-$(rpm -E %fedora).noarch.rpm" \
      "https://mirrors.rpmfusion.org/nonfree/fedora/rpmfusion-nonfree-release-$(rpm -E %fedora).noarch.rpm" && \
    dnf -y install \
        kernel-devel akmod-nvidia xorg-x11-drv-nvidia-cuda \
        xorg-x11-drv-nvidia-power nvidia-settings nvidia-modprobe \
        akmods gcc && \
    if dnf -q repoquery --available --qf '%{name}' akmod-wl 2>/dev/null | grep -Fxq akmod-wl; then \
        dnf -y install broadcom-wl akmod-wl; \
    fi && \
    for modules_dir in /usr/lib/modules/*; do \
        [ -d "${modules_dir}" ] || continue; \
        kernel_ver="$(basename "${modules_dir}")"; \
        if [ ! -d "/usr/src/kernels/${kernel_ver}" ]; then \
            echo "WARNING: kernel-devel missing for ${kernel_ver}; skipping"; \
            continue; \
        fi; \
        akmods --force --kernels "${kernel_ver}" || \
            echo "WARNING: akmods failed for ${kernel_ver}"; \
    done && \
    NVIDIA_FOUND=0; \
    for d in /usr/lib/modules/*/extra/nvidia/nvidia.ko; do \
        [ -f "$d" ] && NVIDIA_FOUND=1 && break; \
    done; \
    if [ "$NVIDIA_FOUND" -eq 0 ]; then \
        echo "WARNING: No nvidia.ko modules found after akmods build (expected in CI without GPU headers)"; \
    fi && \
    dnf clean all

# ============================================================================
# Stage 6: Sistema Final
# ============================================================================
FROM quay.io/fedora/fedora-bootc:${FEDORA_MAJOR}

ARG LIFEOS_PRELOAD_MODEL=false
ARG FEDORA_MAJOR=43

ARG LIFEOS_CHANNEL=edge
# Runtime booted version for bootc/channel manifests.
# Keep distinct from the formal workspace package semver in Cargo.toml.
ARG LIFEOS_VERSION=dev
ARG BUILD_DATE
ARG VCS_REF
ARG LIFEOS_NVIDIA_KMOD_SIGN_KEY_B64=""
ARG LIFEOS_NVIDIA_KMOD_CERT_DER_B64=""
ARG LIFEOS_IMAGE_VARIANT=nvidia

# Tune dnf for fast package downloads — see comment in builder stage
# (line ~59) for rationale. This stage pulls the entire LifeOS runtime
# closure (COSMIC + pipewire + nvidia userspace + ~1500 transitive deps)
# and was the single biggest contributor to 60-90min build times.
RUN printf '%s\n' \
        'max_parallel_downloads=20' \
        'minrate=5k' \
        'timeout=20' \
        'deltarpm=False' \
        >> /etc/dnf/dnf.conf

# --- Repositorios adicionales (COSMIC y RPMFusion) ---
RUN dnf -y install dnf5-plugins && \
    dnf -y copr enable ryanabx/cosmic-epoch && \
    dnf -y install distribution-gpg-keys && \
    rpm --import \
      /usr/share/distribution-gpg-keys/rpmfusion/RPM-GPG-KEY-rpmfusion-free-fedora-2020 \
      /usr/share/distribution-gpg-keys/rpmfusion/RPM-GPG-KEY-rpmfusion-nonfree-fedora-2020 && \
    dnf -y --setopt=localpkg_gpgcheck=1 install \
      "https://mirrors.rpmfusion.org/free/fedora/rpmfusion-free-release-$(rpm -E %fedora).noarch.rpm" \
      "https://mirrors.rpmfusion.org/nonfree/fedora/rpmfusion-nonfree-release-$(rpm -E %fedora).noarch.rpm" && \
    dnf clean all

# --- Escritorio COSMIC y Base ---
RUN dnf -y install --skip-unavailable \
    cosmic-desktop cosmic-files cosmic-term cosmic-edit cosmic-store \
    cosmic-screenshot cosmic-player cosmic-idle \
    cosmic-initial-setup \
    xdg-desktop-portal-cosmic xdg-desktop-portal-gtk xdg-desktop-portal-wlr \
    xdg-user-dirs \
    NetworkManager NetworkManager-wifi wpa_supplicant wireless-regdb iwd \
    bluez bluez-tools \
    pipewire wireplumber pipewire-alsa pipewire-pulseaudio pipewire-utils \
    alsa-utils alsa-sof-firmware alsa-ucm \
    v4l-utils libcamera \
    grim wl-clipboard gamemode \
    tesseract tesseract-langpack-eng tesseract-langpack-spa \
    espeak-ng \
    vulkan-loader \
    fwupd \
    && dnf clean all

# --- Soporte Nvidia Optimus (pre-built kmods from Stage 6a) ---
# Install NVIDIA userspace packages, then COPY the pre-compiled kernel
# modules from the nvidia-kmod-builder stage. This avoids compiling
# akmods in the final image and makes the build cacheable.
RUN dnf -y install --skip-unavailable \
        xorg-x11-drv-nvidia-cuda xorg-x11-drv-nvidia-power \
        nvidia-settings nvidia-modprobe && \
    if dnf -q repoquery --available --qf '%{name}' supergfxctl 2>/dev/null | grep -Fxq supergfxctl; then \
        dnf -y install supergfxctl; \
    else \
        echo "INFO: supergfxctl not available; continuing without hybrid-switch helper"; \
    fi && \
    if dnf -q repoquery --available --qf '%{name}' akmod-wl 2>/dev/null | grep -Fxq akmod-wl; then \
        dnf -y install broadcom-wl akmod-wl; \
    else \
        echo "INFO: broadcom-wl/akmod-wl not available; continuing without Broadcom proprietary module"; \
    fi && \
    dnf clean all

# Copy pre-built NVIDIA kernel modules and kernel-devel headers (for Secure Boot signing) from the builder stage.
COPY --from=nvidia-kmod-builder /usr/lib/modules/ /usr/lib/modules/
COPY --from=nvidia-kmod-builder /usr/src/kernels/ /usr/src/kernels/

# Regenerate module dependency maps for every kernel present.
RUN for modules_dir in /usr/lib/modules/*; do \
        [ -d "${modules_dir}/extra/nvidia" ] || continue; \
        kernel_ver="$(basename "${modules_dir}")"; \
        if ! depmod "${kernel_ver}"; then \
            echo "ERROR: depmod failed for kernel ${kernel_ver}"; \
            exit 1; \
        fi; \
    done

# Secure Boot signing of NVIDIA kernel modules (optional — needs build args).
RUN set -eux && \
    install -d /usr/share/lifeos/secureboot && \
    if [ -n "${LIFEOS_NVIDIA_KMOD_SIGN_KEY_B64:-}" ] && [ -n "${LIFEOS_NVIDIA_KMOD_CERT_DER_B64:-}" ]; then \
        KMOD_SIGN_KEY=/tmp/lifeos-nvidia-kmod-sign.key; \
        KMOD_SIGN_CERT=/tmp/lifeos-nvidia-kmod-sign.der; \
        echo "${LIFEOS_NVIDIA_KMOD_SIGN_KEY_B64}" | base64 -d > "${KMOD_SIGN_KEY}"; \
        echo "${LIFEOS_NVIDIA_KMOD_CERT_DER_B64}" | base64 -d > "${KMOD_SIGN_CERT}"; \
        chmod 0600 "${KMOD_SIGN_KEY}" "${KMOD_SIGN_CERT}"; \
        cp -f "${KMOD_SIGN_CERT}" /usr/share/lifeos/secureboot/lifeos-nvidia-kmod.der; \
        SIGNED_COUNT=0; \
        KERNELS_WITH_MISSING_SIGN_TOOL=0; \
        for modules_dir in /usr/lib/modules/*; do \
            [ -d "${modules_dir}/extra/nvidia" ] || continue; \
            kernel_ver="$(basename "${modules_dir}")"; \
            SIGN_TOOL="/usr/src/kernels/${kernel_ver}/scripts/sign-file"; \
            if [ ! -x "${SIGN_TOOL}" ]; then \
                echo "ERROR: sign-file not found for kernel ${kernel_ver}"; \
                KERNELS_WITH_MISSING_SIGN_TOOL=$((KERNELS_WITH_MISSING_SIGN_TOOL + 1)); \
                continue; \
            fi; \
            for mod in "${modules_dir}"/extra/nvidia/*.ko; do \
                [ -e "${mod}" ] || continue; \
                "${SIGN_TOOL}" sha256 "${KMOD_SIGN_KEY}" "${KMOD_SIGN_CERT}" "${mod}"; \
                SIGNED_COUNT=$((SIGNED_COUNT + 1)); \
            done; \
        done; \
        if [ "${KERNELS_WITH_MISSING_SIGN_TOOL}" -gt 0 ]; then \
            echo "ERROR: ${KERNELS_WITH_MISSING_SIGN_TOOL} kernels could not be signed"; \
            exit 1; \
        fi; \
        if [ "${SIGNED_COUNT}" -eq 0 ]; then \
            echo "ERROR: No NVIDIA kernel modules found to sign"; \
            exit 1; \
        fi; \
        for modules_dir in /usr/lib/modules/*; do \
            [ -d "${modules_dir}/extra/nvidia" ] || continue; \
            kernel_ver="$(basename "${modules_dir}")"; \
            if ! depmod "${kernel_ver}"; then \
                echo "ERROR: depmod failed for kernel ${kernel_ver} after signing"; \
                exit 1; \
            fi; \
        done; \
        echo "INFO: Signed ${SIGNED_COUNT} NVIDIA kernel modules for Secure Boot"; \
        rm -f "${KMOD_SIGN_KEY}" "${KMOD_SIGN_CERT}"; \
    else \
        echo "INFO: NVIDIA signing secrets not provided; Secure Boot may reject modules"; \
        rm -f /usr/share/lifeos/secureboot/lifeos-nvidia-kmod.der; \
    fi

# Final depmod pass — covers both signed and unsigned paths.
RUN for modules_dir in /usr/lib/modules/*; do \
        [ -d "${modules_dir}/extra/nvidia" ] || continue; \
        depmod "$(basename "${modules_dir}")"; \
    done

# Clean up kernel-devel headers (only needed for signing, not runtime)
RUN rm -rf /usr/src/kernels/

# --- Gaming support (controller udev rules only) ---
# Steam and ProtonUp-Qt are available via Flatpak from COSMIC Store.
# We keep steam-devices for controller/joystick udev rules (tiny, no deps).
RUN dnf -y install steam-devices && dnf clean all

# --- Flatpak: configure Flathub so COSMIC Store shows apps ---
# Use /etc/flatpak/remotes.d/ (immutable, survives bootc updates) + runtime init
RUN mkdir -p /etc/flatpak/remotes.d && \
    printf '[Flatpak Remote]\nName=flathub\nUrl=https://dl.flathub.org/repo/\nGPGKey=https://dl.flathub.org/repo/flathub.gpg\nEnabled=true\n' \
        > /etc/flatpak/remotes.d/flathub.flatpakrepo && \
    flatpak remote-add --if-not-exists --system flathub https://flathub.org/repo/flathub.flatpakrepo || true && \
    flatpak remote-add --if-not-exists --system cosmic https://flatpak.pop-os.org/repo/ || true

# --- Default COSMIC applets (panel essentials) ---
# Ensure remotes are available in this layer, then install applets.
RUN flatpak remote-add --if-not-exists --system flathub \
        https://flathub.org/repo/flathub.flatpakrepo 2>/dev/null || true && \
    flatpak remote-add --if-not-exists --system cosmic \
        https://flatpak.pop-os.org/repo/ 2>/dev/null || true && \
    flatpak install --system -y --noninteractive cosmic \
        io.github.cosmic_utils.cosmic-ext-applet-clipboard-manager \
        io.github.cosmic_utils.minimon-applet \
        com.vintagetechie.CosmicExtAppletTempest 2>/dev/null || \
    echo "INFO: COSMIC applets not available during build; user can install from COSMIC Store"

# --- Pre-create /usr/local/sbin (rpm-ostree tmpfiles tries to create it at boot,
#     but /usr is read-only at runtime → cosmetic boot warning). Baking it into
#     the image silences systemd-tmpfiles. See docs/operations/system-admin.md. ---
RUN mkdir -p /usr/local/sbin && chmod 0755 /usr/local/sbin

