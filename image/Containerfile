# image/Containerfile
# LifeOS: construido directamente sobre Fedora bootc
# Incorpora COSMIC Desktop, Nvidia Optimus y llama-server (AI local)
# Gaming (Steam/Proton) disponible via Flatpak desde COSMIC Store
#
# Build context must be the repo root:
#   podman build -t lifeos:latest -f image/Containerfile .
#
# Channel builds:
#   podman build --build-arg LIFEOS_CHANNEL=stable -t lifeos:stable -f image/Containerfile .
#   podman build --build-arg LIFEOS_CHANNEL=candidate -t lifeos:candidate -f image/Containerfile .
#   podman build --build-arg LIFEOS_CHANNEL=edge -t lifeos:edge -f image/Containerfile .

# Build against the latest supported Fedora major release.
ARG FEDORA_MAJOR=44

# Pre-compiled NVIDIA RPM image — must match FEDORA_MAJOR's kernel ABI.
# Declared at global scope so the `FROM ...:${NVIDIA_DRIVERS_TAG}` in the
# nvidia-rpms stage can reference it (Dockerfile rule: ARGs used in FROM
# must be declared before any FROM, not inside a previous stage). Built
# and published by lifeos-nvidia-drivers CI per Fedora major.
ARG NVIDIA_DRIVERS_TAG=latest-f44-x86_64

# ============================================================================
# Stage 1: Build CLI + Daemon (Rust)
# ============================================================================
FROM fedora:${FEDORA_MAJOR} AS builder

ARG LIFEOS_CHANNEL=edge
# Runtime booted version for bootc/channel manifests.
# Keep distinct from the formal workspace package semver in Cargo.toml.
ARG LIFEOS_VERSION=dev
ARG BUILD_DATE
ARG VCS_REF
ARG LIFEOS_NVIDIA_KMOD_SIGN_KEY_B64=""
ARG LIFEOS_NVIDIA_KMOD_CERT_DER_B64=""
ARG LIFEOS_PRELOAD_MODEL=false

# Image variant selector for the AMD/NVIDIA split (item #12 in
# docs/operations/pending-items-roadmap.md). Values:
#   "nvidia" (default) — full image with proprietary NVIDIA drivers,
#                        akmods, CUDA, Secure Boot signing, and
#                        nvidia-persistenced enabled. Backwards
#                        compatible with the pre-split build.
#   "amd"             — lean image for AMD / Intel / ARM hosts.
#                       Skips the nvidia-rpms stage inputs,
#                       skips nvidia-persistenced enablement, and
#                       does not install the NVIDIA userspace packages.
#                       (Full skip wiring is tracked as follow-up; this
#                       arg is the anchor point for the refactor.)
ARG LIFEOS_IMAGE_VARIANT=nvidia


# Tune dnf for fast package downloads. Default dnf5 ships with
# max_parallel_downloads=3 which bottlenecks heavily on the Fedora
# mirror network — builder stage pulls ~500 transitive packages and
# on Hector's connection individual mirrors were delivering 9 KiB/s,
# stretching STEP 11 past 90 minutes. Raising the parallel ceiling
# to 20 and enabling fastestmirror cut download time by ~3-5x.
# minrate=1k gives dnf permission to drop a stalled mirror after a
# sane threshold instead of hanging indefinitely on a dead CDN.
RUN printf '%s\n' \
        'max_parallel_downloads=20' \
        'minrate=5k' \
        'timeout=20' \
        'deltarpm=False' \
        >> /etc/dnf/dnf.conf

RUN dnf -y install \
    rust cargo \
    openssl-devel \
    pkgconf-pkg-config \
    gcc \
    git \
    dbus-devel \
    glib2-devel \
    gtk4-devel \
    libadwaita-devel \
    pango-devel \
    gdk-pixbuf2-devel \
    graphene-devel \
    cairo-devel \
    wayland-devel \
    libxkbcommon-devel \
    && dnf clean all

# Prebuild QA tooling once so the shipped ISO can run `make ci`
# without a manual cargo bootstrap on the host.
RUN cargo install --locked cargo-audit --root /opt/lifeos-devtools

WORKDIR /build

# Copy workspace manifests first for better build cache behavior.
COPY Cargo.toml Cargo.lock ./
COPY cli/Cargo.toml cli/
COPY daemon/Cargo.toml daemon/
COPY tests/Cargo.toml tests/
COPY tests/integration tests/integration/

# Copy source trees.
COPY cli/src cli/src/
COPY cli/assets cli/assets/
COPY daemon/src daemon/src/
COPY daemon/defaults daemon/defaults/
COPY daemon/static daemon/static/

# Copy contracts for model catalog (needed by CLI include_str!)
COPY contracts/ contracts/

# Build binaries with deterministic dependency resolution, then keep only artifacts.
# Phase 3: lifeosd is no longer built here. The daemon ships from
# ghcr.io/hectormr206/lifeos-lifeosd:stable, built by .github/workflows/side-images.yml
# from containers/lifeos-lifeosd/Containerfile. Dropping the daemon build out
# of bootc cuts ~10 minutes of CI per host image and removes ~150 MB of
# linker-time artifacts from the layer cache.
RUN set -eux && \
    cargo build --release --locked -p life && \
    install -D -m 0755 /build/target/release/life /out/life && \
    rm -rf /build/target /root/.cargo/registry /root/.cargo/git
# Note: lifeos-train-wakeword binary build removed from bootc — wake-word
# personalization is a niche one-off training step (see comment in Stage
# 4-runtime where the binary used to be COPY'd). Removing the build here
# also drops the `wake-word` feature compile from the bootc CI path.

# Stage 2 (llama.cpp build) is REMOVED in Phase 4 of the architecture pivot —
# llama-server now runs inside ghcr.io/hectormr206/lifeos-llama-server:stable
# via /usr/share/containers/systemd/lifeos-llama-server.container. The bootc
# image no longer carries the ~200 MB Vulkan-built binary or the cmake/glslang
# build chain. See containers/lifeos-llama-server/Containerfile for the new
# build site.
# ============================================================================
# Stage 3: whisper.cpp STT tools — REMOVED (Phase 7 of architecture pivot)
# ============================================================================
# whisper-cli now ships INSIDE the lifeos-lifeosd container (the only
# consumer post-Phase-3). See containers/lifeos-lifeosd/Containerfile —
# stage `whisper-builder`. Saves ~10 MB host image and the SDL2/cmake
# build chain that this stage previously required.
# whisper-stream (live PipeWire capture) is deferred to the lifeosd-desktop
# companion (Phase 3b) and not built in any image today.
# Phase 6b: STT model files (ggml-base.bin, ggml-tiny.bin) are downloaded
# at first-boot by lifeos-stt-setup.sh into /var/lib/lifeos/models/whisper
# which is bind-mounted into lifeos-lifeosd.

# ============================================================================
# Stage 4b: WeSpeaker ONNX — REMOVED (moved to lifeos-lifeosd container)
# ============================================================================
# The 24 MB ResNet34 ONNX model + the Python helper script + the
# onnxruntime pip package all live INSIDE ghcr.io/hectormr206/lifeos-lifeosd
# now. See containers/lifeos-lifeosd/Containerfile stages `wespeaker-fetch`
# and the runtime stage's pip install. Saves ~120 MB of host bytes
# (24 MB model + ~80 MB onnxruntime + python3-numpy + python3-pip).

# Stage 5 (Kokoro TTS Python venv) is REMOVED in Phase 6 of the
# architecture pivot — the Kokoro venv, voice models, manifest, and
# server script all moved INTO the lifeos-tts:stable side image.
# bootc no longer carries the ~850 MB Python/torch/kokoro stack.
# See containers/lifeos-tts/Containerfile for the new build site.
# ============================================================================
# Stage 6a-simplex: Extract SimpleX CLI binary from Ubuntu .deb
# ============================================================================
# We use bsdtar (libarchive) which natively handles .deb (ar) and .tar.zst
# without needing dpkg or extra packages.
# simplex-chat host binary stage REMOVED — Phase 5 replaced the host
# CLI with the lifeos-simplex-bridge Quadlet container which downloads
# its own simplex-chat from the upstream Ubuntu .deb. Nothing on the
# bootc host needs the binary any more.

# ============================================================================
# Stage 6a: NVIDIA driver RPMs from lifeos-nvidia-drivers upstream
# ============================================================================
# Pre-built NVIDIA proprietary driver RPMs (Production Branch — currently
# 595.58.03, Blackwell-ready), packaged by hectormr206/lifeos-nvidia-drivers
# via GitHub Actions mock builds. Replaces the previous RPMFusion akmod-nvidia
# compile stage which lagged 1-2 NVIDIA branches behind upstream.
#
# Includes: nvidia-driver, nvidia-kmod (pre-compiled .ko for Fedora's shipping
# kernel), nvidia-kmod-common, nvidia-modprobe, nvidia-settings,
# nvidia-persistenced, nvidia-driver-selinux, nvidia-container-toolkit,
# libnvidia-container.
# BLOCKER on Fedora bumps: lifeos-nvidia-drivers must publish a matching
# `f${FEDORA_MAJOR}` tag BEFORE this Containerfile bumps — the pre-compiled
# kmod-nvidia is linked against the kernel ABI of its build distro and
# crossing majors fails modprobe at first boot. NVIDIA_DRIVERS_TAG is
# declared at global scope at the top of the file (Dockerfile requires
# ARGs used in FROM to be declared before any FROM line, not inside a
# prior stage).
FROM ghcr.io/hectormr206/lifeos-nvidia-drivers:${NVIDIA_DRIVERS_TAG} AS nvidia-rpms

# ============================================================================
# Stage 6: Sistema Final
# ============================================================================
FROM quay.io/fedora/fedora-bootc:${FEDORA_MAJOR}

ARG LIFEOS_PRELOAD_MODEL=false
ARG FEDORA_MAJOR=44

ARG LIFEOS_CHANNEL=edge
# Runtime booted version for bootc/channel manifests.
# Keep distinct from the formal workspace package semver in Cargo.toml.
ARG LIFEOS_VERSION=dev
ARG BUILD_DATE
ARG VCS_REF
ARG LIFEOS_NVIDIA_KMOD_SIGN_KEY_B64=""
ARG LIFEOS_NVIDIA_KMOD_CERT_DER_B64=""
ARG LIFEOS_IMAGE_VARIANT=nvidia

# Tune dnf for fast package downloads — see comment in builder stage
# (line ~59) for rationale. This stage pulls the entire LifeOS runtime
# closure (COSMIC + pipewire + nvidia userspace + ~1500 transitive deps)
# and was the single biggest contributor to 60-90min build times.
RUN printf '%s\n' \
        'max_parallel_downloads=20' \
        'minrate=5k' \
        'timeout=20' \
        'deltarpm=False' \
        >> /etc/dnf/dnf.conf

# --- Repositorios adicionales (COSMIC y RPMFusion) ---
RUN dnf -y install dnf5-plugins && \
    dnf -y copr enable ryanabx/cosmic-epoch && \
    dnf -y install distribution-gpg-keys && \
    rpm --import \
      /usr/share/distribution-gpg-keys/rpmfusion/RPM-GPG-KEY-rpmfusion-free-fedora-2020 \
      /usr/share/distribution-gpg-keys/rpmfusion/RPM-GPG-KEY-rpmfusion-nonfree-fedora-2020 && \
    dnf -y --setopt=localpkg_gpgcheck=1 install \
      "https://mirrors.rpmfusion.org/free/fedora/rpmfusion-free-release-$(rpm -E %fedora).noarch.rpm" \
      "https://mirrors.rpmfusion.org/nonfree/fedora/rpmfusion-nonfree-release-$(rpm -E %fedora).noarch.rpm" && \
    # The rpmfusion release RPM ships rawhide + updates-testing repo files
    # in /etc/yum.repos.d/. On Fedora 44 the rawhide repo points at
    # ffmpeg-libs-8.0.1-9.fc45 which needs glibc 2.44 (not on fc44),
    # breaking the ffmpeg install later. Force-disable both rawhide and
    # updates-testing for free + nonfree by rewriting `enabled=1` to
    # `enabled=0` directly. The dnf5 `config-manager setopt` errors out
    # when the repoid is missing, which made the previous attempt
    # non-portable across rpmfusion package versions; sed on the actual
    # .repo files is robust to that.
    # Use find so the loop self-adapts if rpmfusion renames or adds repo
    # files in future package versions. Empirically on rpmfusion-44:
    # only `rpmfusion-free-rawhide.repo` ships with `enabled=1`; the
    # updates-testing repos already ship `enabled=0`, and there is no
    # `rpmfusion-nonfree-rawhide.repo` at all. The find pattern catches
    # any matching file regardless of which entries the future package
    # actually ships.
    find /etc/yum.repos.d -maxdepth 1 -type f \
        \( -name 'rpmfusion-*-rawhide*.repo' -o -name 'rpmfusion-*-updates-testing*.repo' \) \
        -exec sed -i 's/^enabled *= *1/enabled=0/' {} + && \
    dnf clean all

# --- Escritorio COSMIC y Base ---
RUN dnf -y install --skip-unavailable \
    cosmic-desktop cosmic-files cosmic-term cosmic-edit cosmic-store \
    cosmic-screenshot cosmic-player cosmic-idle \
    cosmic-initial-setup \
    xdg-desktop-portal-cosmic xdg-desktop-portal-gtk xdg-desktop-portal-wlr \
    xdg-user-dirs \
    NetworkManager NetworkManager-wifi wpa_supplicant wireless-regdb iwd \
    bluez bluez-tools \
    pipewire wireplumber pipewire-alsa pipewire-pulseaudio pipewire-utils \
    alsa-utils alsa-sof-firmware alsa-ucm \
    v4l-utils libcamera \
    grim wl-clipboard gamemode \
    tesseract tesseract-langpack-eng tesseract-langpack-spa \
    espeak-ng \
    vulkan-loader \
    fwupd \
    && dnf clean all

# --- NVIDIA driver (userspace + pre-built kmods) from nvidia-rpms ---
# All NVIDIA packages come from the lifeos-nvidia-drivers upstream image —
# a Bazzite-pattern fork pinned to the NVIDIA Production Branch. The kernel
# modules are pre-compiled against Fedora's shipping kernel inside the
# nvidia-rpms build pipeline.
#
# supergfxctl (Optimus hybrid-switch helper) still comes from RPMFusion.
# akmod-wl / broadcom-wl (Broadcom proprietary WiFi) still comes from RPMFusion.
# kernel-devel is installed temporarily for module signing below, then removed.
# Stage `nvidia-rpms` is built `FROM scratch` upstream and contains only RPM
# blobs at `/` — no shell, no `/mnt`, no filesystem layout. `RUN --mount=type=bind`
# fails against scratch stages in rootless buildah ("openat2 mnt: No such file
# or directory"), so we COPY the RPMs into a temp dir, install, then remove.
COPY --from=nvidia-rpms / /tmp/nvidia-rpms/
# Skip nvidia-container-toolkit + libnvidia-container from this RPM pile —
# we install fresher upstream versions from nvidia.github.io later in the
# build (Phase 4 GPU passthrough for Quadlets). Install everything else
# (driver, kmod, modprobe, settings).
RUN find /tmp/nvidia-rpms -maxdepth 1 -name '*.rpm' \
        ! -name 'nvidia-container-toolkit*' \
        ! -name 'libnvidia-container*' \
        -print0 | xargs -0 dnf -y install && \
    rm -rf /tmp/nvidia-rpms && \
    dnf -y install kernel-devel akmods gcc gcc-c++ kmodtool elfutils-libelf-devel && \
    if dnf -q repoquery --available --qf '%{name}' supergfxctl 2>/dev/null | grep -Fxq supergfxctl; then \
        dnf -y install supergfxctl; \
    else \
        echo "INFO: supergfxctl not available; continuing without hybrid-switch helper"; \
    fi && \
    if dnf -q repoquery --available --qf '%{name}' akmod-wl 2>/dev/null | grep -Fxq akmod-wl; then \
        dnf -y install broadcom-wl akmod-wl; \
    else \
        echo "INFO: broadcom-wl/akmod-wl not available; continuing without Broadcom proprietary module"; \
    fi && \
    dnf clean all

# Compile NVIDIA kernel modules against the kernel(s) shipped in this image.
# The lifeos-nvidia-drivers upstream installs akmod source (akmod-nvidia /
# kmod-nvidia source RPMs), not pre-built `.ko` files. akmods turns the source
# into kmod-nvidia-<kernel>.rpm and lays the modules under
# /usr/lib/modules/<kernel>/extra/nvidia/ where the signing step finds them.
# This mirrors what produced the verified working stack on the dev laptop
# (NVRM 595.58.03, akmods@buildkitsandbox signature).
RUN NVIDIA_BUILT=0; \
    for modules_dir in /usr/lib/modules/*; do \
        [ -d "${modules_dir}" ] || continue; \
        kernel_ver="$(basename "${modules_dir}")"; \
        if [ ! -d "/usr/src/kernels/${kernel_ver}" ]; then \
            echo "WARNING: kernel-devel missing for ${kernel_ver}; skipping"; \
            continue; \
        fi; \
        echo "=== building NVIDIA kmod for ${kernel_ver} ==="; \
        if ! akmods --force --kernels "${kernel_ver}" --akmod nvidia; then \
            echo "ERROR: akmods --akmod nvidia failed for ${kernel_ver}"; \
            find /var/cache/akmods -type f -name '*.log' -exec sh -c 'echo "=== $1 ==="; cat "$1"' _ {} \; 2>&1 | tail -100; \
            exit 1; \
        fi; \
        # akmods builds an RPM but does not install it. Find and install the
        # kmod-nvidia-<ver>-<kernel>.rpm it produced under /var/cache/akmods/.
        # The kernel_ver appears as a substring of the produced RPM filename
        # (akmods convention). The original glob used `head -1`; we now keep
        # the substring match and instead error if more than one matches —
        # that protects against future driver subpackages slipping in via
        # a non-deterministic find ordering.
        BUILT_RPMS="$(find /var/cache/akmods/nvidia -maxdepth 2 -type f \
            -name "kmod-nvidia-*${kernel_ver}*.rpm")"; \
        BUILT_COUNT="$(printf '%s\n' "${BUILT_RPMS}" | grep -c .)"; \
        if [ -z "${BUILT_RPMS}" ] || [ "${BUILT_COUNT}" -eq 0 ]; then \
            echo "ERROR: akmods reported success but produced no RPM for ${kernel_ver}"; \
            find /var/cache/akmods -type f 2>&1 | head -20; \
            exit 1; \
        fi; \
        if [ "${BUILT_COUNT}" -gt 1 ]; then \
            echo "ERROR: expected exactly one kmod-nvidia RPM for ${kernel_ver}, got ${BUILT_COUNT}:"; \
            printf '%s\n' "${BUILT_RPMS}"; \
            exit 1; \
        fi; \
        BUILT_RPM="${BUILT_RPMS}"; \
        echo "INFO: installing ${BUILT_RPM}"; \
        dnf -y install "${BUILT_RPM}"; \
        # Modules ship as .ko.xz from the RPM (Fedora default). Decompress in
        # place so the secure-boot signing step (which globs *.ko) can sign
        # them; sign-file does not handle xz wrappers. Errors are NOT swallowed
        # — if any .ko.xz exists, xz must succeed. If no .ko.xz files exist
        # (e.g. RPM already shipped uncompressed .ko), skip the decompress
        # step gracefully.
        if find "${modules_dir}/extra/nvidia" -type f -name '*.ko.xz' | grep -q .; then \
            find "${modules_dir}/extra/nvidia" -type f -name '*.ko.xz' \
                -exec xz --decompress --force {} \; ; \
        else \
            echo "INFO: no .ko.xz files under ${modules_dir}/extra/nvidia (already decompressed)"; \
        fi; \
        if [ -f "${modules_dir}/extra/nvidia/nvidia.ko" ]; then \
            NVIDIA_BUILT=$((NVIDIA_BUILT + 1)); \
            echo "INFO: nvidia.ko ready at ${modules_dir}/extra/nvidia/"; \
        else \
            echo "ERROR: nvidia.ko still missing after install + decompress"; \
            ls -la "${modules_dir}/extra/nvidia/" 2>&1 | head; \
            exit 1; \
        fi; \
    done && \
    if [ "${NVIDIA_BUILT}" -eq 0 ]; then \
        echo "ERROR: no nvidia.ko produced for any kernel in /usr/lib/modules/"; \
        exit 1; \
    fi && \
    echo "INFO: nvidia.ko ready for ${NVIDIA_BUILT} kernel(s)"

# Regenerate module dependency maps for every kernel present.
RUN for modules_dir in /usr/lib/modules/*; do \
        [ -d "${modules_dir}/extra/nvidia" ] || continue; \
        kernel_ver="$(basename "${modules_dir}")"; \
        if ! depmod "${kernel_ver}"; then \
            echo "ERROR: depmod failed for kernel ${kernel_ver}"; \
            exit 1; \
        fi; \
    done

# Secure Boot signing of NVIDIA kernel modules (optional — needs build args).
RUN set -eux && \
    install -d /usr/share/lifeos/secureboot && \
    if [ -n "${LIFEOS_NVIDIA_KMOD_SIGN_KEY_B64:-}" ] && [ -n "${LIFEOS_NVIDIA_KMOD_CERT_DER_B64:-}" ]; then \
        KMOD_SIGN_KEY=/tmp/lifeos-nvidia-kmod-sign.key; \
        KMOD_SIGN_CERT=/tmp/lifeos-nvidia-kmod-sign.der; \
        echo "${LIFEOS_NVIDIA_KMOD_SIGN_KEY_B64}" | base64 -d > "${KMOD_SIGN_KEY}"; \
        echo "${LIFEOS_NVIDIA_KMOD_CERT_DER_B64}" | base64 -d > "${KMOD_SIGN_CERT}"; \
        chmod 0600 "${KMOD_SIGN_KEY}" "${KMOD_SIGN_CERT}"; \
        cp -f "${KMOD_SIGN_CERT}" /usr/share/lifeos/secureboot/lifeos-nvidia-kmod.der; \
        SIGNED_COUNT=0; \
        KERNELS_WITH_MISSING_SIGN_TOOL=0; \
        for modules_dir in /usr/lib/modules/*; do \
            [ -d "${modules_dir}/extra/nvidia" ] || continue; \
            kernel_ver="$(basename "${modules_dir}")"; \
            SIGN_TOOL="/usr/src/kernels/${kernel_ver}/scripts/sign-file"; \
            if [ ! -x "${SIGN_TOOL}" ]; then \
                echo "ERROR: sign-file not found for kernel ${kernel_ver}"; \
                KERNELS_WITH_MISSING_SIGN_TOOL=$((KERNELS_WITH_MISSING_SIGN_TOOL + 1)); \
                continue; \
            fi; \
            for mod in "${modules_dir}"/extra/nvidia/*.ko; do \
                [ -e "${mod}" ] || continue; \
                "${SIGN_TOOL}" sha256 "${KMOD_SIGN_KEY}" "${KMOD_SIGN_CERT}" "${mod}"; \
                SIGNED_COUNT=$((SIGNED_COUNT + 1)); \
            done; \
        done; \
        if [ "${KERNELS_WITH_MISSING_SIGN_TOOL}" -gt 0 ]; then \
            echo "ERROR: ${KERNELS_WITH_MISSING_SIGN_TOOL} kernels could not be signed"; \
            exit 1; \
        fi; \
        if [ "${SIGNED_COUNT}" -eq 0 ]; then \
            echo "ERROR: No NVIDIA kernel modules found to sign"; \
            exit 1; \
        fi; \
        for modules_dir in /usr/lib/modules/*; do \
            [ -d "${modules_dir}/extra/nvidia" ] || continue; \
            kernel_ver="$(basename "${modules_dir}")"; \
            if ! depmod "${kernel_ver}"; then \
                echo "ERROR: depmod failed for kernel ${kernel_ver} after signing"; \
                exit 1; \
            fi; \
        done; \
        echo "INFO: Signed ${SIGNED_COUNT} NVIDIA kernel modules for Secure Boot"; \
        rm -f "${KMOD_SIGN_KEY}" "${KMOD_SIGN_CERT}"; \
    else \
        echo "INFO: NVIDIA signing secrets not provided; Secure Boot may reject modules"; \
        rm -f /usr/share/lifeos/secureboot/lifeos-nvidia-kmod.der; \
    fi

# Final depmod pass — covers both signed and unsigned paths.
RUN for modules_dir in /usr/lib/modules/*; do \
        [ -d "${modules_dir}/extra/nvidia" ] || continue; \
        depmod "$(basename "${modules_dir}")"; \
    done

# Clean up kernel-devel headers (only needed for signing, not runtime)
RUN rm -rf /usr/src/kernels/

# Remove the akmod compile toolchain — only needed during the kmod build
# step above. Mirrors the kernel-devel cleanup pattern: these packages are
# ephemeral build dependencies, not runtime requirements. Keeping them in
# the image bloats /usr and gives an attacker a working compiler if they
# pop the daemon. Failure is non-fatal because not every variant ships every
# package (e.g. CI mock builds may skip akmods).
RUN dnf -y remove akmods gcc gcc-c++ kmodtool elfutils-libelf-devel || true && \
    dnf clean all

# --- Gaming support (controller udev rules only) ---
# Steam and ProtonUp-Qt are available via Flatpak from COSMIC Store.
# We keep steam-devices for controller/joystick udev rules (tiny, no deps).
RUN dnf -y install steam-devices && dnf clean all

# --- Flatpak: configure Flathub so COSMIC Store shows apps ---
# Use /etc/flatpak/remotes.d/ (immutable, survives bootc updates) + runtime init
RUN mkdir -p /etc/flatpak/remotes.d && \
    printf '[Flatpak Remote]\nName=flathub\nUrl=https://dl.flathub.org/repo/\nGPGKey=https://dl.flathub.org/repo/flathub.gpg\nEnabled=true\n' \
        > /etc/flatpak/remotes.d/flathub.flatpakrepo && \
    flatpak remote-add --if-not-exists --system flathub https://flathub.org/repo/flathub.flatpakrepo || true && \
    flatpak remote-add --if-not-exists --system cosmic https://flatpak.pop-os.org/repo/ || true

# --- Default COSMIC applets (panel essentials) ---
# Ensure remotes are available in this layer, then install applets.
RUN flatpak remote-add --if-not-exists --system flathub \
        https://flathub.org/repo/flathub.flatpakrepo 2>/dev/null || true && \
    flatpak remote-add --if-not-exists --system cosmic \
        https://flatpak.pop-os.org/repo/ 2>/dev/null || true && \
    flatpak install --system -y --noninteractive cosmic \
        io.github.cosmic_utils.cosmic-ext-applet-clipboard-manager \
        io.github.cosmic_utils.minimon-applet \
        com.vintagetechie.CosmicExtAppletTempest 2>/dev/null || \
    echo "INFO: COSMIC applets not available during build; user can install from COSMIC Store"

# --- Pre-create /usr/local/sbin (rpm-ostree tmpfiles tries to create it at boot,
#     but /usr is read-only at runtime → cosmetic boot warning). Baking it into
#     the image silences systemd-tmpfiles. See docs/operations/system-admin.md. ---
RUN mkdir -p /usr/local/sbin && chmod 0755 /usr/local/sbin

# --- Flatpak: global Wayland-first overrides (avoid XWayland overhead) ---
COPY image/files/var/lib/flatpak/overrides/global /var/lib/flatpak/overrides/global

# --- Flatpak: Nvidia GL extension sync (matches host driver on every boot) ---
COPY image/files/usr/local/bin/lifeos-flatpak-nvidia-sync.sh /usr/local/bin/lifeos-flatpak-nvidia-sync.sh
RUN chmod +x /usr/local/bin/lifeos-flatpak-nvidia-sync.sh
COPY image/files/etc/systemd/system/lifeos-flatpak-nvidia-sync.service /usr/lib/systemd/system/lifeos-flatpak-nvidia-sync.service

