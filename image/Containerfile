# image/Containerfile
# LifeOS: construido directamente sobre Fedora bootc
# Incorpora COSMIC Desktop, Nvidia Optimus + Gaming (Steam/Proton) y llama-server (AI local)
#
# Build context must be the repo root:
#   podman build -t lifeos:latest -f image/Containerfile .

# ============================================================================
# Stage 1: Build CLI + Daemon (Rust)
# ============================================================================
FROM fedora:42 AS builder

RUN dnf -y install \
    rust cargo \
    openssl-devel \
    pkgconf-pkg-config \
    gcc \
    git \
    && dnf clean all

WORKDIR /build

# Copy CLI source
COPY cli/Cargo.toml cli/Cargo.lock* cli/
COPY cli/src cli/src/

# Copy Daemon source
COPY daemon/Cargo.toml daemon/
COPY daemon/src daemon/src/

# Build both sequentially (they don't share a workspace in the container)
RUN cd cli && cargo build --release
RUN cd daemon && cargo build --release

# ============================================================================
# Stage 2: Sistema Final
# ============================================================================
FROM quay.io/fedora/fedora-bootc:42

# --- Repositorios adicionales (COSMIC y RPMFusion) ---
RUN dnf -y install dnf5-plugins && \
    dnf -y copr enable ryanabx/cosmic-epoch && \
    dnf install -y \
        https://mirrors.rpmfusion.org/free/fedora/rpmfusion-free-release-$(rpm -E %fedora).noarch.rpm \
        https://mirrors.rpmfusion.org/nonfree/fedora/rpmfusion-nonfree-release-$(rpm -E %fedora).noarch.rpm

# --- Escritorio COSMIC y Base ---
RUN dnf -y install --skip-unavailable \
    cosmic-desktop cosmic-files cosmic-term cosmic-edit cosmic-store \
    xdg-desktop-portal-cosmic xdg-user-dirs \
    NetworkManager bluez pipewire wireplumber \
    && dnf clean all

# --- Soporte Nvidia Optimus y Gaming ---
RUN dnf -y install \
    kernel-devel \
    akmod-nvidia xorg-x11-drv-nvidia-cuda supergfxctl \
    && akmods --force || true \
    && dnf clean all

# --- Herramientas del Sistema ---
RUN dnf -y install \
    toolbox btrfs-progs smartmontools podman buildah flatpak \
    fish bat ripgrep fd-find htop fastfetch age jq sqlite \
    pciutils usbutils curl ca-certificates openssl-libs cryptsetup \
    glibc-langpack-es \
    && dnf clean all

# --- CLI Life y Daemon (binarios compilados) ---
COPY --from=builder /build/cli/target/release/life /usr/bin/life
COPY --from=builder /build/daemon/target/release/lifeosd /usr/bin/lifeosd
RUN chmod +x /usr/bin/life /usr/bin/lifeosd && life --version

# --- AI Runtime (llama.cpp / llama-server) ---
# llama-server provides OpenAI-compatible API for local AI inference.
# 1) Try to download pre-compiled binary from latest release.
# 2) Fall back to source compilation if binary unavailable.
RUN set -eux && \
    dnf install -y unzip jq cmake make gcc-c++ git openssl-devel && \
    RELEASE_URL="$( \
        curl -fsSL https://api.github.com/repos/ggerganov/llama.cpp/releases/latest | \
        jq -r '.assets[]? | select(.name | test("(?i)(linux|ubuntu).*x64.*\\.zip$")) | .browser_download_url' | \
        head -n 1 \
    )" && \
    if [ -n "${RELEASE_URL}" ] && [ "${RELEASE_URL}" != "null" ]; then \
        curl -fsSL -o /tmp/llama.zip "${RELEASE_URL}" && \
        unzip /tmp/llama.zip -d /tmp/llama || true; \
    fi && \
    LLAMA_BIN="$(find /tmp/llama -name llama-server -type f 2>/dev/null | head -n 1 || true)" && \
    if [ -n "${LLAMA_BIN}" ]; then \
        install -m 0755 "${LLAMA_BIN}" /usr/bin/llama-server; \
    fi && \
    if [ ! -x /usr/bin/llama-server ]; then \
        git clone --depth=1 https://github.com/ggerganov/llama.cpp /tmp/llama.cpp && \
        cmake -S /tmp/llama.cpp -B /tmp/llama.cpp/build \
            -DBUILD_SHARED_LIBS=OFF -DLLAMA_BUILD_TESTS=OFF -DLLAMA_BUILD_SERVER=ON && \
        cmake --build /tmp/llama.cpp/build -j"$(nproc)" --target llama-server && \
        install -m 0755 /tmp/llama.cpp/build/bin/llama-server /usr/bin/llama-server; \
    fi && \
    rm -rf /tmp/llama /tmp/llama.zip /tmp/llama.cpp && \
    dnf remove -y unzip cmake make gcc-c++ git openssl-devel && \
    dnf clean all

# --- Directorios LifeOS ---
RUN mkdir -p /var/lib/lifeos/models /var/log/lifeos /etc/lifeos

# --- Copiar archivos de configuración y scripts desde el repo ---
# Configuración de LifeOS
COPY image/files/etc/lifeos/lifeos.toml.default /etc/lifeos/lifeos.toml.default
COPY image/files/etc/lifeos/llama-server.env    /etc/lifeos/llama-server.env
COPY image/files/etc/lifeos/tuf/root.json       /etc/lifeos/tuf/root.json
COPY image/files/etc/lifeos/tuf/timestamp.json  /etc/lifeos/tuf/timestamp.json
COPY image/files/etc/lifeos/tuf/snapshot.json   /etc/lifeos/tuf/snapshot.json
COPY image/files/etc/lifeos/tuf/targets.json    /etc/lifeos/tuf/targets.json

# Scripts de LifeOS
COPY image/files/usr/local/bin/lifeos-first-boot.sh       /usr/local/bin/lifeos-first-boot.sh
COPY image/files/usr/local/bin/lifeos-ai-setup.sh          /usr/local/bin/lifeos-ai-setup.sh
COPY image/files/usr/local/bin/llama-server-health-check.sh /usr/local/bin/llama-server-health-check.sh
COPY image/files/usr/local/bin/lifeos-btrfs-snapshot.sh    /usr/local/bin/lifeos-btrfs-snapshot.sh
COPY image/files/usr/local/bin/lifeos-integrity-check.sh   /usr/local/bin/lifeos-integrity-check.sh
COPY image/files/usr/local/bin/lifeos-security-baseline-check.sh /usr/local/bin/lifeos-security-baseline-check.sh
RUN chmod +x /usr/local/bin/lifeos-first-boot.sh \
             /usr/local/bin/lifeos-ai-setup.sh \
             /usr/local/bin/llama-server-health-check.sh \
             /usr/local/bin/lifeos-btrfs-snapshot.sh \
             /usr/local/bin/lifeos-integrity-check.sh \
             /usr/local/bin/lifeos-security-baseline-check.sh

# Copiar configuración inicial si no existe
RUN cp -n /etc/lifeos/lifeos.toml.default /etc/lifeos/lifeos.toml || true

# --- Display Manager: COSMIC Greeter ---
RUN ln -sf /usr/lib/systemd/system/cosmic-greeter.service /etc/systemd/system/display-manager.service && \
    mkdir -p /etc/systemd/system/graphical.target.wants && \
    ln -sf /usr/lib/systemd/system/cosmic-greeter.service /etc/systemd/system/graphical.target.wants/cosmic-greeter.service

# --- Servicios systemd ---
# Copiar unit files desde el repo
COPY image/files/etc/systemd/system/lifeos-first-boot.service /usr/lib/systemd/system/lifeos-first-boot.service
COPY image/files/etc/systemd/system/llama-server.service       /usr/lib/systemd/system/llama-server.service
COPY image/files/etc/systemd/system/lifeos-btrfs-snapshot.service /usr/lib/systemd/system/lifeos-btrfs-snapshot.service
COPY image/files/etc/systemd/system/lifeos-btrfs-snapshot.timer   /usr/lib/systemd/system/lifeos-btrfs-snapshot.timer
COPY image/files/etc/systemd/system/lifeos-security-baseline.service /usr/lib/systemd/system/lifeos-security-baseline.service

# lifeosd.service (inline - es simple)
RUN printf '%s\n' \
    '[Unit]' \
    'Description=LifeOS System Daemon' \
    'After=network-online.target lifeos-security-baseline.service' \
    'Requires=lifeos-security-baseline.service' \
    'Wants=network-online.target' \
    '' \
    '[Service]' \
    'Type=simple' \
    'ExecStart=/usr/bin/lifeosd' \
    'Restart=on-failure' \
    'RestartSec=5' \
    '' \
    '[Install]' \
    'WantedBy=multi-user.target' \
    > /usr/lib/systemd/system/lifeosd.service

# Habilitar servicios via symlinks
RUN mkdir -p /usr/lib/systemd/system/multi-user.target.wants \
             /usr/lib/systemd/system/graphical.target.wants \
             /usr/lib/systemd/system/timers.target.wants && \
    ln -sf /usr/lib/systemd/system/lifeos-security-baseline.service /usr/lib/systemd/system/multi-user.target.wants/lifeos-security-baseline.service && \
    ln -sf /usr/lib/systemd/system/lifeosd.service       /usr/lib/systemd/system/multi-user.target.wants/lifeosd.service && \
    ln -sf /usr/lib/systemd/system/llama-server.service   /usr/lib/systemd/system/multi-user.target.wants/llama-server.service && \
    ln -sf /usr/lib/systemd/system/lifeos-btrfs-snapshot.timer /usr/lib/systemd/system/timers.target.wants/lifeos-btrfs-snapshot.timer && \
    ln -sf /usr/lib/systemd/system/lifeos-first-boot.service /usr/lib/systemd/system/graphical.target.wants/lifeos-first-boot.service && \
    ln -sf /usr/lib/systemd/system/bluetooth.service      /usr/lib/systemd/system/multi-user.target.wants/bluetooth.service && \
    ln -sf /usr/lib/systemd/system/NetworkManager.service /usr/lib/systemd/system/multi-user.target.wants/NetworkManager.service && \
    ln -sf /usr/lib/systemd/system/lifeosd.service        /usr/lib/systemd/system/lifeisd.service

# --- Branding y Personalización ---
RUN rm -f /usr/lib/os-release && \
    printf '%s\n' \
    'NAME="LifeOS"' \
    'VERSION="0.1 Aegis"' \
    'ID=lifeos' \
    'ID_LIKE=fedora' \
    'VERSION_ID="42"' \
    'PLATFORM_ID="platform:f42"' \
    'PRETTY_NAME="LifeOS 0.1 Aegis"' \
    'ANSI_COLOR="0;36"' \
    'LOGO="fedora-logo-icon"' \
    'CPE_NAME="cpe:/o:fedoraproject:fedora:42"' \
    'HOME_URL="https://lifeos.dev"' \
    'DOCUMENTATION_URL="https://lifeos.dev/docs"' \
    'SUPPORT_URL="https://lifeos.dev/support"' \
    'BUG_REPORT_URL="https://lifeos.dev/bugs"' \
    'REDHAT_BUGZILLA_PRODUCT="Fedora"' \
    'REDHAT_BUGZILLA_PRODUCT_VERSION="42"' \
    'REDHAT_SUPPORT_PRODUCT="Fedora"' \
    'REDHAT_SUPPORT_PRODUCT_VERSION="42"' \
    'SUPPORT_END="2026-05-18"' \
    > /usr/lib/os-release

# Placeholders de imagen oscuros para el instalador Anaconda
RUN mkdir -p /usr/share/anaconda/pixmaps/ && \
    dnf install -y ImageMagick && \
    magick -size 400x1200 xc:#1A1B26 /usr/share/anaconda/pixmaps/sidebar-logo.png && \
    magick -size 400x200 xc:#1A1B26 /usr/share/anaconda/pixmaps/sidebar-bg.png && \
    magick -size 1920x100 xc:#1A1B26 /usr/share/anaconda/pixmaps/topbar-bg.png && \
    dnf remove -y ImageMagick && \
    dnf clean all

# --- sysusers + tmpfiles ---
RUN mkdir -p /usr/lib/sysusers.d /usr/lib/tmpfiles.d && \
    printf '%s\n' \
    'g wsdd -' \
    'u wsdd - "WSDD Service User" /var/lib/wsdd -' \
    > /usr/lib/sysusers.d/wsdd.conf && \
    printf '%s\n' \
    'L /var/lib/greetd/.config/systemd/user/xdg-desktop-portal.service - - - - /dev/null' \
    'd /var/cache/PackageKit 0755 root root - -' \
    'd /var/cache/app-info 0755 root root - -' \
    'd /var/cache/app-info/icons 0755 root root - -' \
    'd /var/cache/app-info/xmls 0755 root root - -' \
    'd /var/cache/libX11 0755 root root - -' \
    'd /var/cache/libX11/compose 0755 root root - -' \
    'd /var/cache/libdnf5 0755 root root - -' \
    'd /var/cache/swcatalog 0755 root root - -' \
    'd /var/cache/swcatalog/cache 0755 root root - -' \
    'd /var/cache/swcatalog/gv 0755 root root - -' \
    'd /var/cache/swcatalog/icons 0755 root root - -' \
    'd /var/cache/swcatalog/xml 0755 root root - -' \
    'd /var/lib/AccountsService 0775 root root - -' \
    'd /var/lib/AccountsService/icons 0775 root root - -' \
    'd /var/lib/AccountsService/users 0700 root root - -' \
    'd /var/lib/PackageKit 0755 root root - -' \
    'd /var/lib/dnf 0755 root root - -' \
    'd /var/lib/dnf/repos 0755 root root - -' \
    'd /var/lib/dnf/repos/fedora-f8e7c8bda68a349e 0755 root root - -' \
    'd /var/lib/dnf/repos/updates-79babcf8637033ce 0755 root root - -' \
    'd /var/lib/flatpak 0755 root root - -' \
    'd /var/lib/fprint 0700 root root - -' \
    'd /var/lib/geoclue 0755 geoclue geoclue - -' \
    'd /var/lib/greetd/.config 0755 greetd greetd - -' \
    'd /var/lib/greetd/.config/systemd 0755 greetd greetd - -' \
    'd /var/lib/greetd/.config/systemd/user 0755 greetd greetd - -' \
    'd /var/lib/lifeos 0755 root root - -' \
    'd /var/lib/lifeos/models 0755 root root - -' \
    'd /var/lib/smartmontools 0755 root root - -' \
    'd /var/lib/tuned 0755 root root - -' \
    'd /var/log/lifeos 0755 root root - -' \
    'd /var/log/tuned 0755 root root - -' \
    > /usr/lib/tmpfiles.d/lifeos-var.conf && \
    rm -f /var/lib/dnf/repos/*/countme && \
    rm -f /var/log/dnf5.log* && \
    rm -f /var/cache/ldconfig/aux-cache && \
    rm -f /var/cache/swcatalog/cache/C-local-metainfo.xb /var/cache/swcatalog/cache/C-os-catalog.xb

# --- Verificación final ---
RUN test -x /usr/bin/life && \
    test -x /usr/bin/lifeosd && \
    test -x /usr/bin/llama-server && \
    test -f /usr/lib/systemd/system/lifeosd.service && \
    test -f /usr/lib/systemd/system/llama-server.service && \
    test -f /usr/lib/systemd/system/lifeos-btrfs-snapshot.service && \
    test -f /usr/lib/systemd/system/lifeos-btrfs-snapshot.timer && \
    test -f /usr/lib/systemd/system/lifeos-security-baseline.service && \
    test -f /usr/lib/systemd/system/lifeos-first-boot.service && \
    test -f /etc/lifeos/llama-server.env && \
    test -f /etc/lifeos/tuf/root.json && \
    test -f /etc/lifeos/tuf/timestamp.json && \
    test -f /etc/lifeos/tuf/snapshot.json && \
    test -f /etc/lifeos/tuf/targets.json && \
    test -f /etc/lifeos/lifeos.toml.default && \
    test -x /usr/local/bin/lifeos-first-boot.sh && \
    test -x /usr/local/bin/lifeos-ai-setup.sh && \
    test -x /usr/local/bin/llama-server-health-check.sh && \
    test -x /usr/local/bin/lifeos-btrfs-snapshot.sh && \
    test -x /usr/local/bin/lifeos-integrity-check.sh && \
    test -x /usr/local/bin/lifeos-security-baseline-check.sh

RUN dnf clean all && rm -f /var/log/dnf5.log* && bootc container lint
