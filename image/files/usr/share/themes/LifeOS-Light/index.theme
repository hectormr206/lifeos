[Desktop Entry]
Type=X-GNOME-Metatheme
Name=LifeOS Light
Comment=LifeOS Light Theme - Clean and bright for daytime use
Encoding=UTF-8

[X-GNOME-Metatheme]
GtkTheme=LifeOS-Light
MetacityTheme=LifeOS-Light
IconTheme=Adwaita
CursorTheme=Adwaita
CursorSize=24
NotificationTheme=Default

[Settings]
; LifeOS Light Color Palette
