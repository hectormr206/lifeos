; Surface: #ffffff
; Primary: #0f4c75
; Accent: #3282b8
; Text: #1a1a2e
; Error: #c0392b
; Success: #27ae60

[Cosmic]
; COSMIC-specific theme settings using libcosmic
Background=#f8f9fa
Surface=#ffffff
Primary=#0f4c75
Accent=#3282b8
Text=#1a1a2e
TextMuted=#6b6b7b
