# LifeOS systemd preset — authoritative enable/disable for LifeOS units.
#
# systemctl preset reads these lines top-to-bottom; the first match wins.
# By declaring our units here (instead of relying on manual symlink farms in
# multi-user.target.wants/ and timers.target.wants/), we align with the
# vendor preset policy so `systemctl preset-all` won't fight us.

# --- AIDE integrity check ---
enable lifeos-aide-check.timer
disable lifeos-aide-check.service

# --- Independent watchdog ---
enable lifeos-sentinel.service

# --- Core runtime services ---
enable lifeos-thermal.service
enable lifeos-power-profile.service
enable lifeos-powertune.service
enable lifeos-ecore-pin.service
enable lifeos-battery.service
enable lifeos-security-baseline.service
enable lifeos-nvidia-signed-modules.service

# --- AI runtime ---
# After the architecture pivot (Phases 2, 4, 5, 7), chat inference,
# embeddings, TTS, the SimpleX bot, and STT all run as system Quadlets
# (lifeos-llama-server, lifeos-llama-embeddings, lifeos-tts,
# lifeos-simplex-bridge, plus whisper-cli inside lifeos-lifeosd). The
# Quadlet generator auto-enables them via [Install] WantedBy=
# multi-user.target in each .container file — no preset lines needed.
# The legacy host service unit files were dropped from bootc in the
# Phase-3 trim, so the previous `disable llama-server.service` /
# `disable simplex-chat.service` lines have nothing left to disable.
enable whisper-stt.service

# --- Timers ---
enable lifeos-smart-charge.timer
enable lifeos-btrfs-snapshot.timer
enable lifeos-maintenance-cleanup.timer
enable lifeos-flatpak-update.timer
enable lifeos-update-check.timer
enable lifeos-update-stage.timer
disable lifeos-update-stage.service
