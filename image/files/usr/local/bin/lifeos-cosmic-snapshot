#!/bin/bash
# LifeOS COSMIC config snapshot / restore utility.
#
# Why this exists: when bootc upgrades bring in a new COSMIC package
# version, the compositor can write default values for new config keys
# directly into ~/.config/cosmic/ — effectively resetting user
# customisations (panel plugins, opacity, dock layout, wallpaper, etc.).
# This happened in the 2026-04-10 update and is item #B in the pending
# items roadmap.
#
# This script lets the user snapshot ~/.config/cosmic/ before an upgrade
# and restore it if COSMIC clobbers the config on the next boot.
#
# Usage:
#   lifeos-cosmic-snapshot snapshot [--label <name>]
#       Create a snapshot of the current COSMIC config.
#
#   lifeos-cosmic-snapshot list
#       List available snapshots with timestamps and labels.
#
#   lifeos-cosmic-snapshot restore <timestamp|latest>
#       Restore a snapshot to ~/.config/cosmic/. The current config is
#       backed up to a `pre-restore-<now>` snapshot first so nothing is
#       destructively lost.
#
#   lifeos-cosmic-snapshot prune [--keep N]
#       Keep only the N most recent snapshots (default: 10).
#
# Design notes:
#   - Runs as the user (no sudo). State lives in ~/.local/share/lifeos/
#   - Uses rsync for atomic-ish copies (falls back to cp -a when rsync
#     is unavailable).
#   - Captures `rpm -qa cosmic-\*` in each snapshot so a post-upgrade
#     service (or the user) can correlate a reset with a version change.
#   - NEVER fails the caller — all operations are best-effort and logged
#     to stderr. The script exits 0 unless the user asked for a restore
#     that could not complete.

set -uo pipefail

COSMIC_CONFIG_DIR="${HOME}/.config/cosmic"
SNAPSHOT_ROOT="${HOME}/.local/share/lifeos/cosmic-snapshots"

log()  { printf '[lifeos-cosmic-snapshot] %s\n' "$*" >&2; }
die()  { log "ERROR: $*"; exit 1; }

iso_stamp() {
    date -u +"%Y%m%dT%H%M%SZ"
}

ensure_root() {
    mkdir -p "$SNAPSHOT_ROOT" 2>/dev/null || die "cannot create $SNAPSHOT_ROOT"
}

copy_tree() {
    local src="$1"
    local dst="$2"
    if command -v rsync &>/dev/null; then
        rsync -a --delete "$src/" "$dst/"
    else
        rm -rf "$dst"
        cp -a "$src" "$dst"
    fi
}

capture_cosmic_versions() {
    local out="$1"
    if command -v rpm &>/dev/null; then
        rpm -qa 'cosmic-*' 2>/dev/null | sort > "$out" || true
    else
        : > "$out"
    fi
}

cmd_snapshot() {
    local label="${1:-}"
    ensure_root

    if [ ! -d "$COSMIC_CONFIG_DIR" ]; then
        die "no COSMIC config found at $COSMIC_CONFIG_DIR"
    fi

    local stamp
    stamp="$(iso_stamp)"
    local snap_dir="$SNAPSHOT_ROOT/$stamp"
    mkdir -p "$snap_dir" || die "cannot create $snap_dir"

    copy_tree "$COSMIC_CONFIG_DIR" "$snap_dir/cosmic"
    capture_cosmic_versions "$snap_dir/cosmic-rpm-versions.txt"

    if [ -n "$label" ]; then
        printf '%s\n' "$label" > "$snap_dir/label.txt"
    fi

    log "snapshot saved: $stamp${label:+ (label: $label)}"
    printf '%s\n' "$stamp"
}

cmd_list() {
    ensure_root
    if [ ! -d "$SNAPSHOT_ROOT" ] || [ -z "$(ls -A "$SNAPSHOT_ROOT" 2>/dev/null)" ]; then
        log "no snapshots found"
        return 0
    fi

    local snap label
    printf '%-20s  %s\n' "TIMESTAMP" "LABEL"
    printf '%-20s  %s\n' "--------------------" "------"
    while IFS= read -r snap; do
        [ -d "$SNAPSHOT_ROOT/$snap" ] || continue
        label=""
        if [ -f "$SNAPSHOT_ROOT/$snap/label.txt" ]; then
            label="$(head -n1 "$SNAPSHOT_ROOT/$snap/label.txt")"
        fi
        printf '%-20s  %s\n' "$snap" "$label"
    done < <(ls -1 "$SNAPSHOT_ROOT" | sort -r)
}

cmd_restore() {
    local target="${1:-}"
    [ -n "$target" ] || die "usage: lifeos-cosmic-snapshot restore <timestamp|latest>"
    ensure_root

    if [ "$target" = "latest" ]; then
        target="$(ls -1 "$SNAPSHOT_ROOT" 2>/dev/null | sort -r | head -n1 || true)"
        [ -n "$target" ] || die "no snapshots available"
    fi

    local snap_dir="$SNAPSHOT_ROOT/$target/cosmic"
    [ -d "$snap_dir" ] || die "snapshot not found: $target"

    # Safety net: back up the current config before restoring so the user
    # can undo a bad restore. Labelled "pre-restore" so it is obvious.
    if [ -d "$COSMIC_CONFIG_DIR" ]; then
        cmd_snapshot "pre-restore-${target}" > /dev/null || \
            log "WARN: pre-restore backup failed; continuing anyway"
    fi

    mkdir -p "$COSMIC_CONFIG_DIR" || die "cannot create $COSMIC_CONFIG_DIR"
    copy_tree "$snap_dir" "$COSMIC_CONFIG_DIR"
    log "restored snapshot: $target"
    log "log out and back in to apply the restored COSMIC config"
}

cmd_prune() {
    local keep="${1:-10}"
    ensure_root

    local snaps
    mapfile -t snaps < <(ls -1 "$SNAPSHOT_ROOT" 2>/dev/null | sort -r || true)
    local total="${#snaps[@]}"
    if [ "$total" -le "$keep" ]; then
        log "nothing to prune ($total snapshots, keeping $keep)"
        return 0
    fi

    local i
    for (( i = keep; i < total; i++ )); do
        rm -rf "${SNAPSHOT_ROOT}/${snaps[i]}"
        log "pruned ${snaps[i]}"
    done
}

main() {
    local cmd="${1:-help}"
    shift || true

    case "$cmd" in
        snapshot)
            local label=""
            while [ $# -gt 0 ]; do
                case "$1" in
                    --label)
                        label="${2:-}"
                        shift 2
                        ;;
                    *)
                        die "unknown snapshot argument: $1"
                        ;;
                esac
            done
            cmd_snapshot "$label"
            ;;
        list)
            cmd_list
            ;;
        restore)
            cmd_restore "${1:-}"
            ;;
        prune)
            local keep=10
            while [ $# -gt 0 ]; do
                case "$1" in
                    --keep)
                        keep="${2:-10}"
                        shift 2
                        ;;
                    *)
                        die "unknown prune argument: $1"
                        ;;
                esac
            done
            cmd_prune "$keep"
            ;;
        help|--help|-h|"")
            cat <<'USAGE'
lifeos-cosmic-snapshot — snapshot / restore ~/.config/cosmic/

  snapshot [--label NAME]     Save current COSMIC config as a snapshot.
  list                        Show available snapshots.
  restore <ts|latest>         Restore a snapshot (auto-backup first).
  prune [--keep N]            Keep only the N most recent (default 10).
  help                        Show this message.
USAGE
            ;;
        *)
            die "unknown command: $cmd (try 'help')"
            ;;
    esac
}

main "$@"
