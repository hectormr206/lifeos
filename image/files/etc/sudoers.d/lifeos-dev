# LifeOS Developer Sudoers Policy (v2 — expanded for autonomous AI dev loop)
# ═══════════════════════════════════════════════════════════════════════
# ONLY installed when LIFEOS_BUILD_MODE=dev at image build time.
# Release images do NOT contain this file — enforced by the final
# verification block in image/Containerfile.
#
# This file grants passwordless execution of a curated set of development
# operations to the `lifeos` user so the AI assistant (Claude Code) can
# close the diagnose → fix → verify loop without human intervention for
# every sudo call.
#
# REVOCATION (emergency):
#     sudo rm /etc/sudoers.d/lifeos-dev
#     sudo bootc switch --transport containers-storage localhost/lifeos:release
#     sudo reboot
#
# AUDIT:
#     sudo journalctl _COMM=sudo | grep lifeos
#     sudo cat /var/log/lifeos/sudo-dev.log
#
# ═══════════════════════════════════════════════════════════════════════
# SCOPE — what is GRANTED:
#   READ ACCESS
#   - cat/ls/find/grep/stat/file on any path (diagnostics need this)
#   - dmesg and full journalctl (kernel and service logs)
#   - modinfo, lsmod, modprobe --show-depends, nvidia-smi
#
#   SERVICE MANAGEMENT
#   - systemctl {start,stop,restart,try-restart,reload,reset-failed} on
#     ANY unit (not just LifeOS ones)
#   - systemctl {enable,disable,mask,unmask} on ANY unit
#   - systemctl daemon-reload
#   - Full read-only systemctl queries (status/show/list-units/is-*)
#
#   KERNEL MODULE MANAGEMENT
#   - modprobe any module (nvidia, nouveau, etc)
#   - rmmod any module
#   - depmod -a
#
#   FILE INSTALLATION from repo checkout
#   - install into /etc/systemd/system/ (main units)
#   - install into /etc/systemd/system/*.service.d/ (dropins)
#   - install into /etc/systemd/user/*.service.d/ (user unit dropins)
#   - install into /etc/modules-load.d/ (module autoload)
#   - install into /etc/modprobe.d/ (module options)
#   - install into /etc/sudoers.d/lifeos-dev (THIS FILE SELF-UPDATE)
#
#   FILE DELETION in specific bounded paths
#   - rm ANY file in /etc/systemd/system/*.service.d/ (for cleaning stale
#     dropins)
#   - rm /etc/modules-load.d/lifeos-*.conf (for cleaning LifeOS module
#     autoload files)
#
#   BOOTC
#   - bootc switch to localhost/lifeos:{dev,release,dev-*,release-*}
#   - bootc rollback
#   - bootc status
#
# ═══════════════════════════════════════════════════════════════════════
# SCOPE — what is DENIED (intentionally, NEVER add these):
#   - reboot / shutdown / halt — always a conscious user decision
#   - bootc upgrade --apply — touches production deployment state
#   - bootc switch to any registry other than localhost containers-storage
#   - dnf / rpm / rpm-ostree / pip / cargo install — package installation
#   - Arbitrary write to /etc, /usr, /boot via cp, mv, tee, dd
#   - chmod / chown of system files
#   - Any install command with source OUTSIDE the repo checkout
#   - Any rm outside the narrow bounded paths above
#   - su / sudo to other users
#   - mount / umount of anything
#   - Any shell redirection via `sudo tee` or `sudo sh -c`
#   - visudo interactive mode
# ═══════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────────
# 1. READ-ONLY diagnostics — any file, any dir
# ───────────────────────────────────────────────────────────────────────
Cmnd_Alias LIFEOS_DEV_READ = \
    /usr/bin/cat *, \
    /usr/bin/ls *, \
    /usr/bin/stat *, \
    /usr/bin/file *, \
    /usr/bin/find *, \
    /usr/bin/grep *, \
    /usr/bin/egrep *, \
    /usr/bin/fgrep *, \
    /usr/bin/head *, \
    /usr/bin/tail *, \
    /usr/bin/wc *, \
    /usr/bin/du *, \
    /usr/bin/df *, \
    /usr/bin/lsof *, \
    /usr/sbin/lsof *

# ───────────────────────────────────────────────────────────────────────
# 2. KERNEL log and dmesg
# ───────────────────────────────────────────────────────────────────────
Cmnd_Alias LIFEOS_DEV_KERNEL_LOG = \
    /usr/bin/dmesg, \
    /usr/bin/dmesg *, \
    /usr/bin/journalctl, \
    /usr/bin/journalctl *

# ───────────────────────────────────────────────────────────────────────
# 3. KERNEL MODULE management
# Used to load/unload NVIDIA driver, debug module signing, etc.
# ───────────────────────────────────────────────────────────────────────
Cmnd_Alias LIFEOS_DEV_KMOD = \
    /usr/sbin/modprobe *, \
    /usr/sbin/modprobe, \
    /usr/sbin/rmmod *, \
    /usr/sbin/insmod *, \
    /usr/sbin/depmod, \
    /usr/sbin/depmod *, \
    /usr/sbin/modinfo *, \
    /usr/bin/kmod *

# ───────────────────────────────────────────────────────────────────────
# 4. NVIDIA GPU diagnostics
# ───────────────────────────────────────────────────────────────────────
Cmnd_Alias LIFEOS_DEV_NVIDIA = \
    /usr/bin/nvidia-smi, \
    /usr/bin/nvidia-smi *, \
    /usr/bin/nvidia-modprobe, \
    /usr/bin/nvidia-modprobe *, \
    /usr/bin/nvidia-persistenced, \
    /usr/bin/nvidia-persistenced *, \
    /usr/bin/nvidia-settings *

# ───────────────────────────────────────────────────────────────────────
# 5. SYSTEMCTL — broad service management
# Any unit start/stop/restart/enable/disable. This is the core of the
# AI diagnose→fix→verify loop.
# ───────────────────────────────────────────────────────────────────────
Cmnd_Alias LIFEOS_DEV_SYSTEMCTL = \
    /usr/bin/systemctl daemon-reload, \
    /usr/bin/systemctl daemon-reexec, \
    /usr/bin/systemctl start *, \
    /usr/bin/systemctl stop *, \
    /usr/bin/systemctl restart *, \
    /usr/bin/systemctl try-restart *, \
    /usr/bin/systemctl reload *, \
    /usr/bin/systemctl reload-or-restart *, \
    /usr/bin/systemctl reset-failed *, \
    /usr/bin/systemctl reset-failed, \
    /usr/bin/systemctl enable *, \
    /usr/bin/systemctl disable *, \
    /usr/bin/systemctl reenable *, \
    /usr/bin/systemctl mask *, \
    /usr/bin/systemctl unmask *, \
    /usr/bin/systemctl status, \
    /usr/bin/systemctl status *, \
    /usr/bin/systemctl cat *, \
    /usr/bin/systemctl show, \
    /usr/bin/systemctl show *, \
    /usr/bin/systemctl list-units, \
    /usr/bin/systemctl list-units *, \
    /usr/bin/systemctl list-unit-files, \
    /usr/bin/systemctl list-unit-files *, \
    /usr/bin/systemctl list-dependencies *, \
    /usr/bin/systemctl is-active, \
    /usr/bin/systemctl is-active *, \
    /usr/bin/systemctl is-enabled, \
    /usr/bin/systemctl is-enabled *, \
    /usr/bin/systemctl is-failed, \
    /usr/bin/systemctl is-failed *

# ───────────────────────────────────────────────────────────────────────
# 6. FILE INSTALL from the repo checkout to bounded destinations
# ───────────────────────────────────────────────────────────────────────
# Main system units
Cmnd_Alias LIFEOS_DEV_INSTALL_UNITS = \
    /usr/bin/install -m 644 /var/home/lifeos/personalProjects/gama/lifeos/lifeos/image/files/etc/systemd/system/*.service /etc/systemd/system/, \
    /usr/bin/install -m 644 /var/home/lifeos/personalProjects/gama/lifeos/lifeos/image/files/etc/systemd/system/*.timer /etc/systemd/system/, \
    /usr/bin/install -m 644 /var/home/lifeos/personalProjects/gama/lifeos/lifeos/image/files/etc/systemd/system/*.socket /etc/systemd/system/, \
    /usr/bin/install -m 644 /var/home/lifeos/personalProjects/gama/lifeos/lifeos/image/files/etc/systemd/system/*.conf /etc/systemd/system/

# System unit dropins
Cmnd_Alias LIFEOS_DEV_INSTALL_DROPINS = \
    /usr/bin/install -D -m 644 /var/home/lifeos/personalProjects/gama/lifeos/lifeos/image/files/etc/systemd/system/llama-server.service.d/*.conf /etc/systemd/system/llama-server.service.d/, \
    /usr/bin/install -D -m 644 /var/home/lifeos/personalProjects/gama/lifeos/lifeos/image/files/etc/systemd/system/llama-embeddings.service.d/*.conf /etc/systemd/system/llama-embeddings.service.d/, \
    /usr/bin/install -D -m 644 /var/home/lifeos/personalProjects/gama/lifeos/lifeos/image/files/etc/systemd/system/nvidia-persistenced.service.d/*.conf /etc/systemd/system/nvidia-persistenced.service.d/, \
    /usr/bin/install -D -m 644 /var/home/lifeos/personalProjects/gama/lifeos/lifeos/image/files/etc/systemd/system/whisper-stt.service.d/*.conf /etc/systemd/system/whisper-stt.service.d/, \
    /usr/bin/install -D -m 644 /var/home/lifeos/personalProjects/gama/lifeos/lifeos/image/files/etc/systemd/system/lifeos-sentinel.service.d/*.conf /etc/systemd/system/lifeos-sentinel.service.d/, \
    /usr/bin/install -D -m 644 /var/home/lifeos/personalProjects/gama/lifeos/lifeos/image/files/etc/systemd/system/lifeos-sentinel.service.d/*.conf /etc/systemd/system/lifeos-sentinel.service.d/*.conf, \
    /usr/bin/install -D -m 644 /var/home/lifeos/personalProjects/gama/lifeos/lifeos/image/files/etc/systemd/user/lifeosd.service.d/*.conf /etc/systemd/user/lifeosd.service.d/

# Module autoload and options
Cmnd_Alias LIFEOS_DEV_INSTALL_MODULES = \
    /usr/bin/install -m 644 /var/home/lifeos/personalProjects/gama/lifeos/lifeos/image/files/etc/modules-load.d/*.conf /etc/modules-load.d/, \
    /usr/bin/install -m 644 /var/home/lifeos/personalProjects/gama/lifeos/lifeos/image/files/etc/modprobe.d/*.conf /etc/modprobe.d/

# Self-update: the AI can install an updated version of THIS sudoers
# file from the repo. The destination is pinned to the exact path so
# it cannot install an arbitrary sudoers file under a different name.
# Every change to the file is visible in the git history as a commit.
Cmnd_Alias LIFEOS_DEV_INSTALL_SUDOERS = \
    /usr/bin/install -m 440 -o root -g root /var/home/lifeos/personalProjects/gama/lifeos/lifeos/image/files/etc/sudoers.d/lifeos-dev /etc/sudoers.d/lifeos-dev

# ───────────────────────────────────────────────────────────────────────
# 7. FILE DELETION in bounded paths
# Deletion is more dangerous than installation, so the paths are very
# narrow. Only things the AI needs to clean up can be removed.
# ───────────────────────────────────────────────────────────────────────
Cmnd_Alias LIFEOS_DEV_RM = \
    /usr/bin/rm /etc/systemd/system/*.service.d/*.conf, \
    /usr/bin/rm /etc/systemd/user/*.service.d/*.conf, \
    /usr/bin/rm /etc/modules-load.d/lifeos-*.conf, \
    /usr/bin/rm /etc/modprobe.d/lifeos-*.conf

# ───────────────────────────────────────────────────────────────────────
# 8. BOOTC operations
# ───────────────────────────────────────────────────────────────────────
Cmnd_Alias LIFEOS_DEV_BOOTC = \
    /usr/bin/bootc switch --transport containers-storage localhost/lifeos\:dev, \
    /usr/bin/bootc switch --transport containers-storage localhost/lifeos\:release, \
    /usr/bin/bootc switch --transport containers-storage localhost/lifeos\:dev-*, \
    /usr/bin/bootc switch --transport containers-storage localhost/lifeos\:release-*, \
    /usr/bin/bootc rollback, \
    /usr/bin/bootc status, \
    /usr/bin/bootc status --json

# ───────────────────────────────────────────────────────────────────────
# 9. PODMAN — needed for image transfers between rootless and rootful
# ───────────────────────────────────────────────────────────────────────
Cmnd_Alias LIFEOS_DEV_PODMAN = \
    /usr/bin/podman load *, \
    /usr/bin/podman load, \
    /usr/bin/podman images, \
    /usr/bin/podman images *, \
    /usr/bin/podman inspect *, \
    /usr/bin/podman rmi *

# ───────────────────────────────────────────────────────────────────────
# Grant to the lifeos user only, NOPASSWD for all aliases above.
# Note: the user must exist on the target system; if the user is not
# named "lifeos" this file will have no effect.
# ───────────────────────────────────────────────────────────────────────
lifeos ALL=(root) NOPASSWD: \
    LIFEOS_DEV_READ, \
    LIFEOS_DEV_KERNEL_LOG, \
    LIFEOS_DEV_KMOD, \
    LIFEOS_DEV_NVIDIA, \
    LIFEOS_DEV_SYSTEMCTL, \
    LIFEOS_DEV_INSTALL_UNITS, \
    LIFEOS_DEV_INSTALL_DROPINS, \
    LIFEOS_DEV_INSTALL_MODULES, \
    LIFEOS_DEV_INSTALL_SUDOERS, \
    LIFEOS_DEV_RM, \
    LIFEOS_DEV_BOOTC, \
    LIFEOS_DEV_PODMAN

# Audit — log every NOPASSWD invocation to the dedicated log file + journal.
# log_output captures stdout/stderr of sudo-invoked commands for forensics.
Defaults:lifeos log_output
Defaults:lifeos !lecture
Defaults:lifeos logfile=/var/log/lifeos/sudo-dev.log
