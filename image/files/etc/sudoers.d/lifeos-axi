# LifeOS Axi — controlled sudo permissions for automated system management.
# Each permission is audited and specific. No blanket root access.
# Uses %wheel group so any user created during installation gets access.
# Audit date: 2026-04-15 | Source: daemon/src/ privilege audit (wildcards removed)

# === LLAMA-SERVER (Game Guard GPU offload) ===
# game_guard.rs, agent_runtime.rs, sensory_pipeline.rs, api/mod.rs
%wheel ALL=(root) NOPASSWD: /usr/bin/systemctl restart llama-server.service
%wheel ALL=(root) NOPASSWD: /usr/bin/systemctl stop llama-server.service
%wheel ALL=(root) NOPASSWD: /usr/bin/systemctl start llama-server.service
%wheel ALL=(root) NOPASSWD: /usr/bin/systemctl try-restart llama-server.service
%wheel ALL=(root) NOPASSWD: /usr/bin/systemctl is-active llama-server.service

# === STT SERVICE (Speech-to-text lifecycle) ===
# api/mod.rs — start/stop/enable speech recognition
%wheel ALL=(root) NOPASSWD: /usr/bin/systemctl start whisper-stt.service
%wheel ALL=(root) NOPASSWD: /usr/bin/systemctl stop whisper-stt.service
%wheel ALL=(root) NOPASSWD: /usr/bin/systemctl restart whisper-stt.service
%wheel ALL=(root) NOPASSWD: /usr/bin/systemctl enable whisper-stt.service
%wheel ALL=(root) NOPASSWD: /usr/bin/systemctl is-active whisper-stt.service
%wheel ALL=(root) NOPASSWD: /usr/bin/systemctl is-enabled whisper-stt.service

# === SYSTEMD DAEMON RELOAD ===
# Needed after writing drop-in configs
%wheel ALL=(root) NOPASSWD: /usr/bin/systemctl daemon-reload

# === BOOTC UPDATES (atomic OS updates) ===
# updates.rs, health.rs, agent_runtime.rs
%wheel ALL=(root) NOPASSWD: /usr/bin/bootc status --json
%wheel ALL=(root) NOPASSWD: /usr/bin/bootc upgrade --check
%wheel ALL=(root) NOPASSWD: /usr/bin/bootc upgrade
%wheel ALL=(root) NOPASSWD: /usr/bin/bootc upgrade --apply
%wheel ALL=(root) NOPASSWD: /usr/bin/bootc rollback
%wheel ALL=(root) NOPASSWD: /usr/bin/bootc switch --transport containers-storage localhost/lifeos\:dev
%wheel ALL=(root) NOPASSWD: /usr/bin/bootc switch --transport containers-storage localhost/lifeos\:stable
%wheel ALL=(root) NOPASSWD: /usr/bin/bootc usr-overlay
# Load LifeOS images from user-storage tar into root containers-storage so bootc can see them
%wheel ALL=(root) NOPASSWD: /usr/bin/podman load -i /tmp/lifeos-dev.tar
%wheel ALL=(root) NOPASSWD: /usr/bin/podman load -i /tmp/lifeos-stable.tar

