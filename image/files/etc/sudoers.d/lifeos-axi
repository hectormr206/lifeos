# LifeOS Axi — controlled sudo permissions for automated system management.
# Each permission is audited and specific. No blanket root access.
# Uses %wheel group so any user created during installation gets access.
# Audit date: 2026-03-26 | Source: daemon/src/ privilege audit (26 locations)

# === LLAMA-SERVER (Game Guard GPU offload) ===
# game_guard.rs, agent_runtime.rs, sensory_pipeline.rs, api/mod.rs
%wheel ALL=(root) NOPASSWD: /usr/bin/systemctl restart llama-server.service
%wheel ALL=(root) NOPASSWD: /usr/bin/systemctl stop llama-server.service
%wheel ALL=(root) NOPASSWD: /usr/bin/systemctl start llama-server.service
%wheel ALL=(root) NOPASSWD: /usr/bin/systemctl try-restart llama-server.service
%wheel ALL=(root) NOPASSWD: /usr/bin/systemctl is-active llama-server.service

# === STT SERVICE (Speech-to-text lifecycle) ===
# api/mod.rs — start/stop/enable speech recognition
%wheel ALL=(root) NOPASSWD: /usr/bin/systemctl start whisper-stt.service
%wheel ALL=(root) NOPASSWD: /usr/bin/systemctl stop whisper-stt.service
%wheel ALL=(root) NOPASSWD: /usr/bin/systemctl restart whisper-stt.service
%wheel ALL=(root) NOPASSWD: /usr/bin/systemctl enable whisper-stt.service
%wheel ALL=(root) NOPASSWD: /usr/bin/systemctl is-active whisper-stt.service
%wheel ALL=(root) NOPASSWD: /usr/bin/systemctl is-enabled whisper-stt.service

# === SYSTEMD DAEMON RELOAD ===
# Needed after writing drop-in configs
%wheel ALL=(root) NOPASSWD: /usr/bin/systemctl daemon-reload

# === BOOTC UPDATES (atomic OS updates) ===
# updates.rs, health.rs, agent_runtime.rs
%wheel ALL=(root) NOPASSWD: /usr/bin/bootc status --json
%wheel ALL=(root) NOPASSWD: /usr/bin/bootc upgrade --check
%wheel ALL=(root) NOPASSWD: /usr/bin/bootc upgrade
%wheel ALL=(root) NOPASSWD: /usr/bin/bootc upgrade --apply
%wheel ALL=(root) NOPASSWD: /usr/bin/bootc rollback

# === FLATPAK SYSTEM INSTALLS ===
# telegram_tools.rs, security_daemon.rs, proactive.rs
%wheel ALL=(root) NOPASSWD: /usr/bin/flatpak install --system -y --noninteractive flathub *
%wheel ALL=(root) NOPASSWD: /usr/bin/flatpak uninstall --unused -y
%wheel ALL=(root) NOPASSWD: /usr/bin/flatpak update --system -y --noninteractive

# === HARDWARE DIAGNOSTICS (read-only) ===
# security_daemon.rs, proactive.rs — SSD health monitoring
%wheel ALL=(root) NOPASSWD: /usr/sbin/smartctl -j -a /dev/nvme*
%wheel ALL=(root) NOPASSWD: /usr/sbin/smartctl -j -a /dev/sd*

# === NETWORK SECURITY (read-only) ===
# proactive.rs — firewall status check
%wheel ALL=(root) NOPASSWD: /usr/sbin/nft list ruleset

# === NETWORK SECURITY (service management — telegram_tools.rs service_manage) ===
%wheel ALL=(root) NOPASSWD: /usr/bin/systemctl start nftables.service
%wheel ALL=(root) NOPASSWD: /usr/bin/systemctl stop nftables.service
%wheel ALL=(root) NOPASSWD: /usr/bin/systemctl restart nftables.service
%wheel ALL=(root) NOPASSWD: /usr/bin/systemctl enable nftables.service
%wheel ALL=(root) NOPASSWD: /usr/bin/systemctl disable nftables.service
%wheel ALL=(root) NOPASSWD: /usr/bin/systemctl start firewalld.service
%wheel ALL=(root) NOPASSWD: /usr/bin/systemctl stop firewalld.service
%wheel ALL=(root) NOPASSWD: /usr/bin/systemctl restart firewalld.service
%wheel ALL=(root) NOPASSWD: /usr/bin/systemctl enable firewalld.service
%wheel ALL=(root) NOPASSWD: /usr/bin/systemctl disable firewalld.service

# === NETWORK SECURITY (blocking — security_ai.rs) ===
%wheel ALL=(root) NOPASSWD: /usr/sbin/nft add rule inet filter input ip saddr * drop
%wheel ALL=(root) NOPASSWD: /usr/sbin/iptables -A INPUT -s * -j DROP

# === SYSTEM TUNER (sysctl optimization — system_tuner.rs) ===
%wheel ALL=(root) NOPASSWD: /usr/sbin/sysctl -w *

# === BATTERY MANAGER (charge thresholds — battery_manager.rs) ===
%wheel ALL=(root) NOPASSWD: /usr/bin/tee /sys/class/power_supply/BAT*/charge_control_end_threshold

# === PROCESS ISOLATION (security_ai.rs) ===
%wheel ALL=(root) NOPASSWD: /usr/bin/kill -STOP *

# === RPM VERIFICATION (security_ai.rs system integrity) ===
%wheel ALL=(root) NOPASSWD: /usr/bin/rpm -V *

# === SYSTEMCTL RESET-FAILED (recover from start-limit-hit) ===
%wheel ALL=(root) NOPASSWD: /usr/bin/systemctl reset-failed *

# === DEV DEPLOYMENT (sync repo changes to live system) ===
# Validated script: source must be under image/files/, dest under allowed paths only.
# Enables AI assistant to apply fixes to both repo AND live system in one turn.
%wheel ALL=(root) NOPASSWD: /var/lib/lifeos/lifeos-dev-deploy.sh
