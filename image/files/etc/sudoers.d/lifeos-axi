# === NETWORK SECURITY (service management — axi_tools.rs service_manage) ===
%wheel ALL=(root) NOPASSWD: /usr/bin/systemctl start nftables.service
%wheel ALL=(root) NOPASSWD: /usr/bin/systemctl stop nftables.service
%wheel ALL=(root) NOPASSWD: /usr/bin/systemctl restart nftables.service
%wheel ALL=(root) NOPASSWD: /usr/bin/systemctl enable nftables.service
%wheel ALL=(root) NOPASSWD: /usr/bin/systemctl disable nftables.service
%wheel ALL=(root) NOPASSWD: /usr/bin/systemctl start firewalld.service
%wheel ALL=(root) NOPASSWD: /usr/bin/systemctl stop firewalld.service
%wheel ALL=(root) NOPASSWD: /usr/bin/systemctl restart firewalld.service
%wheel ALL=(root) NOPASSWD: /usr/bin/systemctl enable firewalld.service
%wheel ALL=(root) NOPASSWD: /usr/bin/systemctl disable firewalld.service

# === NETWORK SECURITY (blocking via named set — security_ai.rs) ===
# The nftables blocklist set `lifeos_banlist` is pre-created by
# /etc/firewalld/zones/lifeos.xml (or the nftables ruleset). To blackhole a
# source address, Axi adds/removes elements to this set only — no raw rule
# creation allowed.
%wheel ALL=(root) NOPASSWD: /usr/sbin/nft add element inet filter lifeos_banlist { *
%wheel ALL=(root) NOPASSWD: /usr/sbin/nft delete element inet filter lifeos_banlist { *
# (No /usr/sbin/iptables -A INPUT wildcard — iptables blocking deprecated.)

# === SYSTEM TUNER (sysctl optimization — system_tuner.rs) ===
# Enumerated from daemon/src/system_tuner.rs:166-170 (the only writable keys).
# Adding a new tunable requires updating BOTH the daemon and this file.
%wheel ALL=(root) NOPASSWD: /usr/sbin/sysctl -w vm.swappiness=10
%wheel ALL=(root) NOPASSWD: /usr/sbin/sysctl -w vm.swappiness=30
%wheel ALL=(root) NOPASSWD: /usr/sbin/sysctl -w vm.swappiness=60
%wheel ALL=(root) NOPASSWD: /usr/sbin/sysctl -w vm.dirty_ratio=10
%wheel ALL=(root) NOPASSWD: /usr/sbin/sysctl -w vm.dirty_ratio=20
%wheel ALL=(root) NOPASSWD: /usr/sbin/sysctl -w vm.dirty_ratio=40
%wheel ALL=(root) NOPASSWD: /usr/sbin/sysctl -w vm.dirty_background_ratio=5
%wheel ALL=(root) NOPASSWD: /usr/sbin/sysctl -w vm.dirty_background_ratio=10
%wheel ALL=(root) NOPASSWD: /usr/sbin/sysctl -w vm.dirty_background_ratio=20

# === BATTERY MANAGER (charge thresholds — battery_manager.rs) ===
%wheel ALL=(root) NOPASSWD: /usr/bin/tee /sys/class/power_supply/BAT*/charge_control_end_threshold

# === PROCESS ISOLATION (security_ai.rs) ===
# Wildcard `kill -STOP *` removed — could target PID 1. Isolation now goes
# through a vetted wrapper that reads a PID from a controlled file, verifies
# the PID belongs to a LifeOS-managed unit (not systemd/init), and only then
# sends SIGSTOP. The wrapper lives in /usr/local/bin and ignores any args.
%wheel ALL=(root) NOPASSWD: /usr/local/bin/lifeos-isolate-process

# === RPM VERIFICATION (security_ai.rs system integrity) ===
# Enumerated from daemon/src/security_ai.rs:549-555 (critical_packages list).
# Wildcard `rpm -V *` removed — no arbitrary package verification.
%wheel ALL=(root) NOPASSWD: /usr/bin/rpm -V coreutils
%wheel ALL=(root) NOPASSWD: /usr/bin/rpm -V systemd
%wheel ALL=(root) NOPASSWD: /usr/bin/rpm -V openssh-server
%wheel ALL=(root) NOPASSWD: /usr/bin/rpm -V shadow-utils
%wheel ALL=(root) NOPASSWD: /usr/bin/rpm -V sudo

# === SYSTEMCTL RESET-FAILED (recover from start-limit-hit) ===
# Enumerated to LifeOS-managed units only.
%wheel ALL=(root) NOPASSWD: /usr/bin/systemctl reset-failed llama-server.service
%wheel ALL=(root) NOPASSWD: /usr/bin/systemctl reset-failed llama-embeddings.service
%wheel ALL=(root) NOPASSWD: /usr/bin/systemctl reset-failed whisper-stt.service
%wheel ALL=(root) NOPASSWD: /usr/bin/systemctl reset-failed lifeos-sentinel.service
%wheel ALL=(root) NOPASSWD: /usr/bin/systemctl reset-failed lifeos-thermal.service
%wheel ALL=(root) NOPASSWD: /usr/bin/systemctl reset-failed lifeos-power-profile.service
%wheel ALL=(root) NOPASSWD: /usr/bin/systemctl reset-failed lifeos-ecore-pin.service

# === DEV DEPLOYMENT (sync repo changes to live system) ===
# The script internally enforces:
#   - Source MUST resolve inside /var/home/lifeos/personalProjects/gama/lifeos/lifeos/image/files/
#   - Dest MUST be under a hard-coded ALLOWED_DESTS allowlist
# Sudoers keeps the wildcard because the args ARE user-chosen paths; the
# safety comes from the in-script validation (read-only allowlist). See
# lifeos-dev-deploy.sh for the full check.
%wheel ALL=(root) NOPASSWD: /var/lib/lifeos/lifeos-dev-deploy.sh *
%wheel ALL=(root) NOPASSWD: /usr/local/bin/lifeos-dev-deploy.sh *

# === UDEV RELOAD (AI-driven dev workflow — re-apply rules after deploy) ===
# Needed after lifeos-dev-deploy.sh syncs new udev rules to /etc/udev/rules.d/.
%wheel ALL=(root) NOPASSWD: /usr/bin/udevadm control --reload
%wheel ALL=(root) NOPASSWD: /usr/bin/udevadm trigger --subsystem-match=cpu
%wheel ALL=(root) NOPASSWD: /usr/bin/udevadm trigger --subsystem-match=cpu --action=add
%wheel ALL=(root) NOPASSWD: /usr/bin/udevadm trigger --subsystem-match=cpu --action=change
%wheel ALL=(root) NOPASSWD: /usr/bin/udevadm trigger --subsystem-match=cpu --action=remove
