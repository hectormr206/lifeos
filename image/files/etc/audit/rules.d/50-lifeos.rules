# LifeOS auditd Rules — Kernel Audit Framework (CIS Benchmark)
# Provides an immutable ledger of security-relevant system events.
# These rules monitor the most critical attack surfaces.

# --- Identity & Authentication ---
# Monitor access to password/shadow files
-w /etc/passwd -p wa -k identity
-w /etc/shadow -p wa -k identity
-w /etc/group -p wa -k identity
-w /etc/gshadow -p wa -k identity

# --- Privilege Escalation ---
# Monitor changes to sudoers
-w /etc/sudoers -p wa -k privilege_escalation
-w /etc/sudoers.d/ -p wa -k privilege_escalation

# Monitor su and sudo usage
-w /usr/bin/su -p x -k privilege_escalation
-w /usr/bin/sudo -p x -k privilege_escalation

# --- Kernel Module Loading ---
# Detect unauthorized kernel module insertion
-w /sbin/insmod -p x -k kernel_modules
-w /sbin/modprobe -p x -k kernel_modules
-w /sbin/rmmod -p x -k kernel_modules
-a always,exit -F arch=b64 -S init_module,finit_module -k kernel_modules
-a always,exit -F arch=b64 -S delete_module -k kernel_modules

# --- Mount Operations ---
# Detect unauthorized filesystem mounts (USB, network shares)
-a always,exit -F arch=b64 -S mount -k mounts

# --- Time Changes ---
# Detect attempts to tamper with system time (cover tracks)
-a always,exit -F arch=b64 -S adjtimex,settimeofday,clock_settime -k time_change
-w /etc/localtime -p wa -k time_change

# --- Network Configuration ---
# Detect network configuration changes
-w /etc/hosts -p wa -k network_config
-w /etc/hostname -p wa -k network_config
-a always,exit -F arch=b64 -S sethostname,setdomainname -k network_config

# --- Login Events ---
# Track login/logout for forensics
-w /var/log/lastlog -p wa -k logins
-w /var/log/wtmp -p wa -k logins
-w /var/log/btmp -p wa -k logins

# --- LifeOS-specific ---
# Monitor LifeOS config changes
-w /etc/lifeos/ -p wa -k lifeos_config
-w /var/lib/lifeos/ -p wa -k lifeos_data

# --- LifeOS Container Infrastructure (Capa 6 of defense-in-depth) ---
# PRD: docs/strategy/prd-architecture-pivot-lean-bootc-quadlet.md §5e Capa 6.
# Track modifications to Quadlet service definitions and rootful container
# storage so post-incident forensics can identify who changed what.
# (/etc/sudoers.d/ is already covered above by privilege_escalation key.)
#
# Volume note: container_storage_changed is a high-frequency key — every
# image pull, container start, and layer write hits it. This is intentional;
# the trail is more valuable than the log size on a single-user laptop.
-w /etc/containers/systemd/ -p wa -k lifeos_quadlet_changed
-w /var/lib/containers/storage/ -p wa -k lifeos_container_storage_changed

# Make audit configuration immutable (requires reboot to change)
-e 2
