# LifeOS TTS Server Configuration
# Loaded by the lifeos-tts.service Quadlet via [Container] EnvironmentFile=
# (the file's vars propagate into the container process env via podman --env-file).
# See containers/lifeos-tts/lifeos-tts-server.py for the server implementation
# and containers/lifeos-tts/Containerfile for how the venv + voices ship.

# Default voice for synthesis when no per-request or user-preference voice is set.
# Must be a valid Kokoro voice name (see GET /voices for the full list).
# Prefix convention: ef_=Español-F, em_=Español-M, af_/am_=US-English, bf_/bm_=UK-English,
# if_/im_=Italiano, ff_=Français, pf_/pm_=Português, jf_/jm_=Japonés, zf_/zm_=中文, hf_/hm_=Hindi.
LIFEOS_TTS_DEFAULT_VOICE=ef_dora

# Path to libespeak-ng shared library. Required: without this, phonemizer falls back
# to grapheme-level output and Kokoro produces robotic audio for every voice.
# Fedora ships libespeak-ng.so.1 at /usr/lib64/.
PHONEMIZER_ESPEAK_LIBRARY=/usr/lib64/libespeak-ng.so.1

# TCP port the server binds to (loopback only — never exposed externally).
# 8083 is reserved for llama-embeddings.service (nomic-embed); Kokoro uses 8084.
LIFEOS_TTS_ENGINE_PORT=8084

# Torch inference device. cpu = CPU-only (no CUDA required).
# Change to cuda:0 if a CUDA GPU is available and you want GPU acceleration.
LIFEOS_TTS_DEVICE=cpu

# HuggingFace cache directory — voices and models pre-loaded at image build.
# Must match the build-time HF_HOME so kokoro finds cached weights.
HF_HOME=/opt/lifeos/kokoro-env/hf-cache

# Prevent HuggingFace Hub from making outbound requests at inference time.
# Models and voices are pre-loaded into the image — no downloads needed.
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
PYTORCH_DISABLE_HUGGINGFACE_HUB_TELEMETRY=1
