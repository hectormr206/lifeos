# LifeOS automatic maintenance cleanup policy

# Screenshots (screen awareness)
SCREENSHOT_DIR=/var/lib/lifeos/screenshots
SCREENSHOT_KEEP_COUNT=120
SCREENSHOT_KEEP_DAYS=2

# Voice artifacts (always-on audio snippets + TTS wav outputs)
AUDIO_DIR=/var/lib/lifeos/audio
AUDIO_KEEP_COUNT=120
AUDIO_KEEP_DAYS=2
TTS_DIR=/var/lib/lifeos/tts
TTS_KEEP_COUNT=120
TTS_KEEP_DAYS=2

# GitHub self-hosted runner
RUNNER_DIR=/var/lib/lifeos/actions-runner
RUNNER_DIAG_KEEP_DAYS=14
RUNNER_TEMP_KEEP_DAYS=2
RUNNER_ACTIONS_KEEP_DAYS=30
RUNNER_TARGET_KEEP_DAYS=3

# Space-separated list of output directories used for ISO/image artifacts
ISO_OUTPUT_DIRS="/var/home/lifeos/personalProjects/gama/lifeos/output"
ISO_KEEP_LATEST=2
ISO_LOG_KEEP_DAYS=14

# Development targets
DEV_PROJECT_DIRS="/var/home/lifeos/personalProjects/gama/lifeos"
DEV_TARGET_PRUNE_ON_HIGH_DISK=true
DEV_TARGET_PRUNE_THRESHOLD=92

# Temporary build directories
TMP_PURGE_DAYS=3

# Container and host maintenance
PODMAN_PRUNE_ENABLED=false
PODMAN_PRUNE_IMAGES=false
PODMAN_PRUNE_UNTIL=168h
BOOTC_CLEANUP_ENABLED=true
FLATPAK_PRUNE_ENABLED=false
JOURNAL_VACUUM_DAYS=14

# Build guard: skip cleanup while ISO/image build is running
BUILD_GUARD_ENABLED=true
BUILD_LOCK_FILES="/run/lifeos/build-iso.lock /run/lifeos/iso-build.lock /tmp/lifeos-build.lock"
BUILD_PROCESS_PATTERN="scripts/build-iso.sh|scripts/generate-iso-simple.sh|scripts/generate-iso.sh|bootc-image-builder|osbuild|xorriso|mkisofs|genisoimage|qemu-img"
