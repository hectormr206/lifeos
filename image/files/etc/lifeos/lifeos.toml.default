[system]
channel = "stable"
mode = "personal"
locale = "es_MX.UTF-8"
timezone = "UTC"

[ai]
enabled = true
provider = "llama-server"
model = "Qwen3.5-4B-Q4_K_M.gguf"
llama_server_host = "http://localhost:8082"

[security]
encryption = true
secure_boot = true
auto_lock = true
auto_lock_timeout = 300
