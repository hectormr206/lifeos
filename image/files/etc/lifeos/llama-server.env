# LifeOS AI Runtime Configuration
# See docs/AI_MODEL_SELECTION.md for technical justification
# Reference: https://unsloth.ai/docs/models/qwen3.5
#
# BASELINE / FALLBACK values only. lifeosd writes a hardware-tuned profile to
# /var/lib/lifeos/llama-server-runtime-profile.env after the first benchmark
# and that file is loaded AFTER this one in llama-server.service (later
# EnvironmentFile= wins), so LIFEOS_AI_CTX_SIZE, _THREADS, _GPU_LAYERS,
# _PARALLEL, _BATCH_SIZE and _UBATCH_SIZE here are only used until the first
# benchmark completes. Do NOT hand-edit the runtime profile — it is
# regenerated on hardware changes.

# Model to load (filename in /var/lib/lifeos/models/)
# 9B is the canonical LifeOS model (see project_pending_model_vps memory).
LIFEOS_AI_MODEL=Qwen3.5-9B-Q4_K_M.gguf
# Multimodal vision projector (filename in /var/lib/lifeos/models/)
LIFEOS_AI_MMPROJ=Qwen3.5-9B-mmproj-F16.gguf
# Auto-manage heavy model downloads at boot (true/false)
# true => automatically download the default model if missing (zero-config experience)
# Set to false to prevent auto-downloads on metered connections
LIFEOS_AI_AUTO_MANAGE_MODELS=true
# Bind host (loopback-only by default)
LIFEOS_AI_HOST=127.0.0.1
# Context size (tokens) — Qwen3.5-4B supports up to 262K natively
# 16K is the recommended default per Unsloth guide (~5.5GB RAM for 4B Q4_K_M)
# Increase to 32768, 65536, or 131072 if you have more RAM
LIFEOS_AI_CTX_SIZE=16384
# Number of CPU threads. The first-boot script auto-detects this from
# `nproc` (capped at 8 to avoid hyperthread thrash). Override here if you
# want to pin a specific value — your override will not be touched on
# subsequent boots.
LIFEOS_AI_THREADS=4
# GPU layers to offload (0 = CPU only, -1 = all, 99 = auto/all available)
# Default 99 = use all GPU layers when GPU is available, gracefully falls back to CPU
LIFEOS_AI_GPU_LAYERS=99
# llama.cpp parallel slots. Runtime tuning may override this in
# /var/lib/lifeos/llama-server-runtime-profile.env after first benchmark.
LIFEOS_AI_PARALLEL=1
# llama.cpp batch and micro-batch sizes. These are now tunable per device.
LIFEOS_AI_BATCH_SIZE=512
LIFEOS_AI_UBATCH_SIZE=128
# Server port
LIFEOS_AI_PORT=8082
# Model alias for OpenAI-compatible API responses
LIFEOS_AI_ALIAS=lifeos
# Game Guard defaults. Axi disables the guard automatically on machines
# without a supported dedicated GPU profile.
LIFEOS_AI_GAME_GUARD=true
LIFEOS_AI_GAME_ASSISTANT=true

# ─────────────────────────────────────────────────────────────────────────────
# Sampling defaults (Qwen3.5 official recipe — Unsloth)
# ─────────────────────────────────────────────────────────────────────────────
# These are wired directly into the systemd ExecStart, NOT read from this
# file, so editing them here has no effect. They live in
# /etc/systemd/system/llama-server.service. To override them per-request,
# pass `temperature`, `top_p`, `top_k`, `min_p`, `presence_penalty`,
# `repeat_penalty` in your /v1/chat/completions JSON body.
#
#   --temp 0.6  --top-p 0.95  --top-k 20  --min-p 0.0
#   --presence-penalty 0.0  --repeat-penalty 1.0
#
# Performance flags (also wired into ExecStart):
#   --flash-attn               Flash Attention (auto-falls back if unsupported)
#   --cache-type-k q8_0        KV cache K cuantizado a 8-bit
#   --cache-type-v q8_0        KV cache V cuantizado a 8-bit
#   -sm none -mg 0             single-GPU pinning (no-op on CPU)
#   --parallel/--batch/--ubatch now read the env vars above and may be
#   auto-overridden by `lifeosd` after the first hardware benchmark.
#   --reasoning off            disable Qwen3.5 thinking at the template level
#                              (stronger than --reasoning-budget 0: the
#                              <think> block is never opened). Override
#                              per-request with `enable_thinking: true` or
#                              a /think prefix in the user message.
# ─────────────────────────────────────────────────────────────────────────────
