# LifeOS AI Runtime Configuration
# See docs/AI_MODEL_SELECTION.md for technical justification

# Model to load (filename in /var/lib/lifeos/models/)
LIFEOS_AI_MODEL=Qwen3VL-4B-Instruct-Q4_K_M.gguf
# Multimodal vision projector (filename in /var/lib/lifeos/models/)
LIFEOS_AI_MMPROJ=mmproj-Qwen3VL-4B-Instruct-Q8_0.gguf
# Bind host (loopback-only by default)
LIFEOS_AI_HOST=127.0.0.1
# Context size (tokens) — Qwen3-VL-4B supports up to 256K
LIFEOS_AI_CTX_SIZE=131072
# KV cache quantization — reduces 128K context from ~9.5GB to ~3.2GB RAM
LIFEOS_AI_CACHE_TYPE_K=q4_0
LIFEOS_AI_CACHE_TYPE_V=q4_0
# Flash Attention — critical for long context on CPU (reduces latency + RAM)
LIFEOS_AI_FLASH_ATTN=1
# Number of CPU threads
LIFEOS_AI_THREADS=4
# GPU layers to offload (0 = CPU only, -1 = all)
LIFEOS_AI_GPU_LAYERS=0
# Server port
LIFEOS_AI_PORT=8082
