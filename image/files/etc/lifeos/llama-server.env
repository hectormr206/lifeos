# LifeOS AI Runtime Configuration
# Model to load (filename in /var/lib/lifeos/models/)
LIFEOS_AI_MODEL=qwen3-8b-q4_k_m.gguf
# Bind host (loopback-only by default)
LIFEOS_AI_HOST=127.0.0.1
# Context size (tokens)
LIFEOS_AI_CTX_SIZE=4096
# Number of CPU threads
LIFEOS_AI_THREADS=4
# GPU layers to offload (0 = CPU only, -1 = all)
LIFEOS_AI_GPU_LAYERS=0
# Server port
LIFEOS_AI_PORT=8080
