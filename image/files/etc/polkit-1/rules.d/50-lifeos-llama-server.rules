// Allow wheel group members to manage llama-server.service without a password.
// This enables Game Guard to offload the LLM from GPU to RAM when a game is
// detected, and restore it when the game exits.
// Uses wheel group so any user created during installation gets access.
polkit.addRule(function(action, subject) {
    if (action.id === "org.freedesktop.systemd1.manage-units" &&
        subject.isInGroup("wheel") &&
        action.lookup("unit") === "llama-server.service") {
        return polkit.Result.YES;
    }
});
